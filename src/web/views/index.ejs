<%
title = 'Главная';
%>

<%- include('layouts/main') %>

<style>
    /* ===== МИНИМАЛИСТИЧНЫЙ ЧЕРНО-БЕЛЫЙ СТИЛЬ ===== */
    :root {
        --bg-primary: #0A0A0A;
        --bg-secondary: #111111;
        --bg-card: rgba(20, 20, 30, 0.6);
        --bg-card-hover: rgba(34, 34, 34, 0.8);
        --border-color: rgba(255, 255, 255, 0.05);
        --border-color-hover: rgba(255, 255, 255, 0.15);
        --text-primary: #FFFFFF;
        --text-secondary: rgba(255, 255, 255, 0.7);
        --text-muted: rgba(255, 255, 255, 0.4);
        --accent-white: #FFFFFF;
        --accent-gray: #9CA3AF;
        --accent-dark: #374151;
        --shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
        --shadow-lg: 0 15px 40px rgba(0, 0, 0, 0.5);
        --glass-bg: rgba(20, 20, 30, 0.4);
        --glass-border: 1px solid rgba(255, 255, 255, 0.03);
        --glass-border-hover: 1px solid rgba(255, 255, 255, 0.1);
        --glass-blur: blur(15px);
        
        /* Шрифты */
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    }

    /* ===== ГЛАВНАЯ СТРАНИЦА ===== */
    .home-page {
        min-height: 100vh;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        background: var(--bg-primary);
        font-family: var(--font-sans);
    }

    /* ===== МИНИМАЛИСТИЧНЫЙ ФОН ===== */
    .background-animation {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 0;
        overflow: hidden;
    }

    .gradient-sphere-1 {
        position: absolute;
        width: 80vmax;
        height: 80vmax;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%, 
            rgba(255, 255, 255, 0.05) 0%, 
            rgba(200, 200, 200, 0.03) 40%, 
            transparent 70%);
        top: -20%;
        right: -10%;
        animation: floatSlow 30s ease-in-out infinite;
        filter: blur(80px);
    }

    .gradient-sphere-2 {
        position: absolute;
        width: 70vmax;
        height: 70vmax;
        border-radius: 50%;
        background: radial-gradient(circle at 70% 70%, 
            rgba(255, 255, 255, 0.05) 0%, 
            rgba(150, 150, 150, 0.03) 40%, 
            transparent 70%);
        bottom: -20%;
        left: -10%;
        animation: floatMedium 25s ease-in-out infinite reverse;
        filter: blur(80px);
    }

    .gradient-sphere-3 {
        position: absolute;
        width: 60vmax;
        height: 60vmax;
        border-radius: 50%;
        background: radial-gradient(circle, 
            rgba(255, 255, 255, 0.03) 0%, 
            rgba(100, 100, 100, 0.02) 30%, 
            transparent 60%);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        animation: pulse 15s ease-in-out infinite;
        filter: blur(90px);
    }

    @keyframes floatSlow {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(3%, -3%) scale(1.1); }
        66% { transform: translate(-2%, 2%) scale(0.95); }
    }

    @keyframes floatMedium {
        0%, 100% { transform: translate(0, 0) scale(1); }
        25% { transform: translate(4%, -4%) scale(1.15); }
        50% { transform: translate(-3%, 3%) scale(0.9); }
        75% { transform: translate(2%, -2%) scale(1.05); }
    }

    @keyframes pulse {
        0%, 100% { 
            opacity: 0.3;
            transform: translate(-50%, -50%) scale(1);
        }
        50% { 
            opacity: 0.5;
            transform: translate(-50%, -50%) scale(1.2);
        }
    }

    /* Частицы фона */
    .bg-particle {
        position: fixed;
        width: 2px;
        height: 2px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        pointer-events: none;
        z-index: -1;
        animation: floatParticle 20s linear infinite;
    }

    @keyframes floatParticle {
        0% {
            transform: translateY(100vh) scale(0);
            opacity: 0;
        }
        10% {
            opacity: 0.5;
        }
        90% {
            opacity: 0.5;
        }
        100% {
            transform: translateY(-100vh) scale(1);
            opacity: 0;
        }
    }

    /* ===== ЦЕНТРАЛЬНЫЙ КОНТЕЙНЕР ===== */
    .center-content {
        position: relative;
        z-index: 1;
        text-align: center;
        max-width: 800px;
        padding: 3rem 4rem;
        animation: fadeIn 0.8s ease-out;
        
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 30px;
        box-shadow: var(--shadow);
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ===== ЛОГОТИП ===== */
    .logo-wrapper {
        margin-bottom: 2rem;
        display: inline-block;
        position: relative;
    }

    .logo-image {
        width: 140px;
        height: 140px;
        border-radius: 30px;
        object-fit: cover;
        border: var(--glass-border);
        box-shadow: var(--shadow);
        transition: all 0.3s ease;
        display: block;
    }

    .logo-image:hover {
        transform: scale(1.05);
        border-color: rgba(255, 255, 255, 0.2);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.5);
    }

    /* ===== ЗАГОЛОВОК ===== */
    .title {
        font-family: var(--font-sans);
        font-size: 3.5rem;
        font-weight: 800;
        letter-spacing: 0.02em;
        line-height: 1.2;
        text-transform: uppercase;
        color: var(--text-primary);
        margin: 0 0 0.5rem 0;
        text-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
    }

    /* Минималистичное подчеркивание */
    .title-underline {
        width: 100px;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--text-primary), transparent);
        margin: 1.5rem auto;
        opacity: 0.2;
    }

    /* ===== ПОДЗАГОЛОВОК ===== */
    .subtitle {
        font-size: 1.2rem;
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
        line-height: 1.6;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
        font-weight: 300;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    /* Официальная строка */
    .official-line {
        font-size: 0.95rem;
        color: var(--text-muted);
        margin: 1rem 0 1.5rem 0;
        letter-spacing: 1px;
        font-weight: 300;
        text-transform: uppercase;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding: 0.8rem 0;
        display: inline-block;
        width: 100%;
    }

    .official-line span {
        color: var(--text-secondary);
        font-weight: 400;
        margin: 0 0.3rem;
    }

    /* Версия */
    .version {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 1.5rem;
        letter-spacing: 0.5px;
        font-family: monospace;
        opacity: 0.5;
    }

    /* ===== НАЗВАНИЕ СЕРВЕРА ===== */
    .server-name {
        display: inline-block;
        font-size: 1.1rem;
        font-weight: 300;
        color: var(--text-secondary);
        padding: 0.5rem 1.5rem;
        border: var(--glass-border);
        border-radius: 40px;
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(5px);
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-transform: uppercase;
    }

    .server-name:hover {
        border-color: rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.03);
        color: var(--text-primary);
    }

    .server-name i {
        font-size: 0.8rem;
        margin: 0 0.3rem;
        opacity: 0.5;
    }

    /* ===== ДЕКОРАТИВНЫЕ ЭЛЕМЕНТЫ ===== */
    .decorative-star {
        position: absolute;
        color: rgba(255, 255, 255, 0.1);
        font-size: 1.5rem;
        pointer-events: none;
        animation: floatStar 15s linear infinite;
    }

    @keyframes floatStar {
        from { transform: rotate(0deg) translateY(0); }
        to { transform: rotate(360deg) translateY(-30px); }
    }

    /* ===== АДАПТИВНОСТЬ ===== */
    @media (max-width: 768px) {
        .title {
            font-size: 2.5rem;
        }

        .logo-image {
            width: 120px;
            height: 120px;
        }

        .server-name {
            font-size: 1rem;
        }
        
        .center-content {
            padding: 2rem;
            margin: 0 1rem;
        }
        
        .subtitle {
            font-size: 1rem;
        }
    }

    @media (max-width: 480px) {
        .title {
            font-size: 1.8rem;
        }

        .logo-image {
            width: 100px;
            height: 100px;
        }

        .server-name {
            font-size: 0.8rem;
            padding: 0.4rem 1rem;
        }

        .subtitle {
            font-size: 0.8rem;
        }
        
        .official-line {
            font-size: 0.8rem;
        }
        
        .version {
            font-size: 0.7rem;
        }
    }
</style>

<!-- Главная страница -->
<div class="home-page">
    <!-- Генерация частиц фона -->
    <script>
        (function() {
            for (let i = 0; i < 20; i++) {
                const particle = document.createElement('div');
                particle.className = 'bg-particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.animationDelay = Math.random() * 20 + 's';
                particle.style.animationDuration = (Math.random() * 20 + 15) + 's';
                particle.style.opacity = Math.random() * 0.3;
                particle.style.width = (Math.random() * 3 + 1) + 'px';
                particle.style.height = particle.style.width;
                document.body.appendChild(particle);
            }
        })();
    </script>

    <!-- Анимированный фон -->
    <div class="background-animation">
        <div class="gradient-sphere-1"></div>
        <div class="gradient-sphere-2"></div>
        <div class="gradient-sphere-3"></div>
    </div>

    <!-- Декоративные звездочки -->
    <div class="decorative-star" style="top: 10%; left: 5%;">✦</div>
    <div class="decorative-star" style="bottom: 15%; right: 8%;">✧</div>
    <div class="decorative-star" style="top: 20%; right: 15%;">✦</div>
    <div class="decorative-star" style="bottom: 25%; left: 12%;">✧</div>

    <!-- Эффект параллакса для фона -->
    <script>
    (function() {
        document.addEventListener('mousemove', (e) => {
            const spheres = document.querySelectorAll('.gradient-sphere-1, .gradient-sphere-2, .gradient-sphere-3');
            const mouseX = e.clientX / window.innerWidth;
            const mouseY = e.clientY / window.innerHeight;

            spheres.forEach((sphere, index) => {
                const speed = 15 + (index * 5);
                const x = (mouseX - 0.5) * speed;
                const y = (mouseY - 0.5) * speed;
                sphere.style.transform = `translate(${x}px, ${y}px)`;
            });
        });
    })();
    </script>

    <!-- Центральный контент -->
    <div class="center-content">
        <!-- Логотип - ОНЛАЙН ИЗОБРАЖЕНИЕ -->
        <div class="logo-wrapper">
            <img 
                src="https://i.yapx.ru/dEuRy.jpg" 
                alt="KINGSIZE Logo" 
                class="logo-image"
                onerror="this.onerror=null; this.src='https://via.placeholder.com/140x140/333/fff?text=KINGSIZE'; console.log('❌ Ошибка загрузки основного логотипа, используем placeholder');"
                onload="console.log('✅ Логотип успешно загружен')"
            >
        </div>
        
        <!-- Заголовок -->
        <h1 class="title">KINGSIZE LEGENDARY BOT</h1>
        
        <!-- Минималистичное подчеркивание -->
        <div class="title-underline"></div>
        
        <!-- Подзаголовок -->
        <div class="subtitle">
            Official Discord Bot
        </div>
        
        <!-- Официальная строка -->
        <div class="official-line">
            разработано для <span>KINGSIZE FAMILY</span>
        </div>
        
        <!-- Автор -->
        <div class="server-name">
            <i class="fas fa-code"></i> ZEPHYR <i class="fas fa-code"></i>
        </div>
        
        <!-- Версия -->
        <div class="version">
            v2.0.0 · 2026
        </div>
    </div>
</div>

