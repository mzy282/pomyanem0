</div>

<script>
(function() {
    'use strict';
    
    const MEMBER_ROLE_ID = '<%= env.MEMBER_ROLE_ID || "1476744899335557171" %>';
    const isOwner = <%= user && user.user_id === env.BOT_OWNER_ID ? 'true' : 'false' %>;
    
    let currentFilter = 'all';
    let applications = [];
    let adminsMap = {};
    let currentAcceptId = null;
    let currentAcceptName = '';
    let currentRejectId = null;
    let currentRejectName = '';
    let currentDeleteId = null;
    let currentDeleteName = '';
    let currentChannelId = '';
    let currentInterviewId = null;
    let currentInterviewData = null;
    let isLoading = false;
    let loadingTimeout = null;

    // Переменные для шаблонов
    let rejectTemplates = [];

    // ===== WEBSOCKET =====
    const socket = io();
    
    socket.on('connect', () => {
        console.log('🔌 WebSocket подключен');
        socket.emit('subscribe_applications');
    });
    
    socket.on('new_application', (data) => {
        console.log('📬 Новая заявка:', data);
        showNotification(`📬 Новая заявка от ${data.username}`, 'success');
        setTimeout(() => {
            loadApplications();
        }, 300);
    });
    
    socket.on('application_updated', () => {
        setTimeout(() => {
            loadApplications();
        }, 300);
    });
    
    socket.on('application_deleted', () => {
        setTimeout(() => {
            loadApplications();
        }, 300);
    });

    // ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====
    // ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====
function formatDate(dateString) {
    if (!dateString) return 'Неизвестно';
    const date = new Date(dateString);
    
    // Конвертируем в московское время (UTC+3)
    const mskDate = new Date(date.toLocaleString('en-US', { timeZone: 'Europe/Moscow' }));
    
    return mskDate.toLocaleString('ru-RU', {
        day: '2-digit',
        month: '2-digit',
        hour: '2-digit',
        minute: '2-digit'
    });
}

    function showNotification(message, type = 'success') {
        const notification = document.createElement('div');
        notification.className = `notification ${type === 'error' ? 'error' : ''}`;
        notification.innerHTML = `
            <i class="fas fa-${type === 'error' ? 'exclamation-circle' : 'check-circle'}"></i>
            <span>${message}</span>
        `;
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.remove();
        }, 3000);
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function truncateText(text, maxLength) {
        if (!text) return '';
        if (text.length <= maxLength) return escapeHtml(text);
        return escapeHtml(text.substring(0, maxLength)) + '...';
    }

    // Функция для преобразования текста в ссылки
    function linkify(text) {
        if (!text) return '';
        
        const urlRegex = /(https?:\/\/[^\s]+)/g;
        
        return text.replace(urlRegex, function(url) {
            return `<a href="${url}" target="_blank" rel="noopener noreferrer">${url}</a>`;
        });
    }

    function showLoading() {
        const overlay = document.getElementById('loadingOverlay');
        if (overlay) {
            overlay.classList.add('show');
        }
        
        if (loadingTimeout) clearTimeout(loadingTimeout);
        loadingTimeout = setTimeout(() => {
            const container = document.getElementById('applicationsTableContainer');
            if (!container) return;
            
            container.innerHTML = `
                <div class="applications-table-container">
                    <table class="applications-table">
                        <thead>
                            <tr>
                                <th>Пользователь</th>
                                <th>Статус</th>
                                <th>Nick/Static</th>
                                <th>Имя / Возраст</th>
                                <th>Опыт</th>
                                <th>Откаты</th>
                                <th>Дата</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${Array(3).fill(0).map(() => `
                                <tr class="loading-skeleton">
                                    <td><div style="height: 18px; width: 120px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                    <td><div style="height: 18px; width: 70px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                    <td><div style="height: 18px; width: 80px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                    <td><div style="height: 18px; width: 100px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                    <td><div style="height: 18px; width: 120px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                    <td><div style="height: 18px; width: 80px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                    <td><div style="height: 18px; width: 100px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
            `;
        }, 200);
    }

    function hideLoading() {
        const overlay = document.getElementById('loadingOverlay');
        if (overlay) {
            overlay.classList.remove('show');
        }
        if (loadingTimeout) {
            clearTimeout(loadingTimeout);
            loadingTimeout = null;
        }
    }

    // ===== МОДАЛЬНЫЕ ОКНА =====
    window.showViewModal = function(application) {
        const modalBody = document.getElementById('viewModalBody');
        const modalFooter = document.getElementById('viewModalFooter');
        
        const statusClass = application.status === 'pending' ? 'pending' :
                          application.status === 'accepted' ? 'accepted' :
                          application.status === 'interview' ? 'interview' : 'rejected';
        
        const statusIcon = application.status === 'pending' ? '⏳' :
                          application.status === 'accepted' ? '✅' :
                          application.status === 'interview' ? '📞' : '❌';
        
        const statusText = application.status === 'pending' ? 'Ожидает' :
                          application.status === 'accepted' ? 'Принят' :
                          application.status === 'interview' ? 'На обзвон' : 'Отклонен';
        
        let adminName = 'Администратор';
        let actionText = 'Обработал';
        
        if (application.reviewed_by) {
            adminName = adminsMap[application.reviewed_by] || application.reviewed_by;
            
            if (application.reviewed_at) {
                if (application.status === 'accepted') {
                    actionText = 'Принял';
                } else if (application.status === 'rejected') {
                    actionText = 'Отклонил';
                } else if (application.status === 'interview') {
                    actionText = 'Назначил обзвон';
                }
            }
        }
        
        let nickStatic = application.nick_static || '';
        let userName = application.user_name || '';
        let age = application.age || '';
        let experienceText = application.play_time_info || 'Не указано';
        let gungLinks = application.gung_links || 'Не указано';
        
        if (!nickStatic && application.full_name) {
            const parts = application.full_name.split(',');
            userName = parts[0]?.trim() || '';
            age = parts[1]?.trim() || '';
            nickStatic = parts[2]?.trim() || '';
        }
        
        modalBody.innerHTML = `
            <div class="modal-profile">
                <img src="${application.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png'}" 
                     alt="" class="modal-avatar"
                     onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                <div class="modal-user-info">
                    <div class="modal-username">${escapeHtml(application.username)}</div>
                    <div class="modal-discord">
                        <i class="fab fa-discord"></i>
                        ${escapeHtml(application.discord_name)}
                    </div>
                    <div class="modal-user-id">ID: ${application.user_id}</div>
                </div>
            </div>
            
            <div style="margin-bottom: 1rem; display: flex; justify-content: space-between; align-items: center;">
                <span class="modal-status ${statusClass}">
                    ${statusIcon} ${statusText}
                </span>
                <span style="color: var(--text-muted); font-size: 0.8rem;">
                    #${application.id}
                </span>
            </div>
            
            ${application.reviewed_by ? `
                <div class="reviewed-info">
                    <i class="fas fa-user-shield"></i>
                    <span>
                        ${actionText}: <strong style="color: var(--accent-purple);">${escapeHtml(adminName)}</strong>
                        <span style="color: var(--text-muted); margin-left: 0.5rem;">${formatDate(application.reviewed_at)}</span>
                    </span>
                </div>
            ` : ''}
            
            ${application.reject_reason ? `
                <div class="reason-info">
                    <i class="fas fa-pen"></i>
                    <span><strong>Причина:</strong> ${escapeHtml(application.reject_reason)}</span>
                </div>
            ` : ''}
            
            <div class="modal-grid">
                <div class="modal-field">
                    <div class="modal-field-label">
                        <i class="fas fa-tag"></i>
                        Nick/Static
                    </div>
                    <div class="modal-field-value">${escapeHtml(nickStatic)}</div>
                </div>
                
                <div class="modal-field">
                    <div class="modal-field-label">
                        <i class="fas fa-user"></i>
                        Имя
                    </div>
                    <div class="modal-field-value">${escapeHtml(userName)}</div>
                </div>
                
                <div class="modal-field">
                    <div class="modal-field-label">
                        <i class="fas fa-birthday-cake"></i>
                        Возраст
                    </div>
                    <div class="modal-field-value">${escapeHtml(age)}</div>
                </div>
            </div>
            
            <div class="modal-field full-width">
                <div class="modal-field-label">
                    <i class="fas fa-gamepad"></i>
                    Опыт игры / Сервера / Семьи / МП
                </div>
                <div class="modal-field-value" style="max-height: 200px; overflow-y: auto; padding: 0.8rem; background: rgba(0,0,0,0.2); border-radius: 12px; white-space: pre-wrap;">
                    ${linkify(escapeHtml(experienceText))}
                </div>
            </div>
            
            <div class="modal-field full-width">
                <div class="modal-field-label">
                    <i class="fas fa-link"></i>
                    Откаты с гангейма
                </div>
                <div class="modal-field-value" style="max-height: 150px; overflow-y: auto; padding: 0.8rem; background: rgba(0,0,0,0.2); border-radius: 12px;">
                    ${linkify(escapeHtml(gungLinks))}
                </div>
            </div>
            
            <div style="display: flex; justify-content: flex-end; color: var(--text-muted); font-size: 0.75rem; margin-top: 0.5rem;">
                <i class="fas fa-calendar-alt" style="margin-right: 0.3rem;"></i>
                Создана: ${formatDate(application.created_at)}
            </div>
        `;
        
        let footerButtons = '<button class="modal-button cancel" onclick="hideViewModal()">Закрыть</button>';
        
        if (application.status === 'pending' || application.status === 'interview') {
            footerButtons = `
                <button class="modal-button cancel" onclick="hideViewModal()">Закрыть</button>
            `;
        }
        
        modalFooter.innerHTML = footerButtons;
        
        document.getElementById('viewModal').classList.add('show');
    };

    window.hideViewModal = function() {
        document.getElementById('viewModal').classList.remove('show');
    };

    window.showAcceptModal = function(id, username) {
        currentAcceptId = id;
        currentAcceptName = username;
        document.getElementById('acceptUserName').textContent = username;
        document.getElementById('acceptNick').value = '';
        document.getElementById('acceptStatic').value = '';
        document.getElementById('acceptModal').classList.add('show');
    };

    window.hideAcceptModal = function() {
        document.getElementById('acceptModal').classList.remove('show');
        currentAcceptId = null;
        currentAcceptName = '';
    };

    window.confirmAccept = async function() {
        if (!currentAcceptId) return;
        
        const acceptBtn = document.getElementById('acceptConfirmBtn');
        const originalText = acceptBtn.innerHTML;
        acceptBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        acceptBtn.disabled = true;
        
        const nick = document.getElementById('acceptNick').value.trim();
        const staticVal = document.getElementById('acceptStatic').value.trim();
        
        if (!nick || !staticVal) {
            showNotification('Заполните все поля', 'error');
            acceptBtn.innerHTML = originalText;
            acceptBtn.disabled = false;
            return;
        }

        try {
            const response = await fetch(`/api/admin/applications/${currentAcceptId}/accept`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nick, static: staticVal })
            });

            const data = await response.json();

            if (data.success) {
                await fetch(`/api/admin/applications/${currentAcceptId}/archive`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                showNotification('✅ Заявка принята');
                hideAcceptModal();
                hideViewModal();
                setTimeout(() => {
                    loadApplications();
                }, 300);
            } else {
                showNotification(data.error || 'Ошибка', 'error');
            }
        } catch (error) {
            showNotification('Ошибка', 'error');
        } finally {
            acceptBtn.innerHTML = originalText;
            acceptBtn.disabled = false;
        }
    };

    window.showRejectModal = function(id, username) {
        currentRejectId = id;
        currentRejectName = username;
        document.getElementById('rejectUserName').textContent = username;
        document.getElementById('rejectReason').value = '';
        document.getElementById('rejectTemplateSelect').value = '';
        document.getElementById('rejectModal').classList.add('show');
    };

    window.hideRejectModal = function() {
        document.getElementById('rejectModal').classList.remove('show');
        currentRejectId = null;
        currentRejectName = '';
    };

    // ===== ФУНКЦИИ ДЛЯ ОБЗВОНА =====
    window.showInterviewConfirmModal = function(id, username, discordName) {
        currentInterviewId = id;
        document.getElementById('interviewUserDiscord').innerHTML = `<i class="fab fa-discord"></i> ${escapeHtml(discordName)}`;
        document.getElementById('interviewConfirmModal').classList.add('show');
    };

    window.hideInterviewConfirmModal = function() {
        document.getElementById('interviewConfirmModal').classList.remove('show');
        currentInterviewId = null;
    };

    window.confirmInterviewSend = async function() {
        if (!currentInterviewId) return;
        
        const confirmBtn = document.getElementById('interviewConfirmBtn');
        const originalText = confirmBtn.innerHTML;
        confirmBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        confirmBtn.disabled = true;
        
        try {
            const response = await fetch(`/api/admin/applications/${currentInterviewId}/send-interview`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });

            const data = await response.json();

            if (data.success) {
                showNotification('✅ Приглашение отправлено');
                
                const statusResponse = await fetch(`/api/admin/applications/${currentInterviewId}/status`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: 'interview' })
                });
                
                const statusData = await statusResponse.json();
                
                if (statusData.success) {
                    hideInterviewConfirmModal();
                    setTimeout(() => {
                        loadApplications();
                    }, 300);
                }
            } else {
                showNotification(data.error || 'Ошибка', 'error');
                confirmBtn.innerHTML = originalText;
                confirmBtn.disabled = false;
            }
        } catch (error) {
            showNotification('Ошибка', 'error');
            confirmBtn.innerHTML = originalText;
            confirmBtn.disabled = false;
        }
    };

    // ===== ФУНКЦИИ ДЛЯ ШАБЛОНОВ ОТКАЗОВ =====
    
    async function loadRejectTemplates() {
        try {
            const response = await fetch('/api/admin/reject-templates');
            const data = await response.json();
            
            if (data.success) {
                rejectTemplates = data.data;
                updateTemplateSelect();
            }
        } catch (error) {
            console.error('Ошибка загрузки шаблонов:', error);
        }
    }

    function updateTemplateSelect() {
        const select = document.getElementById('rejectTemplateSelect');
        if (!select) return;
        
        select.innerHTML = '<option value="">Выберите шаблон...</option>';
        rejectTemplates.forEach(template => {
            select.innerHTML += `<option value="${template.id}">${escapeHtml(template.name)}</option>`;
        });
    }

    function applyRejectTemplate() {
        const templateId = document.getElementById('rejectTemplateSelect').value;
        const reasonArea = document.getElementById('rejectReason');
        
        if (templateId) {
            const template = rejectTemplates.find(t => t.id == templateId);
            if (template) reasonArea.value = template.text;
        }
    }

    function showTemplateManager() {
        document.getElementById('templateManagerModal').classList.add('show');
        loadTemplatesList();
    }

    function hideTemplateManager() {
        document.getElementById('templateManagerModal').classList.remove('show');
    }

    async function loadTemplatesList() {
        const container = document.getElementById('templatesList');
        
        try {
            const response = await fetch('/api/admin/reject-templates');
            const data = await response.json();
            
            if (data.success && data.data.length > 0) {
                container.innerHTML = data.data.map(template => `
                    <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 1rem; margin-bottom: 0.8rem;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                            <strong style="color: var(--accent-purple);">${escapeHtml(template.name)}</strong>
                            <div style="display: flex; gap: 0.5rem;">
                                <button onclick="showEditTemplateModal(${template.id})" class="modal-button" style="padding: 0.3rem 0.8rem; min-width: auto;">✏️</button>
                                <button onclick="deleteTemplate(${template.id})" class="modal-button" style="padding: 0.3rem 0.8rem; min-width: auto; background: rgba(239,68,68,0.1);">🗑️</button>
                            </div>
                        </div>
                        <p style="color: var(--text-secondary); font-size: 0.9rem;">${escapeHtml(template.text)}</p>
                    </div>
                `).join('');
            } else {
                container.innerHTML = '<p style="text-align: center; color: var(--text-muted);">Нет шаблонов</p>';
            }
        } catch (error) {
            console.error('Ошибка загрузки шаблонов:', error);
        }
    }

    async function createTemplate() {
        const name = document.getElementById('newTemplateName').value.trim();
        const text = document.getElementById('newTemplateText').value.trim();
        
        if (!name || !text) {
            showNotification('Заполните все поля', 'error');
            return;
        }
        
        try {
            const response = await fetch('/api/admin/reject-templates', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, text })
            });
            
            const data = await response.json();
            
            if (data.success) {
                showNotification('Шаблон создан');
                document.getElementById('newTemplateName').value = '';
                document.getElementById('newTemplateText').value = '';
                await loadTemplatesList();
                await loadRejectTemplates();
            }
        } catch (error) {
            showNotification('Ошибка', 'error');
        }
    }

    function showEditTemplateModal(id) {
        const template = rejectTemplates.find(t => t.id == id);
        if (template) {
            document.getElementById('editTemplateId').value = template.id;
            document.getElementById('editTemplateName').value = template.name;
            document.getElementById('editTemplateText').value = template.text;
            document.getElementById('editTemplateModal').classList.add('show');
        }
    }

    function hideEditTemplateModal() {
        document.getElementById('editTemplateModal').classList.remove('show');
    }

    async function updateTemplate() {
        const id = document.getElementById('editTemplateId').value;
        const name = document.getElementById('editTemplateName').value.trim();
        const text = document.getElementById('editTemplateText').value.trim();
        
        if (!name || !text) {
            showNotification('Заполните все поля', 'error');
            return;
        }
        
        try {
            const response = await fetch(`/api/admin/reject-templates/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, text })
            });
            
            const data = await response.json();
            
            if (data.success) {
                showNotification('Шаблон обновлен');
                hideEditTemplateModal();
                await loadTemplatesList();
                await loadRejectTemplates();
            }
        } catch (error) {
            showNotification('Ошибка', 'error');
        }
    }

    async function deleteTemplate(id) {
        if (!confirm('Удалить шаблон?')) return;
        
        try {
            const response = await fetch(`/api/admin/reject-templates/${id}`, {
                method: 'DELETE'
            });
            
            const data = await response.json();
            
            if (data.success) {
                showNotification('Шаблон удален');
                await loadTemplatesList();
                await loadRejectTemplates();
            }
        } catch (error) {
            showNotification('Ошибка', 'error');
        }
    }

    window.confirmReject = async function() {
        if (!currentRejectId) return;
        
        const reason = document.getElementById('rejectReason').value.trim();
        
        if (!reason) {
            showNotification('Укажите причину', 'error');
            return;
        }

        try {
            const response = await fetch(`/api/admin/applications/${currentRejectId}/status`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: 'rejected', reason })
            });

            const data = await response.json();

            if (data.success) {
                await fetch(`/api/admin/applications/${currentRejectId}/archive`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                showNotification('❌ Заявка отклонена');
                hideRejectModal();
                hideViewModal();
                setTimeout(() => {
                    loadApplications();
                }, 300);
            } else {
                showNotification(data.error || 'Ошибка', 'error');
            }
        } catch (error) {
            showNotification('Ошибка', 'error');
        }
    };

    window.showDeleteModal = function(id, username) {
        currentDeleteId = id;
        currentDeleteName = username;
        document.getElementById('deleteUserName').textContent = username;
        document.getElementById('deleteModal').classList.add('show');
    };

    window.hideDeleteModal = function() {
        document.getElementById('deleteModal').classList.remove('show');
        currentDeleteId = null;
        currentDeleteName = '';
    };

    window.confirmDelete = async function() {
        if (!currentDeleteId) return;

        try {
            const response = await fetch(`/api/admin/applications/${currentDeleteId}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            });

            const data = await response.json();

            if (data.success) {
                showNotification('🗑️ Заявка удалена');
                hideDeleteModal();
                hideViewModal();
                setTimeout(() => {
                    loadApplications();
                }, 300);
            } else {
                showNotification(data.error || 'Ошибка', 'error');
            }
        } catch (error) {
            showNotification('Ошибка', 'error');
        }
    };

    // ===== ФУНКЦИИ ДЛЯ EMBED =====
    window.showEmbedModal = function() {
        document.getElementById('embedModal').classList.add('show');
        document.getElementById('channelId').value = '';
    };

    window.hideEmbedModal = function() {
        document.getElementById('embedModal').classList.remove('show');
        document.getElementById('channelId').value = '';
    };

    window.hideEmbedConfirmModal = function() {
        document.getElementById('embedConfirmModal').classList.remove('show');
        currentChannelId = '';
    };

    window.prepareEmbedSend = function() {
        const channelId = document.getElementById('channelId').value.trim();
        
        if (!channelId || !/^\d+$/.test(channelId)) {
            showNotification('Введите корректный ID канала', 'error');
            return;
        }
        
        currentChannelId = channelId;
        document.getElementById('confirmChannelId').textContent = channelId;
        hideEmbedModal();
        document.getElementById('embedConfirmModal').classList.add('show');
    };

    window.sendEmbed = async function() {
        if (!currentChannelId) return;
        
        try {
            const response = await fetch('/api/discord/send-embed', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ channelId: currentChannelId })
            });

            const data = await response.json();

            if (data.success) {
                showNotification('✅ Embed отправлен');
                hideEmbedConfirmModal();
            } else {
                showNotification(data.error || 'Ошибка', 'error');
            }
        } catch (error) {
            showNotification('Ошибка', 'error');
        }
    };

    // ===== ФИЛЬТРАЦИЯ =====
    window.filterApplications = function(filter) {
        currentFilter = filter;
        
        document.querySelectorAll('.filter-button').forEach(btn => btn.classList.remove('active'));
        document.getElementById(`filter${filter.charAt(0).toUpperCase() + filter.slice(1)}`).classList.add('active');
        
        const container = document.getElementById('applicationsTableContainer');
        container.style.opacity = '0.5';
        setTimeout(() => {
            renderApplications();
            container.style.opacity = '1';
        }, 200);
    };

    // ===== ИЗМЕНЕНИЕ СТАТУСА =====
    window.changeStatus = async function(id, newStatus) {
        try {
            const application = applications.find(app => app.id === id);
            
            if (newStatus === 'accepted') {
                if (application) showAcceptModal(id, application.username);
            } else if (newStatus === 'rejected') {
                if (application) showRejectModal(id, application.username);
            } else if (newStatus === 'interview') {
                if (application) {
                    showInterviewConfirmModal(id, application.username, application.discord_name);
                }
            }
        } catch (error) {
            showNotification('Ошибка', 'error');
        }
    };

    // ===== ЗАГРУЗКА АДМИНИСТРАТОРОВ =====
    async function loadAdmins() {
        try {
            const response = await fetch('/api/admin/admins');
            const data = await response.json();
            
            if (data.success) {
                adminsMap = {};
                data.data.forEach(admin => {
                    adminsMap[admin.user_id] = admin.username;
                });
            }
        } catch (error) {
            console.error('Ошибка загрузки админов:', error);
        }
    }

    // ===== ЗАГРУЗКА ЗАЯВОК =====
    window.loadApplications = async function() {
        if (isLoading) return;
        
        isLoading = true;
        showLoading();
        
        try {
            const [appsResponse, adminsResponse] = await Promise.all([
                fetch('/api/admin/applications'),
                fetch('/api/admin/admins').catch(() => ({ success: false }))
            ]);
            
            const appsData = await appsResponse.json();
            
            if (appsData.success) {
                applications = appsData.data;
                
                if (adminsResponse.success) {
                    const adminsData = await adminsResponse.json();
                    adminsMap = {};
                    adminsData.data.forEach(admin => {
                        adminsMap[admin.user_id] = admin.username;
                    });
                }
                
                updateStats();
                
                const container = document.getElementById('applicationsTableContainer');
                container.style.opacity = '0';
                
                setTimeout(() => {
                    renderApplications();
                    container.style.opacity = '1';
                    hideLoading();
                }, 200);
            }
        } catch (error) {
            showNotification('Ошибка загрузки', 'error');
            hideLoading();
        } finally {
            isLoading = false;
        }
    };

    // ===== СТАТИСТИКА =====
    function updateStats() {
        const stats = {
            total: applications.filter(app => app.status === 'pending' || app.status === 'interview').length,
            pending: applications.filter(app => app.status === 'pending').length,
            interview: applications.filter(app => app.status === 'interview').length
        };

        document.getElementById('allCountFilter').textContent = stats.total;
        document.getElementById('pendingCountFilter').textContent = stats.pending;
        document.getElementById('interviewCountFilter').textContent = stats.interview;
    }

    // ===== ОТОБРАЖЕНИЕ ЗАЯВОК =====
    function renderApplications() {
        const container = document.getElementById('applicationsTableContainer');
        
        let activeApplications = applications.filter(app => 
            app.status === 'pending' || app.status === 'interview'
        );
        
        let filteredApps = activeApplications;
        if (currentFilter !== 'all') {
            filteredApps = activeApplications.filter(app => app.status === currentFilter);
        }
        
        filteredApps.sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
        
        if (filteredApps.length === 0) {
            container.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-inbox"></i>
                    </div>
                    <h3 class="empty-title">Нет активных заявок</h3>
                    <p class="empty-text">${getEmptyStateText()}</p>
                </div>
            `;
            return;
        }
        
        let tableHtml = `
            <div class="applications-table-container">
                <table class="applications-table">
                    <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Статус</th>
                            <th>Nick/Static</th>
                            <th>Имя / Возраст</th>
                            <th>Опыт</th>
                            <th>Откаты</th>
                            <th>Дата</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
        `;
        
        filteredApps.forEach((app, index) => {
            const statusClass = app.status === 'pending' ? 'pending' : 'interview';
            const statusIcon = app.status === 'pending' ? '⏳' : '📞';
            const statusText = app.status === 'pending' ? 'Ожидает' : 'Обзвон';
            
            let adminName = 'Администратор';
            if (app.reviewed_by) {
                adminName = adminsMap[app.reviewed_by] || app.reviewed_by;
            }
            
            let nickStatic = app.nick_static || '';
            let userName = app.user_name || '';
            let age = app.age || '';
            let experienceText = app.play_time_info || '';
            let gungLinks = app.gung_links || '';
            
            if (!nickStatic && app.full_name) {
                const parts = app.full_name.split(',');
                userName = parts[0]?.trim() || '';
                age = parts[1]?.trim() || '';
                nickStatic = parts[2]?.trim() || '';
            }
            
            const appJson = JSON.stringify(app).replace(/'/g, "\\'").replace(/"/g, '&quot;');
            
            const fadeClass = `fade-enter`;
            const fadeStyle = `transition-delay: ${index * 50}ms;`;
            
            tableHtml += `
                <tr class="${fadeClass}" style="${fadeStyle}">
                    <td>
                        <div class="table-user">
                            <img src="${app.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png'}" 
                                 alt="" class="table-avatar"
                                 onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            <div class="table-user-info">
                                <span class="table-discord">
                                    <i class="fab fa-discord"></i>
                                    ${escapeHtml(app.discord_name)}
                                </span>
                                <span class="table-user-id">${app.user_id}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="table-status ${statusClass}">
                            ${statusIcon} ${statusText}
                        </span>
                    </td>
                    <td>
                        <div class="table-details">
                            <div class="table-detail-item">
                                <i class="fas fa-tag"></i>
                                <span>${escapeHtml(nickStatic) || '—'}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="table-details">
                            <div class="table-detail-item">
                                <i class="fas fa-user"></i>
                                <span>${escapeHtml(userName) || '—'}</span>
                            </div>
                            <div class="table-detail-item">
                                <i class="fas fa-birthday-cake"></i>
                                <span>${escapeHtml(age) || '—'}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="table-details">
                            <div class="table-detail-item">
                                <i class="fas fa-gamepad"></i>
                                <span title="${escapeHtml(experienceText)}">${truncateText(experienceText, 20) || '—'}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="table-details">
                            <div class="table-detail-item">
                                <i class="fas fa-link"></i>
                                <span title="${escapeHtml(gungLinks)}">${truncateText(gungLinks, 15) || '—'}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="table-date">
                            <i class="fas fa-calendar-alt"></i>
                            ${formatDate(app.created_at)}
                        </div>
                        ${app.reviewed_by ? `
                            <div class="table-admin">
                                <i class="fas fa-user-shield"></i>
                                <span class="admin-name">${escapeHtml(adminName)}</span>
                            </div>
                        ` : ''}
                    </td>
                    <td>
                        <div class="table-actions">
                            <button class="table-action-btn view" onclick='showViewModal(${appJson})' title="Просмотр">
                                <i class="fas fa-eye"></i>
                            </button>
                            
                            ${app.status === 'pending' ? `
                                <button class="table-action-btn interview" onclick="changeStatus(${app.id}, 'interview')" title="Обзвон">
                                    <i class="fas fa-phone-alt"></i>
                                </button>
                                <button class="table-action-btn reject" onclick="showRejectModal(${app.id}, '${escapeHtml(app.username)}')" title="Отклонить">
                                    <i class="fas fa-times"></i>
                                </button>
                            ` : ''}
                            
                            ${app.status === 'interview' ? `
                                <button class="table-action-btn accept" onclick="changeStatus(${app.id}, 'accepted')" title="Принять">
                                    <i class="fas fa-check"></i>
                                </button>
                                <button class="table-action-btn reject" onclick="showRejectModal(${app.id}, '${escapeHtml(app.username)}')" title="Отклонить">
                                    <i class="fas fa-times"></i>
                                </button>
                            ` : ''}
                        </div>
                    </td>
                </tr>
            `;
        });
        
        tableHtml += `
                    </tbody>
                </table>
            </div>
        `;
        
        container.innerHTML = tableHtml;
        
        setTimeout(() => {
            document.querySelectorAll('.fade-enter').forEach(el => {
                el.classList.add('fade-enter-active');
            });
        }, 50);
    }

    function getEmptyStateText() {
        switch(currentFilter) {
            case 'pending': return 'Нет ожидающих заявок';
            case 'interview': return 'Нет заявок на обзвоне';
            default: return 'Нет активных заявок';
        }
    }

    // ===== ИНИЦИАЛИЗАЦИЯ =====
    document.addEventListener('DOMContentLoaded', () => {
        loadApplications();
        loadAdmins();
        loadRejectTemplates();
        document.getElementById('filterAll').classList.add('active');
    });

    document.addEventListener('click', (event) => {
        const modals = ['viewModal', 'acceptModal', 'rejectModal', 'deleteModal', 'embedModal', 'embedConfirmModal', 'templateManagerModal', 'editTemplateModal', 'interviewConfirmModal'];
        modals.forEach(modalId => {
            const modal = document.getElementById(modalId);
            if (event.target === modal) {
                if (modalId === 'viewModal') hideViewModal();
                if (modalId === 'acceptModal') hideAcceptModal();
                if (modalId === 'rejectModal') hideRejectModal();
                if (modalId === 'deleteModal') hideDeleteModal();
                if (modalId === 'embedModal') hideEmbedModal();
                if (modalId === 'embedConfirmModal') hideEmbedConfirmModal();
                if (modalId === 'templateManagerModal') hideTemplateManager();
                if (modalId === 'editTemplateModal') hideEditTemplateModal();
                if (modalId === 'interviewConfirmModal') hideInterviewConfirmModal();
            }
        });
    });

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            hideViewModal();
            hideAcceptModal();
            hideRejectModal();
            hideDeleteModal();
            hideEmbedModal();
            hideEmbedConfirmModal();
            hideTemplateManager();
            hideEditTemplateModal();
            hideInterviewConfirmModal();
        }
    });

})();
</script>