    window.showAcceptModal = function(id, username) {
        currentAcceptId = id;
        currentAcceptName = username;
        document.getElementById('acceptUserName').textContent = username;
        document.getElementById('acceptNick').value = '';
        document.getElementById('acceptStatic').value = '';
        
        document.getElementById('acceptNick').addEventListener('input', updateNickPreview);
        document.getElementById('acceptStatic').addEventListener('input', updateNickPreview);
        
        updateNickPreview();
        document.getElementById('acceptModal').classList.add('show');
    };

    window.hideAcceptModal = function() {
        document.getElementById('acceptModal').classList.remove('show');
        
        document.getElementById('acceptNick').removeEventListener('input', updateNickPreview);
        document.getElementById('acceptStatic').removeEventListener('input', updateNickPreview);
        
        currentAcceptId = null;
        currentAcceptName = '';
    };

    window.confirmAccept = async function() {
        if (!currentAcceptId) return;
        
        const acceptBtn = document.getElementById('acceptConfirmBtn');
        const originalText = acceptBtn.innerHTML;
        acceptBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        acceptBtn.disabled = true;
        
        const nick = document.getElementById('acceptNick').value.trim();
        const staticVal = document.getElementById('acceptStatic').value.trim();
        
        if (!nick) {
            showNotification('Введите Nick', 'error');
            acceptBtn.innerHTML = originalText;
            acceptBtn.disabled = false;
            return;
        }
        
        if (!staticVal) {
            showNotification('Введите Static', 'error');
            acceptBtn.innerHTML = originalText;
            acceptBtn.disabled = false;
            return;
        }

        try {
            const response = await fetch(`/api/admin/applications/${currentAcceptId}/accept`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ 
                    nick: nick,
                    static: staticVal
                })
            });

            const data = await response.json();

            if (data.success) {
                if (data.warning) {
                    showNotification(`⚠️ ${data.warning}`, 'warning');
                } else {
                    showNotification(`✅ Заявка принята`);
                }
                hideAcceptModal();
                hideViewModal();
                await loadApplications();
            } else {
                showNotification(data.error || 'Ошибка', 'error');
            }
        } catch (error) {
            console.error('Ошибка:', error);
            showNotification('Ошибка', 'error');
        } finally {
            acceptBtn.innerHTML = originalText;
            acceptBtn.disabled = false;
        }
    };

