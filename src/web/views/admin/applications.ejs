    // Обновление предпросмотра ника
    function updateNickPreview() {
        const nick = document.getElementById('acceptNick').value.trim();
        const staticVal = document.getElementById('acceptStatic').value.trim();
        const preview = document.getElementById('previewNick');
        
        if (nick && staticVal) {
            preview.textContent = `${nick} | ${staticVal}`;
            preview.style.color = 'var(--accent-green)';
        } else if (nick) {
            preview.textContent = `${nick} | Статик`;
            preview.style.color = 'var(--text-secondary)';
        } else if (staticVal) {
            preview.textContent = `Ник | ${staticVal}`;
            preview.style.color = 'var(--text-secondary)';
        } else {
            preview.textContent = 'Ник | Статик';
            preview.style.color = 'var(--text-secondary)';
        }
    }

