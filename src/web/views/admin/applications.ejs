    // ===== ИЗМЕНЕНИЕ СТАТУСА =====
    window.changeStatus = async function(id, newStatus) {
        try {
            if (newStatus === 'accepted') {
                const application = applications.find(app => app.id === id);
                if (application) {
                    showAcceptModal(id, application.username);
                }
                return;
            }

            if (newStatus === 'rejected') {
                const application = applications.find(app => app.id === id);
                if (application) {
                    showRejectModal(id, application.username);
                }
                return;
            }

            if (newStatus === 'interview') {
                const application = applications.find(app => app.id === id);
                if (!application) {
                    showNotification('Заявка не найдена', 'error');
                    return;
                }

                if (!confirm(`Отправить приглашение ${application.username}?`)) {
                    return;
                }

                showNotification('Отправка...', 'success');
                
                const response = await fetch(`/api/admin/applications/${id}/send-interview`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const data = await response.json();

                if (data.success) {
                    showNotification('✅ Приглашение отправлено');
                    
                    const statusResponse = await fetch(`/api/admin/applications/${id}/status`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ status: newStatus })
                    });
                    
                    const statusData = await statusResponse.json();
                    
                    if (statusData.success) {
                        await loadApplications();
                    }
                } else {
                    showNotification(data.error || 'Ошибка', 'error');
                }
                return;
            }

            const response = await fetch(`/api/admin/applications/${id}/status`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ status: newStatus })
            });

            const data = await response.json();

            if (data.success) {
                showNotification(`Статус изменен`);
                await loadApplications();
            } else {
                showNotification(data.error || 'Ошибка', 'error');
            }
        } catch (error) {
            console.error('Ошибка:', error);
            showNotification('Ошибка', 'error');
        }
    };

    // ===== ЗАГРУЗКА АДМИНИСТРАТОРОВ =====
    async function loadAdmins() {
        try {
            const response = await fetch('/api/admin/admins');
            const data = await response.json();
            
            if (data.success) {
                adminsMap = {};
                data.data.forEach(admin => {
                    adminsMap[admin.user_id] = admin.username;
                });
            }
        } catch (error) {
            console.error('Ошибка загрузки админов:', error);
        }
    }

    // ===== ЗАГРУЗКА ЗАЯВОК =====
    window.loadApplications = async function(force = false) {
        const refreshBtn = document.getElementById('refreshBtn');
        if (refreshBtn) {
            refreshBtn.classList.add('loading');
            const icon = refreshBtn.querySelector('i');
            if (icon) icon.classList.add('fa-spin');
        }
        
        showLoading();
        
        try {
            const [appsResponse, adminsResponse] = await Promise.all([
                fetch('/api/admin/applications'),
                fetch('/api/admin/admins').catch(() => ({ success: false }))
            ]);
            
            const appsData = await appsResponse.json();
            
            if (appsData.success) {
                applications = appsData.data;
                
                if (adminsResponse.success) {
                    const adminsData = await adminsResponse.json();
                    adminsMap = {};
                    adminsData.data.forEach(admin => {
                        adminsMap[admin.user_id] = admin.username;
                    });
                }
                
                updateStats();
                renderApplications();
            } else {
                throw new Error(appsData.error || 'Ошибка загрузки');
            }
        } catch (error) {
            console.error('Ошибка загрузки:', error);
            showNotification('Ошибка загрузки', 'error');
            
            const container = document.getElementById('applicationsTableContainer');
            container.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-exclamation-triangle" style="color: #EF4444;"></i>
                    </div>
                    <h3 class="empty-title">Ошибка</h3>
                    <p class="empty-text">Не удалось загрузить заявки</p>
                    <button onclick="loadApplications(true)" class="filter-button" style="margin-top: 1rem;">
                        <i class="fas fa-sync-alt"></i> Повторить
                    </button>
                </div>
            `;
        } finally {
            if (refreshBtn) {
                refreshBtn.classList.remove('loading');
                const icon = refreshBtn.querySelector('i');
                if (icon) icon.classList.remove('fa-spin');
            }
        }
    };

    // ===== ОБНОВЛЕНИЕ СТАТИСТИКИ =====
    function updateStats() {
        const stats = {
            total: applications.length,
            pending: applications.filter(app => app.status === 'pending').length,
            accepted: applications.filter(app => app.status === 'accepted').length,
            interview: applications.filter(app => app.status === 'interview').length,
            rejected: applications.filter(app => app.status === 'rejected').length
        };

        document.getElementById('totalCount').textContent = stats.total;
        document.getElementById('pendingCountFilter').textContent = stats.pending;
        document.getElementById('acceptedCountFilter').textContent = stats.accepted;
        document.getElementById('interviewCountFilter').textContent = stats.interview;
        document.getElementById('rejectedCountFilter').textContent = stats.rejected;
        document.getElementById('allCountFilter').textContent = stats.total;
    }

    // ===== ОТОБРАЖЕНИЕ ЗАЯВОК =====
    function renderApplications() {
        const container = document.getElementById('applicationsTableContainer');
        
        let filteredApps = applications;
        if (currentFilter !== 'all') {
            filteredApps = applications.filter(app => app.status === currentFilter);
        }
        
        filteredApps.sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
        
        if (filteredApps.length === 0) {
            container.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-inbox"></i>
                    </div>
                    <h3 class="empty-title">Нет заявок</h3>
                    <p class="empty-text">${getEmptyStateText()}</p>
                    ${currentFilter !== 'pending' ? `
                        <button onclick="filterApplications('pending')" class="filter-button">
                            <i class="fas fa-clock"></i> Ожидающие
                        </button>
                    ` : ''}
                </div>
            `;
            return;
        }
        
        let tableHtml = `
            <div class="applications-table-container">
                <table class="applications-table">
                    <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Статус</th>
                            <th>Имя / Ник</th>
                            <th>Время / Сервера</th>
                            <th>Опыт / Откаты</th>
                            <th>Дата</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
        `;
        
        filteredApps.forEach(app => {
            const statusClass = app.status === 'pending' ? 'pending' :
                              app.status === 'accepted' ? 'accepted' :
                              app.status === 'interview' ? 'interview' : 'rejected';
            
            const statusIcon = app.status === 'pending' ? '⏳' :
                              app.status === 'accepted' ? '✅' :
                              app.status === 'interview' ? '📞' : '❌';
            
            const statusText = app.status === 'pending' ? 'Ожидает' :
                              app.status === 'accepted' ? 'Принят' :
                              app.status === 'interview' ? 'Обзвон' : 'Отклонен';
            
            const adminName = app.reviewed_by ? (adminsMap[app.reviewed_by] || 'Админ') : null;
            
            const appJson = JSON.stringify(app).replace(/'/g, "\\'").replace(/"/g, '&quot;');
            
            tableHtml += `
                <tr>
                    <td>
                        <div class="table-user">
                            <img src="${app.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png'}" 
                                 alt="" class="table-avatar"
                                 onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            <div class="table-user-info">
                                <span class="table-username">${escapeHtml(app.username)}</span>
                                <span class="table-discord">
                                    <i class="fab fa-discord"></i>
                                    ${escapeHtml(app.discord_name)}
                                </span>
                                <span class="table-user-id">${app.user_id}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="table-status ${statusClass}">
                            ${statusIcon} ${statusText}
                        </span>
                    </td>
                    <td>
                        <div class="table-details">
                            <div class="table-detail-item">
                                <i class="fas fa-user"></i>
                                <span>${escapeHtml(app.full_name ? app.full_name.split(',')[0] : '')}</span>
                            </div>
                            <div class="table-detail-item">
                                <i class="fas fa-tag"></i>
                                <span>${escapeHtml(app.full_name ? app.full_name.split(',')[2] || '' : '')}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="table-details">
                            <div class="table-detail-item">
                                <i class="fas fa-clock"></i>
                                <span>${escapeHtml(app.play_time_info || '')}</span>
                            </div>
                            <div class="table-detail-item">
                                <i class="fas fa-server"></i>
                                <span>${truncateText(app.servers_history || '', 15)}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="table-details">
                            <div class="table-detail-item">
                                <i class="fas fa-gamepad"></i>
                                <span>${truncateText(app.mp_experience || '', 15)}</span>
                            </div>
                            <div class="table-detail-item">
                                <i class="fas fa-link"></i>
                                <span>${truncateText(app.gung_links || '', 15)}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="table-date">
                            <i class="fas fa-calendar-alt"></i>
                            ${formatDate(app.created_at)}
                        </div>
                        ${app.reviewed_by ? `
                            <div class="table-admin">
                                <i class="fas fa-user-shield"></i>
                                <span class="admin-name">${escapeHtml(adminName)}</span>
                            </div>
                        ` : ''}
                        ${app.reject_reason ? `
                            <div class="table-reason" title="${escapeHtml(app.reject_reason)}">
                                <i class="fas fa-pen"></i>
                                <span>${truncateText(app.reject_reason, 10)}</span>
                            </div>
                        ` : ''}
                    </td>
                    <td>
                        <div class="table-actions">
                            <button class="table-action-btn view" onclick='showViewModal(${appJson})' title="Просмотр">
                                <i class="fas fa-eye"></i>
                            </button>
                            
                            ${app.status === 'pending' ? `
                                <button class="table-action-btn interview" onclick="changeStatus(${app.id}, 'interview')" title="Обзвон">
                                    <i class="fas fa-phone-alt"></i>
                                </button>
                                <button class="table-action-btn accept" onclick="changeStatus(${app.id}, 'accepted')" title="Принять">
                                    <i class="fas fa-check"></i>
                                </button>
                                <button class="table-action-btn reject" onclick="showRejectModal(${app.id}, '${escapeHtml(app.username)}')" title="Отклонить">
                                    <i class="fas fa-times"></i>
                                </button>
                            ` : ''}
                            
                            ${app.status === 'interview' ? `
                                <button class="table-action-btn accept" onclick="changeStatus(${app.id}, 'accepted')" title="Принять">
                                    <i class="fas fa-check"></i>
                                </button>
                                <button class="table-action-btn reject" onclick="showRejectModal(${app.id}, '${escapeHtml(app.username)}')" title="Отклонить">
                                    <i class="fas fa-times"></i>
                                </button>
                            ` : ''}
                            
                            <button class="table-action-btn archive" onclick="showArchiveModal(${app.id}, '${escapeHtml(app.username)}', '${app.status}')" title="В архив">
                                <i class="fas fa-archive"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        });
        
        tableHtml += `
                    </tbody>
                </table>
            </div>
        `;
        
        container.innerHTML = tableHtml;
    }

    function getEmptyStateText() {
        switch(currentFilter) {
            case 'pending': return 'Нет ожидающих заявок';
            case 'accepted': return 'Нет принятых заявок';
            case 'interview': return 'Нет заявок на обзвоне';
            case 'rejected': return 'Нет отклоненных заявок';
            default: return 'Пока нет ни одной заявки';
        }
    }

    // ===== ИНИЦИАЛИЗАЦИЯ =====
    document.addEventListener('DOMContentLoaded', () => {
        loadApplications();
        loadAdmins();
        document.getElementById('filterPending').classList.add('active');
    });

    // Закрытие модальных окон по клику вне их
    document.addEventListener('click', (event) => {
        const modals = ['viewModal', 'acceptModal', 'rejectModal', 'deleteModal', 'archiveModal', 'embedModal', 'embedConfirmModal'];
        modals.forEach(modalId => {
            const modal = document.getElementById(modalId);
            if (event.target === modal) {
                if (modalId === 'viewModal') hideViewModal();
                if (modalId === 'acceptModal') hideAcceptModal();
                if (modalId === 'rejectModal') hideRejectModal();
                if (modalId === 'deleteModal') hideDeleteModal();
                if (modalId === 'archiveModal') hideArchiveModal();
                if (modalId === 'embedModal') hideEmbedModal();
                if (modalId === 'embedConfirmModal') hideEmbedConfirmModal();
            }
        });
    });

    // Закрытие по Escape
    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            hideViewModal();
            hideAcceptModal();
            hideRejectModal();
            hideDeleteModal();
            hideArchiveModal();
            hideEmbedModal();
            hideEmbedConfirmModal();
        }
    });

})();
</script>