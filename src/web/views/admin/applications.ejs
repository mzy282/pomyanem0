                <h4 style="margin-bottom: 1rem; color: var(--accent-purple);">Новый шаблон</h4>
                <input type="text" class="modal-input" id="newTemplateName" placeholder="Название шаблона">
                <textarea class="modal-textarea" id="newTemplateText" placeholder="Текст шаблона" rows="2" style="margin-top: 0.5rem;"></textarea>
                <button class="modal-button accept" onclick="createTemplate()" style="width: 100%; margin-top: 1rem;">
                    <i class="fas fa-plus"></i> Добавить
                </button>
            </div>
            
            <h4 style="margin-bottom: 1rem;">Существующие шаблоны</h4>
            <div id="templatesList" style="max-height: 300px; overflow-y: auto;">
                <!-- Шаблоны будут загружаться сюда -->
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно редактирования шаблона -->
<div class="modal" id="editTemplateModal">
    <div class="modal-content" style="max-width: 450px;">
