                       onblur="this.style.borderColor='rgba(139,92,246,0.2)'; this.style.boxShadow='0 4px 15px rgba(0,0,0,0.2)'; this.style.background='linear-gradient(145deg, rgba(0,0,0,0.4), rgba(20,20,30,0.6))'"
