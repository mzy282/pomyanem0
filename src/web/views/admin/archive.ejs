        <div class="modal-footer">
            <button class="modal-button cancel" onclick="hideViewModal()">Закрыть</button>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';

    let currentFilter = 'all';
    let applications = [];
    let adminsMap = {};
    let isLoading = false;
    let loadingTimeout = null;

    // ===== WEBSOCKET =====
    const socket = io();
    
    socket.on('connect', () => {
        console.log('🔌 WebSocket подключен');
        socket.emit('subscribe_archive');
    });

    socket.on('archive_updated', () => {
        console.log('📦 Архив обновлен');
        setTimeout(() => {
            loadArchivedApplications();
        }, 300);
    });

    // ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====
function formatDate(dateString) {
    if (!dateString) return 'Неизвестно';
    const date = new Date(dateString);
    
    // Конвертируем в московское время (UTC+3)
    const mskDate = new Date(date.toLocaleString('en-US', { timeZone: 'Europe/Moscow' }));
    
    return mskDate.toLocaleString('ru-RU', {
        day: '2-digit',
        month: '2-digit',
        hour: '2-digit',
        minute: '2-digit'
    });
}

    function showNotification(message, type = 'success') {
        const notification = document.createElement('div');
        notification.className = `notification ${type === 'error' ? 'error' : ''}`;
        notification.innerHTML = `
            <i class="fas fa-${type === 'error' ? 'exclamation-circle' : 'check-circle'}"></i>
            <span>${message}</span>
        `;
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.remove();
        }, 3000);
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function truncateText(text, maxLength) {
        if (!text) return '';
        if (text.length <= maxLength) return escapeHtml(text);
        return escapeHtml(text.substring(0, maxLength)) + '...';
    }

    function linkify(text) {
        if (!text) return '';
        const urlRegex = /(https?:\/\/[^\s]+)/g;
        return text.replace(urlRegex, function(url) {
            return `<a href="${url}" target="_blank" rel="noopener noreferrer">${url}</a>`;
        });
    }

    function showLoading() {
        const overlay = document.getElementById('loadingOverlay');
        if (overlay) {
            overlay.classList.add('show');
        }
        
        if (loadingTimeout) clearTimeout(loadingTimeout);
        loadingTimeout = setTimeout(() => {
            const container = document.getElementById('archiveTableContainer');
            if (!container) return;
            
            container.innerHTML = `
                <div class="archive-table-container">
                    <table class="archive-table">
                        <thead>
                            <tr>
                                <th>Пользователь</th>
                                <th>Статус</th>
                                <th>Nick/Static</th>
                                <th>Дата решения</th>
                                <th>Администратор</th>
                                <th>Причина</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${Array(3).fill(0).map(() => `
                                <tr class="loading-skeleton">
                                    <td><div style="height: 18px; width: 120px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                    <td><div style="height: 18px; width: 70px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                    <td><div style="height: 18px; width: 80px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                    <td><div style="height: 18px; width: 80px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                    <td><div style="height: 18px; width: 80px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                    <td><div style="height: 18px; width: 100px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                    <td><div style="height: 18px; width: 40px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
            `;
        }, 200);
    }

    function hideLoading() {
        const overlay = document.getElementById('loadingOverlay');
        if (overlay) {
            overlay.classList.remove('show');
        }
        if (loadingTimeout) {
            clearTimeout(loadingTimeout);
            loadingTimeout = null;
        }
    }

    // ===== ЗАГРУЗКА АДМИНИСТРАТОРОВ =====
    async function loadAdmins() {
        try {
            const response = await fetch('/api/admin/admins');
            const data = await response.json();
            
            if (data.success) {
                adminsMap = {};
                data.data.forEach(admin => {
                    adminsMap[admin.user_id] = admin.username;
                });
                console.log('✅ Администраторы загружены:', adminsMap);
            }
        } catch (error) {
            console.error('❌ Ошибка загрузки админов:', error);
        }
    }

    // ===== МОДАЛЬНЫЕ ОКНА =====
    window.showViewModal = function(application) {
        const modalBody = document.getElementById('viewModalBody');
        
        const statusClass = application.status === 'accepted' ? 'accepted' : 'rejected';
        const statusIcon = application.status === 'accepted' ? '✅' : '❌';
        const statusText = application.status === 'accepted' ? 'Принят' : 'Отклонен';
        
        // Получаем имя администратора
        let adminName = 'Администратор';
        let actionText = 'Обработал';
        
        if (application.reviewed_by) {
            adminName = adminsMap[application.reviewed_by] || application.reviewed_by;
            
            if (application.reviewed_at) {
                actionText = application.status === 'accepted' ? 'Принял' : 'Отклонил';
            }
        }
        
        // Получаем данные
        let nickStatic = application.nick_static || '';
        let userName = application.user_name || '';
        let age = application.age || '';
        let experienceText = application.play_time_info || 'Не указано';
        let gungLinks = application.gung_links || 'Не указано';
        let fullName = application.full_name || '';
        
        if (!nickStatic && fullName) {
            const parts = fullName.split(',');
            userName = parts[0]?.trim() || '';
            age = parts[1]?.trim() || '';
            nickStatic = parts[2]?.trim() || '';
        }
        
        modalBody.innerHTML = `
            <div class="modal-profile">
                <img src="${application.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png'}" 
                     alt="" class="modal-avatar"
                     onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                <div class="modal-user-info">
                    <div class="modal-username">${escapeHtml(application.username)}</div>
                    <div class="modal-discord">
                        <i class="fab fa-discord"></i>
                        ${escapeHtml(application.discord_name)}
                    </div>
                    <div class="modal-user-id">ID: ${application.user_id}</div>
                </div>
            </div>
            
            <div style="margin-bottom: 1rem; display: flex; justify-content: space-between; align-items: center;">
                <span class="modal-status ${statusClass}" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.3rem 1rem; border-radius: 30px; background: ${application.status === 'accepted' ? 'rgba(16, 185, 129, 0.15)' : 'rgba(239, 68, 68, 0.15)'}; color: ${application.status === 'accepted' ? '#10B981' : '#EF4444'}; border: 1px solid ${application.status === 'accepted' ? 'rgba(16, 185, 129, 0.3)' : 'rgba(239, 68, 68, 0.3)'};">
                    ${statusIcon} ${statusText}
                </span>
                <span style="color: var(--text-muted); font-size: 0.8rem;">
                    #${application.id}
                </span>
            </div>
            
            ${application.reviewed_by ? `
                <div class="reviewed-info">
                    <i class="fas fa-user-shield"></i>
                    <span>
                        ${actionText}: <strong style="color: var(--accent-purple);">${escapeHtml(adminName)}</strong>
                        <span style="color: var(--text-muted); margin-left: 0.5rem;">${formatDate(application.reviewed_at)}</span>
                    </span>
                </div>
            ` : ''}
            
            ${application.reject_reason ? `
                <div class="reason-info">
                    <i class="fas fa-pen"></i>
                    <span><strong>Причина:</strong> ${escapeHtml(application.reject_reason)}</span>
                </div>
            ` : ''}
            
            <div class="modal-grid">
                <div class="modal-field">
                    <div class="modal-field-label">
                        <i class="fas fa-user"></i>
                        Имя
                    </div>
                    <div class="modal-field-value">${escapeHtml(userName) || 'Не указано'}</div>
                </div>
                
                <div class="modal-field">
                    <div class="modal-field-label">
                        <i class="fas fa-birthday-cake"></i>
                        Возраст
                    </div>
                    <div class="modal-field-value">${escapeHtml(age) || 'Не указано'}</div>
                </div>
                
                <div class="modal-field">
                    <div class="modal-field-label">
                        <i class="fas fa-tag"></i>
                        Nick/Static
                    </div>
                    <div class="modal-field-value">${escapeHtml(nickStatic) || 'Не указано'}</div>
                </div>
            </div>
            
            <div class="modal-field full-width" style="margin-bottom: 0.8rem;">
                <div class="modal-field-label">
                    <i class="fas fa-gamepad"></i>
                    Опыт игры / Сервера / Семьи / МП
                </div>
                <div class="modal-field-value" style="max-height: 150px; overflow-y: auto; padding: 0.5rem; background: rgba(0,0,0,0.2); border-radius: 12px;">
                    ${linkify(escapeHtml(experienceText))}
                </div>
            </div>
            
            <div class="modal-field full-width">
                <div class="modal-field-label">
                    <i class="fas fa-link"></i>
                    Откаты с гангейма
                </div>
                <div class="modal-field-value" style="max-height: 150px; overflow-y: auto; padding: 0.5rem; background: rgba(0,0,0,0.2); border-radius: 12px;">
                    ${linkify(escapeHtml(gungLinks))}
                </div>
            </div>
            
            <div style="display: flex; justify-content: flex-end; color: var(--text-muted); font-size: 0.75rem; margin-top: 0.5rem;">
                <i class="fas fa-calendar-alt" style="margin-right: 0.3rem;"></i>
                Создана: ${formatDate(application.created_at)}
            </div>
        `;
        
        document.getElementById('viewModal').classList.add('show');
    };

    window.hideViewModal = function() {
        document.getElementById('viewModal').classList.remove('show');
    };

    // ===== ФИЛЬТРАЦИЯ =====
    window.filterApplications = function(filter) {
        currentFilter = filter;
        
        document.querySelectorAll('.filter-button').forEach(btn => btn.classList.remove('active'));
        const filterBtn = document.getElementById(`filter${filter.charAt(0).toUpperCase() + filter.slice(1)}`);
        if (filterBtn) filterBtn.classList.add('active');
        
        const container = document.getElementById('archiveTableContainer');
        container.style.opacity = '0.5';
        setTimeout(() => {
            renderApplications();
            container.style.opacity = '1';
        }, 200);
    };

    // ===== ЗАГРУЗКА АРХИВА =====
    window.loadArchivedApplications = async function() {
        if (isLoading) return;
        
        isLoading = true;
        showLoading();
        
        const refreshBtn = document.getElementById('refreshBtn');
        if (refreshBtn) {
            const icon = refreshBtn.querySelector('i');
            if (icon) icon.classList.add('fa-spin');
        }
        
        try {
            console.log('📦 Загрузка архива...');
            
            const [appsResponse, adminsResponse] = await Promise.all([
                fetch('/api/admin/applications/archived'),
                fetch('/api/admin/admins').catch(() => ({ success: false }))
            ]);
            
            const appsData = await appsResponse.json();
            
            if (appsData.success) {
                applications = appsData.data || [];
                
                // Загружаем администраторов
                if (adminsResponse.success) {
                    const adminsData = await adminsResponse.json();
                    adminsMap = {};
                    if (adminsData.data) {
                        adminsData.data.forEach(admin => {
                            adminsMap[admin.user_id] = admin.username;
                        });
                    }
                    console.log('✅ Карта администраторов:', adminsMap);
                } else {
                    // Если не удалось, загружаем отдельно
                    await loadAdmins();
                }
                
                updateStats();
                
                const container = document.getElementById('archiveTableContainer');
                container.style.opacity = '0';
                
                setTimeout(() => {
                    renderApplications();
                    container.style.opacity = '1';
                    hideLoading();
                }, 200);
            } else {
                throw new Error(appsData.error || 'Ошибка загрузки');
            }
        } catch (error) {
            console.error('❌ Ошибка загрузки архива:', error);
            showNotification('Ошибка загрузки архива', 'error');
            
            const container = document.getElementById('archiveTableContainer');
            container.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-exclamation-triangle" style="color: #EF4444;"></i>
                    </div>
                    <h3 class="empty-title">Ошибка загрузки</h3>
                    <p class="empty-text">Не удалось загрузить архив. Попробуйте обновить страницу.</p>
                    <button onclick="loadArchivedApplications()" class="filter-button" style="margin-top: 1rem;">
                        <i class="fas fa-sync-alt"></i> Повторить
                    </button>
                </div>
            `;
            hideLoading();
        } finally {
            isLoading = false;
            if (refreshBtn) {
                const icon = refreshBtn.querySelector('i');
                if (icon) icon.classList.remove('fa-spin');
            }
        }
    };

    // ===== ОБНОВЛЕНИЕ СТАТИСТИКИ =====
    function updateStats() {
        const stats = {
            total: applications.length,
            accepted: applications.filter(app => app.status === 'accepted').length,
            rejected: applications.filter(app => app.status === 'rejected').length
        };

        document.getElementById('totalCount').textContent = stats.total;
        document.getElementById('allCountFilter').textContent = stats.total;
        document.getElementById('acceptedCountFilter').textContent = stats.accepted;
        document.getElementById('rejectedCountFilter').textContent = stats.rejected;
    }

    // ===== ОТОБРАЖЕНИЕ ЗАЯВОК =====
    function renderApplications() {
        const container = document.getElementById('archiveTableContainer');
        
        let filteredApps = applications;
        if (currentFilter !== 'all') {
            filteredApps = applications.filter(app => app.status === currentFilter);
        }
        
        filteredApps.sort((a, b) => new Date(b.reviewed_at || b.created_at) - new Date(a.reviewed_at || a.created_at));
        
        if (filteredApps.length === 0) {
            container.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-archive"></i>
                    </div>
                    <h3 class="empty-title">Архив пуст</h3>
                    <p class="empty-text">В архиве нет заявок</p>
                </div>
            `;
            return;
        }
        
        let tableHtml = `
            <div class="archive-table-container">
                <table class="archive-table">
                    <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Статус</th>
                            <th>Nick/Static</th>
                            <th>Дата решения</th>
                            <th>Администратор</th>
                            <th>Причина</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
        `;
        
        filteredApps.forEach((app, index) => {
            const statusClass = app.status === 'accepted' ? 'accepted' : 'rejected';
            const statusIcon = app.status === 'accepted' ? '✅' : '❌';
            const statusText = app.status === 'accepted' ? 'Принят' : 'Отклонен';
            
            // Получаем имя администратора
            let adminName = 'Администратор';
            if (app.reviewed_by) {
                adminName = adminsMap[app.reviewed_by] || app.reviewed_by;
            }
            
            let nickStatic = app.nick_static || '';
            let fullName = app.full_name || '';
            
            if (!nickStatic && fullName) {
                const parts = fullName.split(',');
                nickStatic = parts[2]?.trim() || '';
            }
            
            const appJson = JSON.stringify(app).replace(/'/g, "\\'").replace(/"/g, '&quot;');
            
            const fadeClass = `fade-enter`;
            const fadeStyle = `transition-delay: ${index * 50}ms;`;
            
            tableHtml += `
                <tr class="${fadeClass}" style="${fadeStyle}">
                    <td>
                        <div class="table-user">
                            <img src="${app.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png'}" 
                                 alt="" class="table-avatar"
                                 onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            <div class="table-user-info">
                                <span class="table-discord">
                                    <i class="fab fa-discord"></i>
                                    ${escapeHtml(app.discord_name)}
                                </span>
                                <span class="table-user-id">${app.user_id}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="table-status ${statusClass}">
                            ${statusIcon} ${statusText}
                        </span>
                    </td>
                    <td>
                        <div class="table-details">
                            <div class="table-detail-item">
                                <i class="fas fa-tag"></i>
                                <span>${escapeHtml(nickStatic) || '—'}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="table-date">
                            <i class="fas fa-calendar-alt"></i>
                            ${formatDate(app.reviewed_at || app.created_at)}
                        </div>
                    </td>
                    <td>
                        <div class="table-admin">
                            <i class="fas fa-user-shield"></i>
                            <span class="admin-name">${escapeHtml(adminName)}</span>
                        </div>
                    </td>
                    <td>
                        ${app.reject_reason ? `
                            <div class="table-reason" title="${escapeHtml(app.reject_reason)}">
                                <i class="fas fa-pen"></i>
                                <span>${truncateText(app.reject_reason, 15)}</span>
                            </div>
                        ` : '<span style="color: var(--text-muted);">—</span>'}
                    </td>
                    <td>
                        <div class="table-actions">
                            <button class="table-action-btn view" onclick='showViewModal(${appJson})' title="Просмотр">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        });
        
        tableHtml += `
                    </tbody>
                </table>
            </div>
        `;
        
        container.innerHTML = tableHtml;
        
        setTimeout(() => {
            document.querySelectorAll('.fade-enter').forEach(el => {
                el.classList.add('fade-enter-active');
            });
        }, 50);
    }

    // ===== ИНИЦИАЛИЗАЦИЯ =====
    document.addEventListener('DOMContentLoaded', () => {
        console.log('📦 Страница архива загружена');
        loadArchivedApplications();
        document.getElementById('filterAll').classList.add('active');
    });

    // Закрытие модального окна
    document.addEventListener('click', (event) => {
        const modal = document.getElementById('viewModal');
        if (event.target === modal) {
            hideViewModal();
        }
    });

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            hideViewModal();
        }
    });

})();
</script>