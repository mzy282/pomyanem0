<!-- Модальное окно просмотра -->
<div class="modal" id="viewModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>
                <i class="fas fa-file-alt"></i>
                Детали заявки
            </h3>
            <button class="modal-close" onclick="hideViewModal()">
                <i class="fas fa-times"></i>
            </button>
