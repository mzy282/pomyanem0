        </div>
        
        <div class="action-buttons-group">
            <div class="total-stats">
                <button class="action-button refresh" onclick="loadArchivedApplications()" id="refreshBtn">
                    <i class="fas fa-sync-alt"></i>
                    <span>Обновить</span>
                </button>
                <div class="total-stat-item">
                    <div class="total-stat-icon">
                        <i class="fas fa-archive"></i>
                    </div>
                    <div class="total-stat-info">
                        <span class="total-stat-label">В архиве</span>
                        <span class="total-stat-number" id="totalCount">0</span>
