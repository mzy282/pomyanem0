<%
title = 'Архив заявок';
%>

<%- include('../layouts/main') %>

<!-- Подключаем Socket.IO -->
<script src="/socket.io/socket.io.js"></script>

<style>
    /* ===== ОСНОВНЫЕ ПЕРЕМЕННЫЕ ===== */
    :root {
        --bg-primary: #0A0A0A;
        --bg-secondary: #111111;
        --bg-card: rgba(26, 26, 26, 0.6);
        --bg-card-hover: rgba(34, 34, 34, 0.8);
        --border-color: rgba(255, 255, 255, 0.05);
        --border-color-hover: rgba(139, 92, 246, 0.2);
        --text-primary: #FFFFFF;
        --text-secondary: rgba(255, 255, 255, 0.7);
        --text-muted: rgba(255, 255, 255, 0.4);
        --accent-blue: #3B82F6;
        --accent-green: #10B981;
        --accent-yellow: #F59E0B;
        --accent-red: #EF4444;
        --accent-purple: #8B5CF6;
        --accent-archive: #6B7280;
        --gradient-archive: linear-gradient(135deg, #6B7280, #4B5563);
        --shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
        --shadow-lg: 0 15px 40px rgba(0, 0, 0, 0.5);
        --glass-bg: rgba(20, 20, 30, 0.4);
        --glass-border: 1px solid rgba(255, 255, 255, 0.03);
        --glass-blur: blur(15px);
    }

    /* ===== АНИМИРОВАННЫЙ ФОН ===== */
    .background-animation {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .gradient-sphere-1 {
        position: absolute;
        width: 80vmax;
        height: 80vmax;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%, 
            rgba(107, 114, 128, 0.2) 0%, 
            rgba(75, 85, 99, 0.15) 40%, 
            rgba(156, 163, 175, 0.1) 70%, 
            transparent 100%);
        top: -20%;
        right: -10%;
        animation: floatSlow 30s ease-in-out infinite;
        filter: blur(60px);
    }

    .gradient-sphere-2 {
        position: absolute;
        width: 70vmax;
        height: 70vmax;
        border-radius: 50%;
        background: radial-gradient(circle at 70% 70%, 
            rgba(75, 85, 99, 0.2) 0%, 
            rgba(107, 114, 128, 0.15) 40%, 
            rgba(156, 163, 175, 0.1) 70%, 
            transparent 100%);
        bottom: -20%;
        left: -10%;
        animation: floatMedium 25s ease-in-out infinite reverse;
        filter: blur(60px);
    }

    @keyframes floatSlow {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(3%, -3%) scale(1.1); }
        66% { transform: translate(-2%, 2%) scale(0.95); }
    }

    @keyframes floatMedium {
        0%, 100% { transform: translate(0, 0) scale(1); }
        25% { transform: translate(4%, -4%) scale(1.15); }
        50% { transform: translate(-3%, 3%) scale(0.9); }
        75% { transform: translate(2%, -2%) scale(1.05); }
    }

    /* ===== ОСНОВНОЙ КОНТЕЙНЕР ===== */
    .archive-content {
        width: 100%;
        max-width: 1600px;
        margin: 2rem auto 0;
        padding: 120px 0 2rem;
        animation: fadeIn 0.6s ease-out;
        position: relative;
        z-index: 1;
    }

    @keyframes fadeIn {
        from { 
            opacity: 0; 
            transform: translateY(20px); 
        }
        to { 
            opacity: 1; 
            transform: translateY(0); 
        }
    }

    /* ===== ВЕРХНЯЯ ПАНЕЛЬ ===== */
    .top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        padding: 1.5rem 2rem;
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 30px;
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
    }

    .top-bar::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--accent-archive), transparent);
    }

    .title-section {
        display: flex;
        align-items: center;
        gap: 1rem;
        position: relative;
        z-index: 1;
    }

    .title-section i {
        font-size: 2rem;
        color: var(--accent-archive);
        filter: drop-shadow(0 0 20px rgba(107, 114, 128, 0.5));
        animation: floatIcon 3s ease-in-out infinite;
    }

    @keyframes floatIcon {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
    }

    .title-section h1 {
        font-size: 2rem;
        font-weight: 800;
        background: linear-gradient(135deg, #fff, var(--accent-archive));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        margin: 0;
    }

    .refresh-button {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.8rem 1.5rem;
        background: rgba(255, 255, 255, 0.05);
        border: var(--glass-border);
        border-radius: 40px;
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.3s ease;
        backdrop-filter: var(--glass-blur);
    }

    .refresh-button:hover {
        background: rgba(107, 114, 128, 0.15);
        border-color: var(--accent-archive);
        color: white;
        transform: translateY(-2px);
    }

    .total-stats {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .total-stat-item {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 0.5rem 1.5rem;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 40px;
        border: var(--glass-border);
        backdrop-filter: var(--glass-blur);
    }

    .total-stat-icon {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        background: rgba(107, 114, 128, 0.15);
        color: var(--accent-archive);
        border: 1px solid rgba(107, 114, 128, 0.3);
    }

    .total-stat-info {
        display: flex;
        flex-direction: column;
    }

    .total-stat-label {
        color: var(--text-secondary);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .total-stat-number {
        font-size: 1.4rem;
        font-weight: 800;
        line-height: 1;
        background: linear-gradient(135deg, #fff, #e0e0e0);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    /* ===== ФИЛЬТРЫ ===== */
    .filters-section {
        display: flex;
        gap: 0.8rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .filter-button {
        padding: 0.7rem 1.5rem;
        border-radius: 40px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        border: var(--glass-border);
        background: rgba(20, 20, 30, 0.2);
        backdrop-filter: var(--glass-blur);
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .filter-button:hover {
        background: rgba(107, 114, 128, 0.25);
        border-color: var(--accent-archive);
        color: white;
        transform: translateY(-2px);
    }

    .filter-button.active {
        background: var(--gradient-archive);
        color: white;
        border-color: transparent;
        box-shadow: 0 10px 25px rgba(107, 114, 128, 0.4);
    }

    .filter-button .count {
        background: rgba(255, 255, 255, 0.1);
        padding: 0.15rem 0.5rem;
        border-radius: 30px;
        font-size: 0.75rem;
    }

    /* ===== ТАБЛИЦА ===== */
    .archive-table-container {
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 30px;
        overflow: hidden;
        box-shadow: var(--shadow);
        margin-bottom: 2rem;
    }

    .archive-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;
    }

    .archive-table th {
        text-align: left;
        padding: 1.2rem 1.5rem;
        background: rgba(0, 0, 0, 0.3);
        color: var(--text-secondary);
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .archive-table td {
        padding: 1.2rem 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        color: var(--text-primary);
        vertical-align: middle;
    }

    .archive-table tbody tr:hover {
        background: rgba(255, 255, 255, 0.02);
    }

    .table-user {
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .table-avatar {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        border: 2px solid var(--accent-archive);
        object-fit: cover;
    }

    .table-username {
        font-weight: 600;
        color: var(--text-primary);
    }

    .table-discord {
        font-size: 0.8rem;
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .table-status {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        border-radius: 60px;
        font-size: 0.8rem;
        font-weight: 600;
        backdrop-filter: var(--glass-blur);
        white-space: nowrap;
    }

    .table-status.accepted {
        background: rgba(16, 185, 129, 0.15);
        color: var(--accent-green);
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .table-status.rejected {
        background: rgba(239, 68, 68, 0.15);
        color: var(--accent-red);
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .table-date {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-secondary);
        font-size: 0.85rem;
    }

    .table-date i {
        color: var(--accent-archive);
    }

    .table-admin {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    .table-admin i {
        color: var(--accent-purple);
    }

    .table-admin .admin-name {
        color: var(--accent-purple);
        font-weight: 500;
    }

    .table-reason {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        color: var(--accent-red);
    }

    .table-actions {
        display: flex;
        gap: 0.5rem;
    }

    .table-action-btn {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        border: none;
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-secondary);
        font-size: 1rem;
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
    }

    .table-action-btn:hover {
        transform: translateY(-2px);
    }

    .table-action-btn.view {
        color: var(--accent-blue);
    }

    .table-action-btn.view:hover {
        background: rgba(59, 130, 246, 0.2);
        color: white;
        border-color: var(--accent-blue);
    }

    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border-radius: 30px;
        border: 1px dashed rgba(255, 255, 255, 0.1);
    }

    .empty-icon {
        font-size: 5rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
        animation: floatIcon 4s ease-in-out infinite;
    }

    .empty-title {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.8rem;
    }

    .empty-text {
        color: var(--text-secondary);
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    .loading-skeleton {
        animation: pulse 1.5s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .notification {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border-left: 4px solid var(--accent-green);
        border-radius: 30px;
        padding: 1.2rem 2rem;
        color: var(--text-primary);
        font-size: 1rem;
        box-shadow: var(--shadow-lg);
        display: flex;
        align-items: center;
        gap: 1rem;
        z-index: 9999;
        animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .notification i {
        color: var(--accent-green);
        font-size: 1.3rem;
    }

    .notification.error {
        border-left-color: var(--accent-red);
        border-color: rgba(239, 68, 68, 0.3);
    }

    .notification.error i {
        color: var(--accent-red);
    }

    @keyframes slideUp {
        from {
            transform: translateY(30px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @keyframes slideDown {
        from {
            transform: translateY(0);
            opacity: 1;
        }
        to {
            transform: translateY(30px);
            opacity: 0;
        }
    }
</style>

<!-- Анимированный фон -->
<div class="background-animation">
    <div class="gradient-sphere-1"></div>
    <div class="gradient-sphere-2"></div>
</div>

<!-- Основной контент -->
<div class="archive-content">
    <!-- Верхняя панель -->
    <div class="top-bar">
        <div class="title-section">
            <i class="fas fa-archive"></i>
            <h1>Архив заявок</h1>
        </div>
        
        <div class="total-stats">
            <button class="refresh-button" onclick="loadArchivedApplications()" id="refreshBtn">
                <i class="fas fa-sync-alt"></i>
                <span>Обновить</span>
            </button>
            <div class="total-stat-item">
                <div class="total-stat-icon">
                    <i class="fas fa-archive"></i>
                </div>
                <div class="total-stat-info">
                    <span class="total-stat-label">В архиве</span>
                    <span class="total-stat-number" id="totalCount">0</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Фильтры -->
    <div class="filters-section">
        <button class="filter-button active" onclick="filterApplications('all')" id="filterAll">
            <i class="fas fa-archive"></i>
            Все
            <span class="count" id="allCountFilter">0</span>
        </button>
        <button class="filter-button" onclick="filterApplications('accepted')" id="filterAccepted">
            <i class="fas fa-check-circle"></i>
            Принятые
            <span class="count" id="acceptedCountFilter">0</span>
        </button>
        <button class="filter-button" onclick="filterApplications('rejected')" id="filterRejected">
            <i class="fas fa-times-circle"></i>
            Отклоненные
            <span class="count" id="rejectedCountFilter">0</span>
        </button>
    </div>

    <!-- Контейнер для таблицы -->
    <div id="archiveTableContainer">
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-archive"></i>
            </div>
            <h3 class="empty-title">Загрузка архива...</h3>
            <p class="empty-text">Пожалуйста, подождите</p>
        </div>
    </div>
</div>

<!-- Модальное окно просмотра -->
<div class="modal" id="viewModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); z-index: 10000; align-items: center; justify-content: center;">
    <div style="background: rgba(20,20,30,0.95); backdrop-filter: blur(15px); border-radius: 30px; padding: 2rem; max-width: 600px; width: 90%; max-height: 85vh; overflow-y: auto; border: 1px solid rgba(255,255,255,0.1);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h3 style="color: white; font-size: 1.5rem;"><i class="fas fa-file-alt" style="color: var(--accent-blue); margin-right: 0.5rem;"></i>Детали заявки</h3>
            <button onclick="hideViewModal()" style="background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer;">&times;</button>
        </div>
        <div id="viewModalBody"></div>
        <div style="display: flex; justify-content: flex-end; margin-top: 1.5rem;">
            <button onclick="hideViewModal()" style="padding: 0.8rem 2rem; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.1); border-radius: 30px; color: white; cursor: pointer;">Закрыть</button>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';

    let currentFilter = 'all';
    let applications = [];
    let adminsMap = {};

    // ===== WEBSOCKET =====
    const socket = io();
    
    socket.on('connect', () => {
        console.log('🔌 WebSocket подключен');
    });

    // ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====
    function formatDate(dateString) {
        if (!dateString) return 'Неизвестно';
        const date = new Date(dateString);
        return date.toLocaleString('ru-RU', {
            day: '2-digit',
            month: '2-digit',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function showNotification(message, type = 'success') {
        // Простая реализация уведомлений
        console.log(`${type}: ${message}`);
        alert(message); // Временно используем alert для простоты
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function showLoading() {
        const container = document.getElementById('archiveTableContainer');
        container.innerHTML = `
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-spinner fa-spin"></i>
                </div>
                <h3 class="empty-title">Загрузка...</h3>
                <p class="empty-text">Пожалуйста, подождите</p>
            </div>
        `;
    }

    // ===== МОДАЛЬНЫЕ ОКНА =====
    window.showViewModal = function(application) {
        const modalBody = document.getElementById('viewModalBody');
        
        const statusClass = application.status === 'accepted' ? 'accepted' : 'rejected';
        const statusIcon = application.status === 'accepted' ? '✅' : '❌';
        const statusText = application.status === 'accepted' ? 'Принят' : 'Отклонен';
        
        const adminName = application.reviewed_by ? (adminsMap[application.reviewed_by] || 'Администратор') : 'Не указан';
        
        modalBody.innerHTML = `
            <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem;">
                <img src="${application.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png'}" 
                     style="width: 80px; height: 80px; border-radius: 20px; border: 3px solid var(--accent-archive); object-fit: cover;"
                     onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                <div>
                    <h2 style="color: white; margin-bottom: 0.3rem;">${escapeHtml(application.username)}</h2>
                    <p style="color: rgba(255,255,255,0.7); margin-bottom: 0.3rem;">
                        <i class="fab fa-discord"></i> ${escapeHtml(application.discord_name)}
                    </p>
                    <p style="color: rgba(255,255,255,0.5); font-size: 0.9rem;">ID: ${application.user_id}</p>
                </div>
            </div>
            
            <div style="margin-bottom: 1rem;">
                <span style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; border-radius: 60px; font-size: 0.9rem; background: ${application.status === 'accepted' ? 'rgba(16, 185, 129, 0.15)' : 'rgba(239, 68, 68, 0.15)'}; color: ${application.status === 'accepted' ? '#10B981' : '#EF4444'}; border: 1px solid ${application.status === 'accepted' ? 'rgba(16, 185, 129, 0.3)' : 'rgba(239, 68, 68, 0.3)'};">
                    ${statusIcon} ${statusText}
                </span>
                <span style="color: rgba(255,255,255,0.5); margin-left: 1rem;">Заявка #${application.id}</span>
            </div>
            
            <div style="background: rgba(0,0,0,0.2); border-radius: 16px; padding: 1rem; margin-bottom: 1rem;">
                <div style="color: rgba(255,255,255,0.7); margin-bottom: 0.5rem;">
                    <i class="fas fa-user-shield" style="color: var(--accent-purple); margin-right: 0.5rem;"></i>
                    Администратор: <strong>${escapeHtml(adminName)}</strong>
                </div>
                <div style="color: rgba(255,255,255,0.5); font-size: 0.9rem;">
                    <i class="fas fa-clock"></i> ${formatDate(application.reviewed_at || application.created_at)}
                </div>
            </div>
            
            ${application.reject_reason ? `
                <div style="background: rgba(239, 68, 68, 0.1); border-radius: 16px; padding: 1rem; margin-bottom: 1rem; border-left: 4px solid var(--accent-red);">
                    <div style="color: var(--accent-red); margin-bottom: 0.5rem;">
                        <i class="fas fa-pen"></i> Причина:
                    </div>
                    <div style="color: white;">${escapeHtml(application.reject_reason)}</div>
                </div>
            ` : ''}
            
            <div style="background: rgba(0,0,0,0.2); border-radius: 16px; padding: 1rem;">
                <p><strong>Полное имя:</strong> ${escapeHtml(application.full_name)}</p>
                <p><strong>Время игры:</strong> ${escapeHtml(application.play_time_info)}</p>
                <p><strong>Серверы:</strong> ${escapeHtml(application.servers_history)}</p>
                <p><strong>Опыт в МП:</strong> ${escapeHtml(application.mp_experience)}</p>
                <p><strong>Откаты:</strong> ${escapeHtml(application.gung_links)}</p>
            </div>
        `;
        
        document.getElementById('viewModal').style.display = 'flex';
    };

    window.hideViewModal = function() {
        document.getElementById('viewModal').style.display = 'none';
    };

    // ===== ФИЛЬТРАЦИЯ =====
    window.filterApplications = function(filter) {
        currentFilter = filter;
        
        document.querySelectorAll('.filter-button').forEach(btn => btn.classList.remove('active'));
        const filterBtn = document.getElementById(`filter${filter.charAt(0).toUpperCase() + filter.slice(1)}`);
        if (filterBtn) filterBtn.classList.add('active');
        
        renderApplications();
    };

    // ===== ЗАГРУЗКА АРХИВА =====
    window.loadArchivedApplications = async function() {
        const refreshBtn = document.getElementById('refreshBtn');
        if (refreshBtn) {
            const icon = refreshBtn.querySelector('i');
            if (icon) icon.classList.add('fa-spin');
        }
        
        showLoading();
        
        try {
            console.log('📦 Загрузка архива...');
            
            const [appsResponse, adminsResponse] = await Promise.all([
                fetch('/api/admin/applications/archived'),
                fetch('/api/admin/admins').catch(() => ({ success: false }))
            ]);
            
            const appsData = await appsResponse.json();
            console.log('📦 Данные архива:', appsData);
            
            if (appsData.success) {
                applications = appsData.data || [];
                
                if (adminsResponse.success) {
                    const adminsData = await adminsResponse.json();
                    adminsMap = {};
                    if (adminsData.data) {
                        adminsData.data.forEach(admin => {
                            adminsMap[admin.user_id] = admin.username;
                        });
                    }
                }
                
                updateStats();
                renderApplications();
            } else {
                throw new Error(appsData.error || 'Ошибка загрузки');
            }
        } catch (error) {
            console.error('❌ Ошибка загрузки архива:', error);
            showNotification('Ошибка загрузки архива', 'error');
            
            const container = document.getElementById('archiveTableContainer');
            container.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-exclamation-triangle" style="color: #EF4444;"></i>
                    </div>
                    <h3 class="empty-title">Ошибка загрузки</h3>
                    <p class="empty-text">Не удалось загрузить архив. Попробуйте обновить страницу.</p>
                    <button onclick="loadArchivedApplications()" class="filter-button" style="margin-top: 1rem;">
                        <i class="fas fa-sync-alt"></i> Повторить
                    </button>
                </div>
            `;
        } finally {
            if (refreshBtn) {
                const icon = refreshBtn.querySelector('i');
                if (icon) icon.classList.remove('fa-spin');
            }
        }
    };

    // ===== ОБНОВЛЕНИЕ СТАТИСТИКИ =====
    function updateStats() {
        const stats = {
            total: applications.length,
            accepted: applications.filter(app => app.status === 'accepted').length,
            rejected: applications.filter(app => app.status === 'rejected').length
        };

        document.getElementById('totalCount').textContent = stats.total;
        document.getElementById('allCountFilter').textContent = stats.total;
        document.getElementById('acceptedCountFilter').textContent = stats.accepted;
        document.getElementById('rejectedCountFilter').textContent = stats.rejected;
    }

    // ===== ОТОБРАЖЕНИЕ ЗАЯВОК =====
    function renderApplications() {
        const container = document.getElementById('archiveTableContainer');
        
        let filteredApps = applications;
        if (currentFilter !== 'all') {
            filteredApps = applications.filter(app => app.status === currentFilter);
        }
        
        filteredApps.sort((a, b) => new Date(b.reviewed_at || b.created_at) - new Date(a.reviewed_at || a.created_at));
        
        if (filteredApps.length === 0) {
            container.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-archive"></i>
                    </div>
                    <h3 class="empty-title">Архив пуст</h3>
                    <p class="empty-text">В архиве нет заявок</p>
                </div>
            `;
            return;
        }
        
        let tableHtml = `
            <div class="archive-table-container">
                <table class="archive-table">
                    <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Статус</th>
                            <th>Имя</th>
                            <th>Дата решения</th>
                            <th>Администратор</th>
                            <th>Причина</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
        `;
        
        filteredApps.forEach(app => {
            const statusClass = app.status === 'accepted' ? 'accepted' : 'rejected';
            const statusIcon = app.status === 'accepted' ? '✅' : '❌';
            const statusText = app.status === 'accepted' ? 'Принят' : 'Отклонен';
            
            const adminName = app.reviewed_by ? (adminsMap[app.reviewed_by] || 'Администратор') : 'Не указан';
            
            const appJson = JSON.stringify(app).replace(/'/g, "\\'").replace(/"/g, '&quot;');
            
            tableHtml += `
                <tr>
                    <td>
                        <div class="table-user">
                            <img src="${app.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png'}" 
                                 alt="" class="table-avatar"
                                 onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            <div class="table-user-info">
                                <span class="table-username">${escapeHtml(app.username)}</span>
                                <span class="table-discord">
                                    <i class="fab fa-discord"></i>
                                    ${escapeHtml(app.discord_name)}
                                </span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="table-status ${statusClass}">
                            ${statusIcon} ${statusText}
                        </span>
                    </td>
                    <td>${escapeHtml(app.full_name ? app.full_name.split(',')[0] : 'Не указано')}</td>
                    <td>
                        <div class="table-date">
                            <i class="fas fa-calendar-alt"></i>
                            ${formatDate(app.reviewed_at || app.created_at)}
                        </div>
                    </td>
                    <td>
                        <div class="table-admin">
                            <i class="fas fa-user-shield"></i>
                            <span class="admin-name">${escapeHtml(adminName)}</span>
                        </div>
                    </td>
                    <td>
                        ${app.reject_reason ? `
                            <div class="table-reason" title="${escapeHtml(app.reject_reason)}">
                                <i class="fas fa-pen"></i>
                                <span>${escapeHtml(app.reject_reason.substring(0, 30))}${app.reject_reason.length > 30 ? '...' : ''}</span>
                            </div>
                        ` : '<span style="color: var(--text-muted);">—</span>'}
                    </td>
                    <td>
                        <div class="table-actions">
                            <button class="table-action-btn view" onclick='showViewModal(${appJson})' title="Просмотр">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        });
        
        tableHtml += `
                    </tbody>
                </table>
            </div>
        `;
        
        container.innerHTML = tableHtml;
    }

    // ===== ИНИЦИАЛИЗАЦИЯ =====
    document.addEventListener('DOMContentLoaded', () => {
        console.log('📦 Страница архива загружена');
        loadArchivedApplications();
    });

    // Закрытие модального окна по клику вне его
    document.addEventListener('click', (event) => {
        const modal = document.getElementById('viewModal');
        if (event.target === modal) {
            hideViewModal();
        }
    });

    // Закрытие по Escape
    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            hideViewModal();
        }
    });

})();
</script>