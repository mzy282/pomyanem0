<!-- Модальное окно подтверждения удаления -->
<div class="modal" id="deleteAdminModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>
                <i class="fas fa-exclamation-triangle" style="color: #EF4444;"></i>
                Подтверждение удаления
            </h3>
            <button class="modal-close" onclick="hideDeleteAdminModal()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="modal-body">
            <p>Удалить администратора <strong id="deleteAdminName"></strong>?</p>
        </div>
        <div class="modal-footer">
            <button class="modal-button cancel" onclick="hideDeleteAdminModal()">Отмена</button>
            <button class="modal-button confirm" onclick="confirmDeleteAdmin()">Удалить</button>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    let socket = null;
    let currentDeleteUserId = null;
    let currentDeleteUserName = '';
    let previousStats = {
        totalUsers: 0,
        onlineUsers: 0,
        voiceUsers: 0
    };

    function formatNumber(num) {
        return new Intl.NumberFormat('ru-RU').format(num || 0);
    }

    function updateStats(data) {
        if (!data || !data.stats) return;

        const stats = data.stats;
        
        // Обновляем числа
        document.getElementById('totalUsers').textContent = formatNumber(stats.totalUsers);
        document.getElementById('onlineUsers').textContent = formatNumber(stats.onlineMembers);
        document.getElementById('voiceUsers').textContent = formatNumber(stats.voiceMembers);
        document.getElementById('onlineAdmins').textContent = formatNumber(stats.onlineAdmins);
        document.getElementById('totalAdmins').textContent = formatNumber(stats.totalAdmins || 0);

        // Обновляем проценты
        const onlinePercent = stats.onlinePercent || 0;
        document.getElementById('onlinePercentValue').textContent = onlinePercent + '%';
        
        // Обновляем тренды
        updateTrend('totalUsers', stats.totalUsers, previousStats.totalUsers);
        updateTrend('onlineUsers', stats.onlineMembers, previousStats.onlineUsers);
        updateTrend('voiceUsers', stats.voiceMembers, previousStats.voiceUsers);
        
        // Обновляем количество голосовых каналов
        document.getElementById('voiceChannelsCount').textContent = 
            (stats.voiceChannels || 0) + ' ' + getChannelWord(stats.voiceChannels);

        // Сохраняем для следующего сравнения
        previousStats = {
            totalUsers: stats.totalUsers,
            onlineUsers: stats.onlineMembers,
            voiceUsers: stats.voiceMembers
        };
    }

    function updateTrend(elementId, current, previous) {
        const trendElement = document.getElementById(elementId + 'Trend');
        if (!trendElement) return;

        const icon = trendElement.querySelector('i');
        const text = trendElement.querySelector('span');
        
        if (current > previous) {
            icon.className = 'fas fa-arrow-up';
            trendElement.className = 'stat-trend up';
            text.textContent = '+' + (current - previous) + ' за минуту';
        } else if (current < previous) {
            icon.className = 'fas fa-arrow-down';
            trendElement.className = 'stat-trend down';
            text.textContent = '-' + (previous - current) + ' за минуту';
        } else {
            icon.className = 'fas fa-minus';
            trendElement.className = 'stat-trend';
            text.textContent = 'нет изменений';
        }
    }

    function getChannelWord(count) {
        if (count % 10 === 1 && count % 100 !== 11) return 'канал';
        if ([2, 3, 4].includes(count % 10) && ![12, 13, 14].includes(count % 100)) return 'канала';
        return 'каналов';
    }

    // ===== МОДАЛЬНЫЕ ОКНА =====
    window.showAddAdminModal = function() {
        document.getElementById('addAdminModal').classList.add('show');
    };

    window.hideAddAdminModal = function() {
        document.getElementById('addAdminModal').classList.remove('show');
        document.getElementById('newAdminId').value = '';
    };

    window.showDeleteAdminModal = function(userId, username) {
        currentDeleteUserId = userId;
        currentDeleteUserName = username;
        document.getElementById('deleteAdminName').textContent = username;
        document.getElementById('deleteAdminModal').classList.add('show');
    };

    window.hideDeleteAdminModal = function() {
        document.getElementById('deleteAdminModal').classList.remove('show');
        currentDeleteUserId = null;
        currentDeleteUserName = '';
    };

    window.addAdmin = async function() {
        const userId = document.getElementById('newAdminId').value.trim();
        
        if (!userId) {
            alert('Введите Discord ID');
            return;
        }

        try {
            const response = await fetch('/api/admin/admins', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId })
            });

            const data = await response.json();
            
            if (data.success) {
                alert('Администратор добавлен');
                hideAddAdminModal();
                loadAdmins();
            } else {
                alert(data.error || 'Ошибка');
            }
        } catch (error) {
            console.error('Ошибка:', error);
            alert('Ошибка при добавлении');
        }
    };

    window.confirmDeleteAdmin = async function() {
        if (!currentDeleteUserId) return;

        try {
            const response = await fetch('/api/admin/admins', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: currentDeleteUserId })
            });

            const data = await response.json();
            
            if (data.success) {
                alert('Администратор удален');
                hideDeleteAdminModal();
                loadAdmins();
            } else {
                alert(data.error || 'Ошибка');
            }
        } catch (error) {
            console.error('Ошибка:', error);
            alert('Ошибка при удалении');
        }
    };

    // ===== ЗАГРУЗКА АДМИНИСТРАТОРОВ =====
    async function loadAdmins() {
        try {
            const response = await fetch('/api/admin/admins');
            const data = await response.json();
            
            const tbody = document.getElementById('adminsTable');
            
            if (data.success && data.data.length > 0) {
                tbody.innerHTML = data.data.map(admin => {
                    const roleClass = admin.role === 'superadmin' ? 'superadmin' : 'admin';
                    const roleIcon = admin.role === 'superadmin' ? '⚜️' : '🛡️';
                    
                    return `
                        <tr>
                            <td>
                                <div class="user-cell">
                                    <img src="${admin.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png'}" 
                                         alt="" class="user-avatar"
                                         onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                                    <span>${admin.username || 'Unknown'}</span>
                                </div>
                            </td>
                            <td><code>${admin.user_id}</code></td>
                            <td>
                                <span class="role-badge ${roleClass}">
                                    ${roleIcon} ${admin.role}
                                </span>
                            </td>
                            <td>${admin.updated_at ? new Date(admin.updated_at).toLocaleDateString() : 'Неизвестно'}</td>
                            <td style="text-align: right;">
                                <div class="action-buttons">
                                    <button class="action-button delete" 
                                            onclick="showDeleteAdminModal('${admin.user_id}', '${admin.username || admin.user_id}')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    `;
                }).join('');
            } else {
                tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 2rem;">Нет администраторов</td></tr>';
            }
        } catch (error) {
            console.error('Ошибка загрузки администраторов:', error);
        }
    }

    // ===== ЗАГРУЗКА СТАТИСТИКИ =====
    async function loadStats() {
        try {
            const response = await fetch('/api/stats');
            const data = await response.json();
            
            if (data.success) {
                updateStats(data);
                
                // Обновляем бейджи
                const appsResponse = await fetch('/api/admin/applications/stats');
                const appsData = await appsResponse.json();
                
                if (appsData.success) {
                    const pendingBadge = document.getElementById('applicationsBadge');
                    if (appsData.data.pending > 0) {
                        pendingBadge.textContent = appsData.data.pending;
                        pendingBadge.style.display = 'block';
                    } else {
                        pendingBadge.style.display = 'none';
                    }
                    
                    const excludedBadge = document.getElementById('excludedBadge');
                    const excludedCount = (appsData.data.rejected || 0) + (appsData.data.blacklisted || 0);
                    if (excludedCount > 0) {
                        excludedBadge.textContent = excludedCount;
                        excludedBadge.style.display = 'block';
                    } else {
                        excludedBadge.style.display = 'none';
                    }
                }
            }
        } catch (error) {
            console.error('Ошибка загрузки статистики:', error);
        }
    }

    // ===== WEBSOCKET =====
    function connectWebSocket() {
        try {
            socket = io({
                reconnection: true,
                reconnectionAttempts: 5,
                reconnectionDelay: 1000
            });
            
            socket.on('connect', () => {
                console.log('WebSocket подключен');
                socket.emit('subscribe_stats');
                socket.emit('subscribe_applications');
            });
            
            socket.on('stats_update', (data) => {
                if (data.success) {
                    updateStats(data);
                }
            });

            socket.on('application_updated', () => {
                loadStats();
            });

            socket.on('new_application', () => {
                loadStats();
            });
            
        } catch (error) {
            console.error('Ошибка WebSocket:', error);
        }
    }

    // ===== ПРОВЕРКА ВЛАДЕЛЬЦА =====
    async function checkOwner() {
        // Опционально: можно добавить проверку владельца
    }

    // ===== ИНИЦИАЛИЗАЦИЯ =====
    document.addEventListener('DOMContentLoaded', () => {
        loadAdmins();
        loadStats();
        connectWebSocket();
        checkOwner();
        
        // Обновляем статистику каждые 30 секунд
        setInterval(loadStats, 30000);
    });

    // Закрытие модальных окон
    document.addEventListener('click', (event) => {
        const addModal = document.getElementById('addAdminModal');
        const deleteModal = document.getElementById('deleteAdminModal');
        
        if (event.target === addModal) hideAddAdminModal();
        if (event.target === deleteModal) hideDeleteAdminModal();
    });

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            hideAddAdminModal();
            hideDeleteAdminModal();
        }
    });

})();
</script>