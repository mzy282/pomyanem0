<% 
title = 'Админ-панель';
%>

<%- include('../layouts/main') %>

<!-- Подключаем Socket.IO -->
<script src="/socket.io/socket.io.js"></script>

<style>
    /* ===== ОСНОВНЫЕ ПЕРЕМЕННЫЕ ===== */
    :root {
        --bg-primary: #0A0A0A;
        --bg-secondary: #111111;
        --bg-card: rgba(26, 26, 26, 0.6);
        --bg-card-hover: rgba(34, 34, 34, 0.8);
        --border-color: rgba(255, 255, 255, 0.05);
        --border-color-hover: rgba(139, 92, 246, 0.3);
        --text-primary: #FFFFFF;
        --text-secondary: rgba(255, 255, 255, 0.7);
        --text-muted: rgba(255, 255, 255, 0.4);
        --accent-blue: #3B82F6;
        --accent-green: #10B981;
        --accent-yellow: #F59E0B;
        --accent-red: #EF4444;
        --accent-purple: #8B5CF6;
        --accent-voice: #EC4899;
        --gradient-primary: linear-gradient(135deg, #3B82F6, #8B5CF6, #EC4899);
        --shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
        --shadow-lg: 0 15px 40px rgba(0, 0, 0, 0.5);
        --glass-bg: rgba(20, 20, 30, 0.4);
        --glass-border: 1px solid rgba(255, 255, 255, 0.03);
        --glass-border-hover: 1px solid rgba(139, 92, 246, 0.2);
        --glass-blur: blur(15px);
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    }

    /* ===== АНИМИРОВАННЫЙ ФОН ===== */
    .background-animation {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .gradient-sphere-1 {
        position: absolute;
        width: 80vmax;
        height: 80vmax;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%, 
            rgba(59, 130, 246, 0.2) 0%, 
            rgba(139, 92, 246, 0.15) 40%, 
            rgba(236, 72, 153, 0.1) 70%, 
            transparent 100%);
        top: -20%;
        right: -10%;
        animation: floatSlow 30s ease-in-out infinite;
        filter: blur(60px);
    }

    .gradient-sphere-2 {
        position: absolute;
        width: 70vmax;
        height: 70vmax;
        border-radius: 50%;
        background: radial-gradient(circle at 70% 70%, 
            rgba(236, 72, 153, 0.2) 0%, 
            rgba(139, 92, 246, 0.15) 40%, 
            rgba(59, 130, 246, 0.1) 70%, 
            transparent 100%);
        bottom: -20%;
        left: -10%;
        animation: floatMedium 25s ease-in-out infinite reverse;
        filter: blur(60px);
    }

    .gradient-sphere-3 {
        position: absolute;
        width: 60vmax;
        height: 60vmax;
        border-radius: 50%;
        background: radial-gradient(circle, 
            rgba(139, 92, 246, 0.15) 0%, 
            rgba(59, 130, 246, 0.1) 30%, 
            rgba(236, 72, 153, 0.05) 60%, 
            transparent 100%);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        animation: pulse 15s ease-in-out infinite;
        filter: blur(70px);
    }

    @keyframes floatSlow {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(3%, -3%) scale(1.1); }
        66% { transform: translate(-2%, 2%) scale(0.95); }
    }

    @keyframes floatMedium {
        0%, 100% { transform: translate(0, 0) scale(1); }
        25% { transform: translate(4%, -4%) scale(1.15); }
        50% { transform: translate(-3%, 3%) scale(0.9); }
        75% { transform: translate(2%, -2%) scale(1.05); }
    }

    @keyframes pulse {
        0%, 100% { 
            opacity: 0.3;
            transform: translate(-50%, -50%) scale(1);
        }
        50% { 
            opacity: 0.6;
            transform: translate(-50%, -50%) scale(1.3);
        }
    }

    /* Декоративные звездочки */
    .decorative-star {
        position: fixed;
        color: rgba(255, 255, 255, 0.15);
        font-size: 2rem;
        pointer-events: none;
        animation: floatStar 10s linear infinite;
        z-index: 0;
    }

    @keyframes floatStar {
        from { transform: rotate(0deg) translateY(0); }
        to { transform: rotate(360deg) translateY(-20px); }
    }

    /* ===== ОСНОВНОЙ КОНТЕЙНЕР ===== */
    .admin-content {
        width: 100%;
        max-width: 1600px;
        margin: 120px auto 0;
        padding: 0 2rem;
        animation: fadeIn 0.6s ease-out;
        position: relative;
        z-index: 1;
    }

    @keyframes fadeIn {
        from { 
            opacity: 0; 
            transform: translateY(20px); 
        }
        to { 
            opacity: 1; 
            transform: translateY(0); 
        }
    }

    /* ===== ВЕРХНЯЯ ПАНЕЛЬ ===== */
    .top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        padding: 1.5rem 2rem;
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 30px;
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
    }

    .top-bar::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(139, 92, 246, 0.1) 0%, transparent 70%);
        animation: rotate 30s linear infinite;
        pointer-events: none;
    }

    .top-bar::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--accent-purple), var(--accent-voice), transparent);
    }

    @keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .title-section {
        display: flex;
        align-items: center;
        gap: 1rem;
        position: relative;
        z-index: 1;
    }

    .title-section i {
        font-size: 2rem;
        color: var(--accent-purple);
        filter: drop-shadow(0 0 20px rgba(139, 92, 246, 0.5));
        animation: floatIcon 3s ease-in-out infinite;
    }

    @keyframes floatIcon {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-5px) rotate(5deg); }
    }

    .title-section h1 {
        font-size: 2rem;
        font-weight: 800;
        background: linear-gradient(135deg, #fff, var(--accent-purple), var(--accent-voice));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        margin: 0;
        letter-spacing: -0.5px;
    }

    /* ===== НОВАЯ ПЛИТКА С УЧАСТНИКАМИ ===== */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 30px;
        padding: 1.5rem;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        border-color: var(--accent-purple);
        box-shadow: 0 10px 30px rgba(139, 92, 246, 0.2);
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(139, 92, 246, 0.1) 0%, transparent 70%);
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

    .stat-card:hover::before {
        opacity: 1;
    }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin-bottom: 1rem;
        background: rgba(139, 92, 246, 0.15);
        color: var(--accent-purple);
        border: 1px solid rgba(139, 92, 246, 0.3);
    }

    .stat-icon.users {
        background: rgba(59, 130, 246, 0.15);
        color: var(--accent-blue);
        border-color: rgba(59, 130, 246, 0.3);
    }

    .stat-icon.online {
        background: rgba(16, 185, 129, 0.15);
        color: var(--accent-green);
        border-color: rgba(16, 185, 129, 0.3);
    }

    .stat-icon.voice {
        background: rgba(236, 72, 153, 0.15);
        color: var(--accent-voice);
        border-color: rgba(236, 72, 153, 0.3);
    }

    .stat-icon.admins {
        background: rgba(245, 158, 11, 0.15);
        color: var(--accent-yellow);
        border-color: rgba(245, 158, 11, 0.3);
    }

    .stat-info {
        flex: 1;
    }

    .stat-label {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .stat-label .badge {
        font-size: 0.7rem;
        padding: 0.2rem 0.6rem;
        border-radius: 30px;
        background: rgba(236, 72, 153, 0.2);
        color: var(--accent-voice);
        border: 1px solid rgba(236, 72, 153, 0.3);
        text-transform: none;
        letter-spacing: normal;
        animation: pulse 2s infinite;
    }

    .stat-number {
        font-size: 2.5rem;
        font-weight: 800;
        line-height: 1;
        background: linear-gradient(135deg, #fff, #e0e0e0);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        letter-spacing: -1px;
        margin-bottom: 0.3rem;
    }

    .stat-small {
        font-size: 1rem;
        color: var(--text-secondary);
        margin-top: 0.3rem;
        font-weight: 500;
    }

    .stat-trend {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .stat-trend i {
        font-size: 0.8rem;
    }

    .stat-trend.up {
        color: var(--accent-green);
    }

    .stat-trend.down {
        color: var(--accent-red);
    }

    .coming-soon {
        position: relative;
        cursor: help;
    }

    .coming-soon:hover::after {
        content: '⚡ Скоро будет доступно';
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(20, 20, 30, 0.9);
        backdrop-filter: var(--glass-blur);
        color: var(--accent-voice);
        padding: 0.5rem 1rem;
        border-radius: 30px;
        font-size: 0.8rem;
        white-space: nowrap;
        border: 1px solid rgba(236, 72, 153, 0.3);
        box-shadow: var(--shadow);
        z-index: 10;
        pointer-events: none;
    }

    /* ===== СЕКЦИЯ УПРАВЛЕНИЯ АДМИНАМИ ===== */
    .admin-section {
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 30px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

    .admin-section::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(139, 92, 246, 0.05) 0%, transparent 70%);
        opacity: 0.3;
        animation: rotate 25s linear infinite;
        pointer-events: none;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: var(--glass-border);
        position: relative;
        z-index: 1;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--text-primary);
    }

    .section-title i {
        color: var(--accent-purple);
        font-size: 1.5rem;
        filter: drop-shadow(0 0 10px rgba(139, 92, 246, 0.3));
    }

    .add-button {
        background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
        color: white;
        border: none;
        border-radius: 50px;
        padding: 0.7rem 1.5rem;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        box-shadow: 0 5px 15px rgba(59, 130, 246, 0.3);
        position: relative;
        overflow: hidden;
    }

    .add-button::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s ease;
    }

    .add-button:hover::before {
        left: 100%;
    }

    .add-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(139, 92, 246, 0.4);
    }

    /* ===== ТАБЛИЦА ===== */
    .table-responsive {
        overflow-x: auto;
        border-radius: 20px;
        position: relative;
        z-index: 1;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        text-align: left;
        padding: 1rem;
        color: var(--text-secondary);
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: var(--glass-border);
        background: rgba(0, 0, 0, 0.2);
    }

    td {
        padding: 1rem;
        color: var(--text-primary);
        border-bottom: 1px solid rgba(255, 255, 255, 0.02);
        transition: background 0.3s ease;
    }

    tr:hover td {
        background: rgba(139, 92, 246, 0.05);
    }

    .user-cell {
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        border: 2px solid var(--accent-purple);
        object-fit: cover;
    }

    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.3rem 0.8rem;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 500;
        backdrop-filter: var(--glass-blur);
    }

    .role-badge.superadmin {
        background: rgba(139, 92, 246, 0.15);
        color: var(--accent-purple);
        border: 1px solid rgba(139, 92, 246, 0.3);
    }

    .role-badge.admin {
        background: rgba(59, 130, 246, 0.15);
        color: var(--accent-blue);
        border: 1px solid rgba(59, 130, 246, 0.3);
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
        justify-content: flex-end;
    }

    .action-button {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        border: var(--glass-border);
        background: rgba(255, 255, 255, 0.02);
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: var(--glass-blur);
    }

    .action-button:hover {
        background: rgba(59, 130, 246, 0.15);
        color: var(--accent-blue);
        transform: scale(1.1);
        border-color: var(--accent-blue);
    }

    .action-button.delete:hover {
        background: rgba(239, 68, 68, 0.15);
        color: var(--accent-red);
        border-color: var(--accent-red);
    }

    /* ===== КАРТОЧКИ МЕНЮ ===== */
    .menu-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .menu-card {
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 30px;
        padding: 2rem 1.5rem;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow);
        cursor: pointer;
        text-decoration: none;
        display: block;
    }

    .menu-card:hover {
        transform: translateY(-5px);
        border-color: var(--accent-purple);
        box-shadow: var(--shadow-lg);
    }

    .menu-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(139, 92, 246, 0.1) 0%, transparent 70%);
        opacity: 0;
        transition: opacity 0.6s ease;
        pointer-events: none;
    }

    .menu-card:hover::before {
        opacity: 1;
        animation: rotate 15s linear infinite;
    }

    .menu-icon {
        width: 80px;
        height: 80px;
        border-radius: 30px;
        background: linear-gradient(145deg, rgba(139, 92, 246, 0.15), rgba(139, 92, 246, 0.05));
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2.5rem;
        color: var(--accent-purple);
        transition: all 0.3s ease;
        border: 1px solid rgba(139, 92, 246, 0.2);
    }

    .menu-card:hover .menu-icon {
        transform: scale(1.1) rotate(5deg);
        background: linear-gradient(145deg, rgba(139, 92, 246, 0.25), rgba(139, 92, 246, 0.15));
    }

    .menu-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .menu-description {
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.6;
    }

    .menu-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: linear-gradient(135deg, var(--accent-red), var(--accent-purple));
        color: white;
        padding: 0.2rem 0.8rem;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 600;
        animation: pulse 2s infinite;
    }

    /* ===== МОДАЛЬНЫЕ ОКНА ===== */
    .modal {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: var(--glass-blur);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        visibility: hidden;
        transition: all 0.4s ease;
    }

    .modal.show {
        opacity: 1;
        visibility: visible;
    }

    .modal-content {
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 40px;
        padding: 2rem;
        max-width: 450px;
        width: 90%;
        position: relative;
        transform: translateY(-30px) scale(0.95);
        transition: all 0.4s ease;
        box-shadow: var(--shadow-lg);
    }

    .modal.show .modal-content {
        transform: translateY(0) scale(1);
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: var(--glass-border);
    }

    .modal-header h3 {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.5rem;
        color: var(--text-primary);
    }

    .modal-close {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: var(--glass-border);
        background: rgba(255, 255, 255, 0.02);
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-close:hover {
        background: rgba(239, 68, 68, 0.15);
        color: #EF4444;
        transform: rotate(90deg);
    }

    .modal-input {
        width: 100%;
        padding: 0.8rem 1.2rem;
        background: rgba(0, 0, 0, 0.3);
        border: var(--glass-border);
        border-radius: 60px;
        color: var(--text-primary);
        font-size: 0.95rem;
        margin-bottom: 1rem;
    }

    .modal-input:focus {
        outline: none;
        border-color: var(--accent-purple);
        box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.15);
    }

    .modal-footer {
        display: flex;
        gap: 1rem;
        justify-content: flex-end;
    }

    .modal-button {
        padding: 0.8rem 1.5rem;
        border-radius: 60px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.3s ease;
        border: none;
        backdrop-filter: var(--glass-blur);
    }

    .modal-button.cancel {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-secondary);
        border: var(--glass-border);
    }

    .modal-button.cancel:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    .modal-button.add {
        background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
        color: white;
        box-shadow: 0 5px 15px rgba(59, 130, 246, 0.3);
    }

    .modal-button.add:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(139, 92, 246, 0.4);
    }

    .modal-button.confirm {
        background: linear-gradient(135deg, var(--accent-red), #B91C1C);
        color: white;
        box-shadow: 0 5px 15px rgba(239, 68, 68, 0.3);
    }

    /* ===== АДАПТИВНОСТЬ ===== */
    @media (max-width: 1200px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .menu-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .admin-content {
            padding: 0 1rem;
            margin: 220px auto 0;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .menu-grid {
