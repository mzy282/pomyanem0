<script>
(function() {
    'use strict';
    
    let excluded = [];
    let adminsMap = {};
    let currentFilter = 'all';
    let currentSearch = '';
    let isLoading = false;

    // ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====
    function formatDate(dateString) {
        if (!dateString) return 'Неизвестно';
        const date = new Date(dateString);
        return date.toLocaleString('ru-RU', {
            day: '2-digit',
            month: '2-digit',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function formatDateShort(dateString) {
        if (!dateString) return 'Неизвестно';
        const date = new Date(dateString);
        return date.toLocaleDateString('ru-RU', {
            day: '2-digit',
            month: '2-digit',
            year: 'numeric'
        });
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function truncateText(text, maxLength) {
        if (!text) return '';
        if (text.length <= maxLength) return escapeHtml(text);
        return escapeHtml(text.substring(0, maxLength)) + '...';
    }

    function showNotification(message, type = 'success') {
        const notification = document.createElement('div');
        notification.className = `notification ${type === 'error' ? 'error' : ''}`;
        notification.innerHTML = `
            <i class="fas fa-${type === 'error' ? 'exclamation-circle' : 'check-circle'}"></i>
            <span>${message}</span>
        `;
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.style.animation = 'slideDown 0.3s ease-in forwards';
            setTimeout(() => notification.remove(), 300);
        }, 3000);
    }

    function showLoading() {
        const grid = document.getElementById('excludedGrid');
        grid.innerHTML = Array(6).fill(0).map(() => `
            <div class="skeleton-card loading-skeleton">
                <div class="skeleton-header"></div>
                <div style="display: flex; align-items: center; margin-bottom: 1rem;">
                    <div class="skeleton-avatar"></div>
                    <div style="flex: 1;">
                        <div class="skeleton-line" style="width: 70%;"></div>
                        <div class="skeleton-line" style="width: 50%;"></div>
                    </div>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 1rem;">
                    <div class="skeleton-line" style="height: 60px;"></div>
                    <div class="skeleton-line" style="height: 60px;"></div>
                </div>
                <div class="skeleton-line" style="height: 80px;"></div>
                <div class="skeleton-line" style="height: 40px; margin-top: 1rem;"></div>
            </div>
        `).join('');
    }

    // ===== МОДАЛЬНЫЕ ОКНА =====
    window.showViewModal = function(item) {
        const modalBody = document.getElementById('viewModalBody');
        
        const statusClass = item.status === 'rejected' ? 'rejected' :
                          item.status === 'excluded' ? 'excluded' :
                          item.status === 'blacklisted' ? 'blacklisted' : 'rejected';
        
        const statusIcon = item.status === 'rejected' ? '❌' :
                          item.status === 'excluded' ? '⚠️' :
                          item.status === 'blacklisted' ? '🚫' : '❌';
        
        const statusText = item.status === 'rejected' ? 'Отклонен' :
                          item.status === 'excluded' ? 'Исключен' :
                          item.status === 'blacklisted' ? 'В черном списке' : 'Отклонен';
        
        const adminName = item.reviewed_by ? (adminsMap[item.reviewed_by] || 'Администратор') : null;
        
        let actionText = 'Обработал';
        if (item.status === 'rejected') {
            actionText = 'Отклонил';
        } else if (item.status === 'excluded') {
            actionText = 'Исключил';
        } else if (item.status === 'blacklisted') {
            actionText = 'Заблокировал';
        }
        
        // ИСПРАВЛЕНО: используем новые поля из заявки
        modalBody.innerHTML = `
            <div class="modal-profile">
                <img src="${item.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png'}" 
                     alt="" class="modal-avatar"
                     onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                <div class="modal-user-info">
                    <div class="modal-username">${escapeHtml(item.username)}</div>
                    <div class="modal-discord">
                        <i class="fab fa-discord"></i>
                        ${escapeHtml(item.discord_name)}
                    </div>
                    <div class="modal-user-id">ID: ${item.user_id}</div>
                </div>
            </div>
            
            <div style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
                <span class="status-badge ${statusClass}" style="display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.3rem 1rem; border-radius: 50px; font-size: 0.9rem; font-weight: 600;">
                    ${statusIcon} ${statusText}
                </span>
                <span style="color: var(--text-muted);">Заявка #${item.id}</span>
            </div>
            
            ${item.reviewed_by ? `
                <div class="reviewed-info" style="margin-bottom: 1rem;">
                    <i class="fas fa-user-shield"></i>
                    <span>
                        ${actionText}: <span class="admin-name">${escapeHtml(adminName)}</span>
                        <span style="color: var(--text-muted); margin-left: 0.5rem;">${formatDate(item.reviewed_at)}</span>
                    </span>
                </div>
            ` : ''}
            
            ${item.reject_reason ? `
                <div class="reason-info" style="margin-bottom: 1rem;">
                    <i class="fas fa-pen"></i>
                    <span class="reason-text" style="white-space: normal;">${escapeHtml(item.reject_reason)}</span>
                </div>
            ` : ''}
            
            <div class="modal-grid">
                <div class="modal-field">
                    <div class="modal-field-label">
                        <i class="fas fa-user"></i>
                        Полное имя
                    </div>
                    <div class="modal-field-value">${escapeHtml(item.full_name) || 'Не указано'}</div>
                </div>
                
                <div class="modal-field">
                    <div class="modal-field-label">
                        <i class="fas fa-clock"></i>
                        Время игры
                    </div>
                    <div class="modal-field-value">${escapeHtml(item.play_time_info) || 'Не указано'}</div>
                </div>
            </div>
            
            <div class="modal-field full-width" style="margin-bottom: 1rem;">
                <div class="modal-field-label">
                    <i class="fas fa-server"></i>
                    Серверы и семьи
                </div>
                <div class="modal-field-value" style="max-height: 200px; overflow-y: auto; padding: 0.8rem; background: rgba(0,0,0,0.2); border-radius: 16px;">
                    ${escapeHtml(item.servers_history) || 'Не указано'}
                </div>
            </div>
            
            <div class="modal-field full-width" style="margin-bottom: 1rem;">
                <div class="modal-field-label">
                    <i class="fas fa-gamepad"></i>
                    Опыт в МП
                </div>
                <div class="modal-field-value" style="max-height: 200px; overflow-y: auto; padding: 0.8rem; background: rgba(0,0,0,0.2); border-radius: 16px;">
                    ${escapeHtml(item.mp_experience) || 'Не указано'}
                </div>
            </div>
            
            <div class="modal-field full-width" style="margin-bottom: 1rem;">
                <div class="modal-field-label">
                    <i class="fas fa-link"></i>
                    Откаты с ГГ
                </div>
                <div class="modal-field-value" style="max-height: 200px; overflow-y: auto; padding: 0.8rem; background: rgba(0,0,0,0.2); border-radius: 16px;">
                    ${escapeHtml(item.gung_links) || 'Не указано'}
                </div>
            </div>
            
            <div style="display: flex; justify-content: flex-end; color: var(--text-muted); font-size: 0.85rem;">
                <i class="fas fa-calendar-alt" style="margin-right: 0.5rem;"></i>
                Создана: ${formatDate(item.created_at)}
            </div>
        `;
        
        document.getElementById('viewModal').classList.add('show');
    };

    window.hideViewModal = function() {
        document.getElementById('viewModal').classList.remove('show');
    };

    // ===== ФИЛЬТРАЦИЯ =====
    window.filterExcluded = function(filter) {
        currentFilter = filter;
        
        document.querySelectorAll('.filter-button').forEach(btn => btn.classList.remove('active'));
        const filterBtn = document.getElementById(`filter${filter.charAt(0).toUpperCase() + filter.slice(1)}`);
        if (filterBtn) filterBtn.classList.add('active');
        
        document.querySelectorAll('.stat-card').forEach(card => card.classList.remove('active'));
        if (filter === 'all') document.getElementById('statAll').classList.add('active');
        else if (filter === 'rejected') document.getElementById('statRejected').classList.add('active');
        else if (filter === 'excluded') document.getElementById('statExcluded').classList.add('active');
        else if (filter === 'blacklisted') document.getElementById('statBlacklisted').classList.add('active');
        
        renderExcluded();
    };

    window.searchExcluded = function() {
        currentSearch = document.getElementById('searchInput').value.toLowerCase();
        const clearBtn = document.getElementById('clearSearchBtn');
        
        if (currentSearch) {
            clearBtn.style.display = 'block';
        } else {
            clearBtn.style.display = 'none';
        }
        
        renderExcluded();
    };

    window.clearSearch = function() {
        document.getElementById('searchInput').value = '';
        currentSearch = '';
        document.getElementById('clearSearchBtn').style.display = 'none';
        renderExcluded();
    };

    // ===== ЗАГРУЗКА ДАННЫХ =====
    window.loadExcluded = async function(force = false) {
        if (isLoading && !force) return;
        
        isLoading = true;
        const refreshBtn = document.getElementById('refreshBtn');
        refreshBtn.classList.add('loading');
        
        showLoading();
        
        try {
            const [appsResponse, adminsResponse] = await Promise.all([
                fetch('/api/admin/applications'),
                fetch('/api/admin/admins').catch(() => ({ success: false }))
            ]);
            
            const appsData = await appsResponse.json();
            
            if (appsData.success) {
                excluded = appsData.data.filter(app => 
                    app.status === 'rejected' || 
                    app.status === 'excluded' || 
                    app.status === 'blacklisted'
                );
                
                if (adminsResponse.success) {
                    const adminsData = await adminsResponse.json();
                    adminsMap = {};
                    adminsData.data.forEach(admin => {
                        adminsMap[admin.user_id] = admin.username;
                    });
                }
                
                updateStats();
                renderExcluded();
            } else {
                throw new Error(appsData.error || 'Ошибка загрузки');
            }
        } catch (error) {
            console.error('Ошибка загрузки данных:', error);
            showNotification('Ошибка загрузки данных', 'error');
            
            const grid = document.getElementById('excludedGrid');
            grid.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-exclamation-triangle" style="color: #EF4444;"></i>
                    </div>
                    <h3 class="empty-title">Ошибка загрузки</h3>
                    <p class="empty-text">Не удалось загрузить данные</p>
                    <button onclick="loadExcluded(true)" class="filter-button" style="margin-top: 1rem;">
                        <i class="fas fa-sync-alt"></i> Повторить
                    </button>
                </div>
            `;
        } finally {
            isLoading = false;
            refreshBtn.classList.remove('loading');
        }
    };

    // ===== ОБНОВЛЕНИЕ СТАТИСТИКИ =====
    function updateStats() {
        const stats = {
            total: excluded.length,
            rejected: excluded.filter(app => app.status === 'rejected').length,
            excluded: excluded.filter(app => app.status === 'excluded').length,
            blacklisted: excluded.filter(app => app.status === 'blacklisted').length
        };

        document.getElementById('totalCount').textContent = stats.total;
        document.getElementById('rejectedCount').textContent = stats.rejected;
        document.getElementById('excludedCount').textContent = stats.excluded;
        document.getElementById('blacklistedCount').textContent = stats.blacklisted;

        document.getElementById('filterTotalCount').textContent = stats.total;
        document.getElementById('filterRejectedCount').textContent = stats.rejected;
        document.getElementById('filterExcludedCount').textContent = stats.excluded;
        document.getElementById('filterBlacklistedCount').textContent = stats.blacklisted;
    }

    // ===== ОТОБРАЖЕНИЕ =====
    function renderExcluded() {
        const grid = document.getElementById('excludedGrid');
        
        let filtered = excluded;
        
        if (currentFilter !== 'all') {
            filtered = filtered.filter(app => app.status === currentFilter);
        }
        
        if (currentSearch) {
            filtered = filtered.filter(app => 
                (app.username && app.username.toLowerCase().includes(currentSearch)) ||
                (app.discord_name && app.discord_name.toLowerCase().includes(currentSearch)) ||
                (app.user_id && app.user_id.includes(currentSearch)) ||
                (app.reject_reason && app.reject_reason.toLowerCase().includes(currentSearch)) ||
                (app.full_name && app.full_name.toLowerCase().includes(currentSearch)) ||
                (app.gung_links && app.gung_links.toLowerCase().includes(currentSearch))
            );
        }
        
        filtered.sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
        
        if (filtered.length === 0) {
            grid.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-user-slash"></i>
                    </div>
                    <h3 class="empty-title">Нет записей</h3>
                    <p class="empty-text">${getEmptyStateText()}</p>
                    ${currentSearch ? '<button onclick="clearSearch()" class="filter-button" style="margin-top: 1rem;">Очистить поиск</button>' : ''}
                </div>
            `;
            return;
        }
        
        grid.innerHTML = filtered.map(item => {
            const statusClass = item.status === 'rejected' ? 'rejected' :
                              item.status === 'excluded' ? 'excluded' :
                              item.status === 'blacklisted' ? 'blacklisted' : 'rejected';
            
            const statusIcon = item.status === 'rejected' ? '❌' :
                              item.status === 'excluded' ? '⚠️' :
                              item.status === 'blacklisted' ? '🚫' : '❌';
            
            const statusText = item.status === 'rejected' ? 'Отклонен' :
                              item.status === 'excluded' ? 'Исключен' :
                              item.status === 'blacklisted' ? 'В черном списке' : 'Отклонен';
            
            const adminName = item.reviewed_by ? (adminsMap[item.reviewed_by] || 'Администратор') : null;
            
            let actionText = 'Обработал';
            if (item.status === 'rejected') {
                actionText = 'Отклонил';
            } else if (item.status === 'excluded') {
                actionText = 'Исключил';
            } else if (item.status === 'blacklisted') {
                actionText = 'Заблокировал';
            }
            
            const itemJson = JSON.stringify(item).replace(/'/g, "\\'").replace(/"/g, '&quot;');
            
            return `
                <div class="excluded-card">
                    <div class="card-header">
                        <span class="status-badge ${statusClass}">
                            ${statusIcon} ${statusText}
                        </span>
                        <span class="application-id">#${item.id}</span>
                    </div>
                    
                    <div class="user-info">
                        <img src="${item.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png'}" 
                             alt="" class="user-avatar"
                             onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                        <div class="user-details">
                            <div class="user-name">${escapeHtml(item.username)}</div>
                            <div class="user-discord">
                                <i class="fab fa-discord"></i>
                                ${escapeHtml(item.discord_name)}
                            </div>
                        </div>
                    </div>
                    
                    <div class="user-details-grid">
                        <div class="detail-item">
                            <div class="detail-label">
                                <i class="fas fa-user"></i>
                                Имя
                            </div>
                            <div class="detail-value">${escapeHtml(item.full_name ? item.full_name.split(',')[0] : 'Не указано')}</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">
                                <i class="fas fa-clock"></i>
                                Время игры
                            </div>
                            <div class="detail-value">${truncateText(item.play_time_info || '', 15)}</div>
                        </div>
                    </div>
                    
                    <div class="time-info">
                        <div class="time-item">
                            <i class="fas fa-calendar-plus"></i>
                            <span>Создана: ${formatDateShort(item.created_at)}</span>
                        </div>
                        ${item.reviewed_at ? `
                            <div class="time-item">
                                <i class="fas fa-calendar-check"></i>
                                <span>${actionText}: ${formatDateShort(item.reviewed_at)}</span>
                            </div>
                        ` : ''}
                    </div>
                    
                    ${item.reviewed_by ? `
                        <div class="reviewed-info">
                            <i class="fas fa-user-shield"></i>
                            <span>
                                ${actionText}: <span class="admin-name">${escapeHtml(adminName)}</span>
                            </span>
                        </div>
                    ` : ''}
                    
                    ${item.reject_reason ? `
                        <div class="reason-info" title="${escapeHtml(item.reject_reason)}">
                            <i class="fas fa-pen"></i>
                            <span class="reason-text">${truncateText(item.reject_reason, 50)}</span>
                        </div>
                    ` : ''}
                    
                    <div class="card-actions">
                        <button class="action-button view" onclick='showViewModal(${itemJson})'>
                            <i class="fas fa-eye"></i>
                            Подробнее
                        </button>
                    </div>
                </div>
            `;
        }).join('');
    }

    function getEmptyStateText() {
        switch(currentFilter) {
            case 'rejected': return 'Нет отклоненных заявок';
            case 'excluded': return 'Нет исключенных участников';
            case 'blacklisted': return 'Нет пользователей в черном списке';
            default: return 'Нет записей';
        }
    }

    // ===== ЭКСПОРТ В CSV (ИСПРАВЛЕНО) =====
    window.exportToCSV = function() {
        if (excluded.length === 0) {
            showNotification('Нет данных для экспорта', 'error');
            return;
        }
        
        const data = excluded.map(item => ({
            ID: item.id,
            'User ID': item.user_id,
            Имя: item.username,
            Discord: item.discord_name,
            Статус: item.status === 'rejected' ? 'Отклонен' : 
                   item.status === 'excluded' ? 'Исключен' : 'Черный список',
            'Полное имя': item.full_name || '',
            'Время игры': item.play_time_info || '',
            'Серверы': item.servers_history || '',
            'Опыт в МП': item.mp_experience || '',
            'Откаты': item.gung_links || '',
            Причина: item.reject_reason || '',
            Создана: new Date(item.created_at).toLocaleDateString('ru-RU'),
            Обработана: item.reviewed_at ? new Date(item.reviewed_at).toLocaleDateString('ru-RU') : ''
        }));
        
        const csv = convertToCSV(data);
        const blob = new Blob(["\uFEFF" + csv], { type: 'text/csv;charset=utf-8;' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `excluded_${new Date().toISOString().split('T')[0]}.csv`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        window.URL.revokeObjectURL(url);
        
        showNotification(`Экспортировано ${data.length} записей`, 'success');
    };

    function convertToCSV(arr) {
        const array = [Object.keys(arr[0])].concat(arr);
        return array.map(row => {
            return Object.values(row).map(value => {
                return typeof value === 'string' ? `"${value.replace(/"/g, '""')}"` : value;
            }).join(';');
        }).join('\n');
    }

    // ===== WEBSOCKET =====
    function connectWebSocket() {
        try {
            const socket = io({
                reconnection: true,
                reconnectionAttempts: 5,
                reconnectionDelay: 1000
            });
            
            socket.on('connect', () => {
                console.log('🔌 WebSocket подключен');
                socket.emit('subscribe_applications');
            });
            
            socket.on('disconnect', () => {
                console.log('🔌 WebSocket отключен');
            });
            
            socket.on('reconnect', () => {
                console.log('🔌 WebSocket переподключен');
                socket.emit('subscribe_applications');
                loadExcluded();
            });
            
            socket.on('application_updated', () => {
                loadExcluded();
            });
            
            socket.on('application_deleted', () => {
                loadExcluded();
            });
            
        } catch (error) {
            console.error('Ошибка при создании WebSocket:', error);
        }
    }

    // ===== ИНИЦИАЛИЗАЦИЯ =====
    document.addEventListener('DOMContentLoaded', () => {
        loadExcluded();
        connectWebSocket();
        
        document.getElementById('statAll').classList.add('active');
    });

    // Закрытие модального окна
    document.addEventListener('click', (event) => {
        const modal = document.getElementById('viewModal');
        if (event.target === modal) {
            hideViewModal();
        }
    });

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            hideViewModal();
        }
    });

})();
</script>