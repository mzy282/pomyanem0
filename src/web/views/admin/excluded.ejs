<% 
title = 'Исключенные и отклоненные';
%>

<%- include('../layouts/main') %>

<!-- Подключаем Socket.IO -->
<script src="/socket.io/socket.io.js"></script>

<style>
    /* ===== ОСНОВНЫЕ ПЕРЕМЕННЫЕ ===== */
    :root {
        --bg-primary: #0A0A0A;
        --bg-secondary: #111111;
        --bg-card: rgba(26, 26, 26, 0.6);
        --bg-card-hover: rgba(34, 34, 34, 0.8);
        --border-color: rgba(255, 255, 255, 0.05);
        --border-color-hover: rgba(239, 68, 68, 0.3);
        --text-primary: #FFFFFF;
        --text-secondary: rgba(255, 255, 255, 0.7);
        --text-muted: rgba(255, 255, 255, 0.4);
        --accent-blue: #3B82F6;
        --accent-green: #10B981;
        --accent-yellow: #F59E0B;
        --accent-red: #EF4444;
        --accent-purple: #8B5CF6;
        --accent-orange: #F97316;
        --gradient-blue: linear-gradient(135deg, #3B82F6, #8B5CF6);
        --gradient-green: linear-gradient(135deg, #10B981, #3B82F6);
        --gradient-yellow: linear-gradient(135deg, #F59E0B, #EC4899);
        --gradient-red: linear-gradient(135deg, #EF4444, #EC4899);
        --gradient-orange: linear-gradient(135deg, #F97316, #EC4899);
        --gradient-purple: linear-gradient(135deg, #8B5CF6, #EC4899);
        --shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
        --shadow-lg: 0 15px 40px rgba(0, 0, 0, 0.5);
        --glass-bg: rgba(20, 20, 30, 0.4);
        --glass-border: 1px solid rgba(255, 255, 255, 0.03);
        --glass-border-hover: 1px solid rgba(239, 68, 68, 0.2);
        --glass-blur: blur(15px);
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    }

    /* ===== АНИМИРОВАННЫЙ ФОН ===== */
    .background-animation {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .gradient-sphere-1 {
        position: absolute;
        width: 80vmax;
        height: 80vmax;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%, 
            rgba(239, 68, 68, 0.15) 0%, 
            rgba(245, 158, 11, 0.1) 40%, 
            rgba(236, 72, 153, 0.05) 70%, 
            transparent 100%);
        top: -20%;
        right: -10%;
        animation: floatSlow 30s ease-in-out infinite;
        filter: blur(60px);
    }

    .gradient-sphere-2 {
        position: absolute;
        width: 70vmax;
        height: 70vmax;
        border-radius: 50%;
        background: radial-gradient(circle at 70% 70%, 
            rgba(245, 158, 11, 0.15) 0%, 
            rgba(239, 68, 68, 0.1) 40%, 
            rgba(236, 72, 153, 0.05) 70%, 
            transparent 100%);
        bottom: -20%;
        left: -10%;
        animation: floatMedium 25s ease-in-out infinite reverse;
        filter: blur(60px);
    }

    .gradient-sphere-3 {
        position: absolute;
        width: 60vmax;
        height: 60vmax;
        border-radius: 50%;
        background: radial-gradient(circle, 
            rgba(239, 68, 68, 0.1) 0%, 
            rgba(245, 158, 11, 0.05) 30%, 
            rgba(236, 72, 153, 0.02) 60%, 
            transparent 100%);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        animation: pulse 15s ease-in-out infinite;
        filter: blur(70px);
    }

    @keyframes floatSlow {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(3%, -3%) scale(1.1); }
        66% { transform: translate(-2%, 2%) scale(0.95); }
    }

    @keyframes floatMedium {
        0%, 100% { transform: translate(0, 0) scale(1); }
        25% { transform: translate(4%, -4%) scale(1.15); }
        50% { transform: translate(-3%, 3%) scale(0.9); }
        75% { transform: translate(2%, -2%) scale(1.05); }
    }

    @keyframes pulse {
        0%, 100% { 
            opacity: 0.3;
            transform: translate(-50%, -50%) scale(1);
        }
        50% { 
            opacity: 0.6;
            transform: translate(-50%, -50%) scale(1.3);
        }
    }

    /* Декоративные звездочки */
    .decorative-star {
        position: fixed;
        color: rgba(255, 255, 255, 0.15);
        font-size: 2rem;
        pointer-events: none;
        animation: floatStar 10s linear infinite;
        z-index: 0;
    }

    @keyframes floatStar {
        from { transform: rotate(0deg) translateY(0); }
        to { transform: rotate(360deg) translateY(-20px); }
    }

    /* ===== ОСНОВНОЙ КОНТЕЙНЕР ===== */
    .excluded-content {
        width: 100%;
        max-width: 1600px;
        margin: 2rem auto 0;
        padding: 120px 0 2rem;
        animation: fadeIn 0.6s ease-out;
        position: relative;
        z-index: 1;
    }

    @keyframes fadeIn {
        from { 
            opacity: 0; 
            transform: translateY(20px); 
        }
        to { 
            opacity: 1; 
            transform: translateY(0); 
        }
    }

    /* ===== ВЕРХНЯЯ ПАНЕЛЬ ===== */
    .top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        padding: 1.5rem 2rem;
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 30px;
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
    }

    .top-bar::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(239, 68, 68, 0.1) 0%, transparent 70%);
        animation: rotate 30s linear infinite;
        pointer-events: none;
    }

    .top-bar::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--accent-red), var(--accent-orange), transparent);
    }

    @keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .title-section {
        display: flex;
        align-items: center;
        gap: 1rem;
        position: relative;
        z-index: 1;
    }

    .title-section i {
        font-size: 2rem;
        color: var(--accent-red);
        filter: drop-shadow(0 0 20px rgba(239, 68, 68, 0.5));
        animation: floatIcon 3s ease-in-out infinite;
    }

    @keyframes floatIcon {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-5px) rotate(5deg); }
    }

    .title-section h1 {
        font-size: 2rem;
        font-weight: 800;
        background: linear-gradient(135deg, #fff, var(--accent-red), var(--accent-orange));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        margin: 0;
        letter-spacing: -0.5px;
    }

    /* Кнопка обновления */
    .refresh-button {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.8rem 1.5rem;
        background: rgba(255, 255, 255, 0.05);
        border: var(--glass-border);
        border-radius: 40px;
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.3s ease;
        backdrop-filter: var(--glass-blur);
    }

    .refresh-button:hover {
        background: rgba(239, 68, 68, 0.1);
        border-color: var(--accent-red);
        color: white;
        transform: translateY(-2px);
    }

    .refresh-button i {
        transition: transform 0.5s ease;
    }

    .refresh-button:hover i {
        transform: rotate(180deg);
    }

    .refresh-button.loading i {
        animation: spin 1s linear infinite;
    }

    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* Кнопка экспорта */
    .export-button {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.8rem 1.5rem;
        background: rgba(255, 255, 255, 0.05);
        border: var(--glass-border);
        border-radius: 40px;
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.3s ease;
        backdrop-filter: var(--glass-blur);
        margin-left: 1rem;
    }

    .export-button:hover {
        background: rgba(16, 185, 129, 0.1);
        border-color: var(--accent-green);
        color: white;
        transform: translateY(-2px);
    }

    /* ===== СТАТИСТИКА ===== */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 24px;
        padding: 1.5rem;
        transition: all 0.3s ease;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        border-color: var(--accent-red);
        box-shadow: 0 10px 30px rgba(239, 68, 68, 0.2);
    }

    .stat-card.active {
        border-color: var(--accent-red);
        box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.3);
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: radial-gradient(circle at 20% 30%, rgba(239, 68, 68, 0.1) 0%, transparent 70%);
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

    .stat-card:hover::before {
        opacity: 1;
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }

    .stat-icon.total {
        background: rgba(139, 92, 246, 0.15);
        color: var(--accent-purple);
        border: 1px solid rgba(139, 92, 246, 0.3);
    }

    .stat-icon.rejected {
        background: rgba(239, 68, 68, 0.15);
        color: var(--accent-red);
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .stat-icon.excluded {
        background: rgba(245, 158, 11, 0.15);
        color: var(--accent-orange);
        border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .stat-icon.blacklisted {
        background: rgba(0, 0, 0, 0.3);
        color: #ffffff;
        border: 1px solid var(--accent-red);
    }

    .stat-info {
        flex: 1;
    }

    .stat-label {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .stat-number {
        font-size: 2.2rem;
        font-weight: 800;
        line-height: 1;
        background: linear-gradient(135deg, #fff, #e0e0e0);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        letter-spacing: -1px;
    }

    /* ===== ФИЛЬТРЫ ===== */
    .filters-section {
        display: flex;
        gap: 0.8rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .filter-button {
        padding: 0.8rem 1.8rem;
        border-radius: 40px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        border: var(--glass-border);
        background: rgba(20, 20, 30, 0.2);
        backdrop-filter: var(--glass-blur);
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .filter-button:hover {
        background: rgba(239, 68, 68, 0.15);
        border-color: var(--accent-red);
        color: white;
        transform: translateY(-2px);
    }

    .filter-button.active {
        background: var(--gradient-red);
        color: white;
        border-color: transparent;
        box-shadow: 0 8px 25px rgba(239, 68, 68, 0.3);
    }

    .filter-button i {
        font-size: 1rem;
    }

    .filter-button .count {
        background: rgba(255, 255, 255, 0.1);
        padding: 0.2rem 0.6rem;
        border-radius: 30px;
        font-size: 0.8rem;
        margin-left: 0.3rem;
    }

    .filter-button.active .count {
        background: rgba(255, 255, 255, 0.2);
    }

    /* ===== ПОИСК ===== */
    .search-section {
        margin-bottom: 2rem;
        position: relative;
    }

    .search-box {
        position: relative;
        max-width: 400px;
    }

    .search-box i {
        position: absolute;
        left: 1.2rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 1rem;
        z-index: 1;
    }

    .search-input {
        width: 100%;
        padding: 1rem 1rem 1rem 3rem;
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 60px;
        color: var(--text-primary);
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--accent-red);
        box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.15);
        background: rgba(20, 20, 30, 0.6);
    }

    .search-clear {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        cursor: pointer;
        padding: 0.5rem;
        border-radius: 50%;
        transition: all 0.2s ease;
    }

    .search-clear:hover {
        color: var(--accent-red);
        background: rgba(239, 68, 68, 0.1);
    }

    /* ===== СЕТКА ===== */
    .excluded-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    /* ===== КАРТОЧКА ===== */
    .excluded-card {
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 30px;
        padding: 1.5rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

    .excluded-card:hover {
        transform: translateY(-5px);
        border-color: var(--accent-red);
        box-shadow: var(--shadow-lg);
    }

    .excluded-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(239, 68, 68, 0.05) 0%, transparent 70%);
        opacity: 0;
        transition: opacity 0.6s ease;
        pointer-events: none;
    }

    .excluded-card:hover::before {
        opacity: 1;
        animation: rotate 20s linear infinite;
    }

    /* Заголовок карточки */
    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
        padding-bottom: 1rem;
        border-bottom: var(--glass-border);
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.4rem 1.2rem;
        border-radius: 60px;
        font-size: 0.85rem;
        font-weight: 600;
        backdrop-filter: var(--glass-blur);
    }

    .status-badge.rejected {
        background: rgba(239, 68, 68, 0.15);
        color: var(--accent-red);
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .status-badge.excluded {
        background: rgba(245, 158, 11, 0.15);
        color: var(--accent-orange);
        border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .status-badge.blacklisted {
        background: rgba(0, 0, 0, 0.5);
        color: #ffffff;
        border: 1px solid var(--accent-red);
    }

    .application-id {
        color: var(--text-muted);
        font-size: 0.8rem;
        font-family: monospace;
        background: rgba(0, 0, 0, 0.2);
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
    }

    /* Информация о пользователе */
    .user-info {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.2rem;
    }

    .user-avatar {
        width: 60px;
        height: 60px;
        border-radius: 18px;
        border: 2px solid var(--accent-red);
        object-fit: cover;
        box-shadow: 0 5px 15px rgba(239, 68, 68, 0.3);
    }

    .user-details {
        flex: 1;
    }

    .user-name {
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.3rem;
        font-size: 1.2rem;
    }

    .user-discord {
        color: var(--text-secondary);
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .user-discord i {
        color: var(--accent-blue);
    }

    /* Детали */
    .user-details-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.8rem;
        margin-bottom: 1rem;
    }

    .detail-item {
        background: rgba(0, 0, 0, 0.2);
        border: var(--glass-border);
        border-radius: 16px;
        padding: 0.8rem;
    }

    .detail-label {
        color: var(--text-muted);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.3rem;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .detail-label i {
        font-size: 0.7rem;
        color: var(--accent-red);
    }

    .detail-value {
        color: var(--text-primary);
        font-size: 1rem;
        font-weight: 500;
    }

    /* Время */
    .time-info {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        margin: 1rem 0;
        padding: 0.8rem;
        background: rgba(0, 0, 0, 0.2);
        border-radius: 16px;
        border: var(--glass-border);
    }

    .time-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-muted);
        font-size: 0.8rem;
    }

    .time-item i {
        width: 16px;
        color: var(--accent-red);
    }

    /* Информация об администраторе */
    .reviewed-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0.5rem 0;
        padding: 0.5rem 0.8rem;
        background: rgba(139, 92, 246, 0.1);
        border-radius: 12px;
        border-left: 3px solid var(--accent-purple);
        font-size: 0.8rem;
    }

    .reviewed-info i {
        color: var(--accent-purple);
    }

    .admin-name {
        color: var(--accent-purple);
        font-weight: 600;
    }

    /* Причина */
    .reason-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0.5rem 0;
        padding: 0.5rem 0.8rem;
        background: rgba(239, 68, 68, 0.1);
        border-radius: 12px;
        border-left: 3px solid var(--accent-red);
        font-size: 0.8rem;
    }

    .reason-info i {
        color: var(--accent-red);
    }

    .reason-text {
        color: var(--accent-red);
        font-weight: 500;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* Действия */
    .card-actions {
        display: flex;
        gap: 0.8rem;
        margin-top: 1.5rem;
        padding-top: 1rem;
        border-top: var(--glass-border);
    }

    .action-button {
        flex: 1;
        padding: 0.8rem;
        border-radius: 16px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        background: rgba(59, 130, 246, 0.1);
        color: var(--accent-blue);
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

    .action-button:hover {
        background: rgba(59, 130, 246, 0.2);
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(59, 130, 246, 0.3);
    }

    /* Пустое состояние */
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border-radius: 40px;
        border: 1px dashed rgba(255, 255, 255, 0.1);
        grid-column: 1 / -1;
    }

    .empty-icon {
        font-size: 5rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
        animation: floatIcon 4s ease-in-out infinite;
    }

    .empty-title {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.8rem;
    }

    .empty-text {
        color: var(--text-secondary);
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    /* Скелетон загрузки */
    .loading-skeleton {
        animation: pulse 1.5s ease-in-out infinite;
        pointer-events: none;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .skeleton-card {
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 30px;
        padding: 1.5rem;
    }

    .skeleton-header {
        height: 40px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 20px;
        margin-bottom: 1rem;
    }

    .skeleton-avatar {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 18px;
        margin-right: 1rem;
    }

    .skeleton-line {
        height: 20px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
        margin-bottom: 0.5rem;
    }

