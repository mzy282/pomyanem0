<% 
title = 'Члены семьи';
%>

<%- include('../layouts/main') %>

<!-- Подключаем Socket.IO -->
<script src="/socket.io/socket.io.js"></script>

<style>
    /* ===== ОСНОВНЫЕ ПЕРЕМЕННЫЕ ===== */
    :root {
        --bg-primary: #0A0A0A;
        --bg-secondary: #111111;
        --bg-card: rgba(26, 26, 26, 0.6);
        --bg-card-hover: rgba(34, 34, 34, 0.8);
        --border-color: rgba(255, 255, 255, 0.05);
        --border-color-hover: rgba(139, 92, 246, 0.2);
        --text-primary: #FFFFFF;
        --text-secondary: rgba(255, 255, 255, 0.7);
        --text-muted: rgba(255, 255, 255, 0.4);
        --accent-blue: #3B82F6;
        --accent-green: #10B981;
        --accent-yellow: #F59E0B;
        --accent-red: #EF4444;
        --accent-purple: #8B5CF6;
        --accent-voice: #EC4899;
        --accent-orange: #F97316;
        --accent-archive: #6B7280;
        --gradient-blue: linear-gradient(135deg, #3B82F6, #8B5CF6);
        --gradient-green: linear-gradient(135deg, #10B981, #3B82F6);
        --gradient-yellow: linear-gradient(135deg, #F59E0B, #EC4899);
        --gradient-red: linear-gradient(135deg, #EF4444, #EC4899);
        --gradient-orange: linear-gradient(135deg, #F97316, #EC4899);
        --gradient-purple: linear-gradient(135deg, #8B5CF6, #EC4899);
        --gradient-archive: linear-gradient(135deg, #6B7280, #4B5563);
        --shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
        --shadow-lg: 0 15px 40px rgba(0, 0, 0, 0.5);
        --glass-bg: rgba(20, 20, 30, 0.4);
        --glass-border: 1px solid rgba(255, 255, 255, 0.03);
        --glass-border-hover: 1px solid rgba(139, 92, 246, 0.2);
        --glass-blur: blur(15px);
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    }

    /* Tier цвета */
    .tier-1 {
        background: linear-gradient(135deg, #F59E0B, #EC4899);
        color: white;
        border: 1px solid rgba(245, 158, 11, 0.5);
        box-shadow: 0 0 15px rgba(245, 158, 11, 0.3);
    }

    .tier-2 {
        background: linear-gradient(135deg, #8B5CF6, #3B82F6);
        color: white;
        border: 1px solid rgba(139, 92, 246, 0.5);
        box-shadow: 0 0 15px rgba(139, 92, 246, 0.3);
    }

    .tier-3 {
        background: linear-gradient(135deg, #10B981, #3B82F6);
        color: white;
        border: 1px solid rgba(16, 185, 129, 0.5);
        box-shadow: 0 0 15px rgba(16, 185, 129, 0.3);
    }

    /* ===== АНИМИРОВАННЫЙ ФОН ===== */
    .background-animation {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .gradient-sphere-1 {
        position: absolute;
        width: 80vmax;
        height: 80vmax;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%, 
            rgba(16, 185, 129, 0.2) 0%, 
            rgba(59, 130, 246, 0.15) 40%, 
            rgba(139, 92, 246, 0.1) 70%, 
            transparent 100%);
        top: -20%;
        right: -10%;
        animation: floatSlow 30s ease-in-out infinite;
        filter: blur(60px);
    }

    .gradient-sphere-2 {
        position: absolute;
        width: 70vmax;
        height: 70vmax;
        border-radius: 50%;
        background: radial-gradient(circle at 70% 70%, 
            rgba(139, 92, 246, 0.2) 0%, 
            rgba(59, 130, 246, 0.15) 40%, 
            rgba(16, 185, 129, 0.1) 70%, 
            transparent 100%);
        bottom: -20%;
        left: -10%;
        animation: floatMedium 25s ease-in-out infinite reverse;
        filter: blur(60px);
    }

    .gradient-sphere-3 {
        position: absolute;
        width: 60vmax;
        height: 60vmax;
        border-radius: 50%;
        background: radial-gradient(circle, 
            rgba(16, 185, 129, 0.15) 0%, 
            rgba(59, 130, 246, 0.1) 30%, 
            rgba(139, 92, 246, 0.05) 60%, 
            transparent 100%);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        animation: pulse 15s ease-in-out infinite;
        filter: blur(70px);
    }

    @keyframes floatSlow {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(3%, -3%) scale(1.1); }
        66% { transform: translate(-2%, 2%) scale(0.95); }
    }

    @keyframes floatMedium {
        0%, 100% { transform: translate(0, 0) scale(1); }
        25% { transform: translate(4%, -4%) scale(1.15); }
        50% { transform: translate(-3%, 3%) scale(0.9); }
        75% { transform: translate(2%, -2%) scale(1.05); }
    }

    @keyframes pulse {
        0%, 100% { 
            opacity: 0.3;
            transform: translate(-50%, -50%) scale(1);
        }
        50% { 
            opacity: 0.6;
            transform: translate(-50%, -50%) scale(1.3);
        }
    }

    /* Декоративные звездочки */
    .decorative-star {
        position: fixed;
        color: rgba(255, 255, 255, 0.15);
        font-size: 2rem;
        pointer-events: none;
        animation: floatStar 10s linear infinite;
        z-index: 0;
    }

    @keyframes floatStar {
        from { transform: rotate(0deg) translateY(0); }
        to { transform: rotate(360deg) translateY(-20px); }
    }

    /* ===== ОСНОВНОЙ КОНТЕЙНЕР ===== */
    .members-content {
        width: 100%;
        max-width: 1400px;
        margin: 2rem auto 0;
        padding: 100px 0 2rem;
        animation: fadeIn 0.6s ease-out;
        position: relative;
        z-index: 1;
    }

    @keyframes fadeIn {
        from { 
            opacity: 0; 
            transform: translateY(20px); 
        }
        to { 
            opacity: 1; 
            transform: translateY(0); 
        }
    }

    /* ===== ВЕРХНЯЯ ПАНЕЛЬ ===== */
    .top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding: 1rem 1.5rem;
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 24px;
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
    }

    .top-bar::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(16, 185, 129, 0.1) 0%, transparent 70%);
        animation: rotate 30s linear infinite;
        pointer-events: none;
    }

    .top-bar::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--accent-green), var(--accent-blue), transparent);
    }

    @keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .title-section {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        position: relative;
        z-index: 1;
    }

    .title-section i {
        font-size: 1.6rem;
        color: var(--accent-green);
        filter: drop-shadow(0 0 20px rgba(16, 185, 129, 0.5));
        animation: floatIcon 3s ease-in-out infinite;
    }

    @keyframes floatIcon {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-5px) rotate(5deg); }
    }

    .title-section h1 {
        font-size: 1.6rem;
        font-weight: 800;
        background: linear-gradient(135deg, #fff, var(--accent-green), var(--accent-blue));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .refresh-button {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.2rem;
        background: rgba(255, 255, 255, 0.05);
        border: var(--glass-border);
        border-radius: 40px;
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.3s ease;
        backdrop-filter: var(--glass-blur);
        font-size: 0.9rem;
    }

    .refresh-button:hover {
        background: rgba(16, 185, 129, 0.1);
        border-color: var(--accent-green);
        color: white;
        transform: translateY(-2px);
    }

    .refresh-button i {
        transition: transform 0.5s ease;
    }

    .refresh-button:hover i {
        transform: rotate(180deg);
    }

    .search-button {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.2rem;
        background: rgba(139, 92, 246, 0.15);
        border: 1px solid rgba(139, 92, 246, 0.3);
        border-radius: 40px;
        color: var(--accent-purple);
        cursor: pointer;
        transition: all 0.3s ease;
        backdrop-filter: var(--glass-blur);
        margin-left: 1rem;
        font-size: 0.9rem;
    }

    .search-button:hover {
        background: rgba(139, 92, 246, 0.25);
        border-color: var(--accent-purple);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(139, 92, 246, 0.3);
    }

    .action-buttons-group {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .total-stats {
        display: flex;
        align-items: center;
        gap: 1rem;
        position: relative;
        z-index: 1;
    }

    .total-stat-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.4rem 1.2rem;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 40px;
        border: var(--glass-border);
        backdrop-filter: var(--glass-blur);
    }

    .total-stat-icon {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }

    .total-stat-icon.total {
        background: rgba(16, 185, 129, 0.15);
        color: var(--accent-green);
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .total-stat-icon.new {
        background: rgba(245, 158, 11, 0.15);
        color: var(--accent-yellow);
        border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .total-stat-info {
        display: flex;
        flex-direction: column;
    }

    .total-stat-label {
        color: var(--text-secondary);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .total-stat-number {
        font-size: 1.2rem;
        font-weight: 800;
        line-height: 1;
        background: linear-gradient(135deg, #fff, #e0e0e0);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        letter-spacing: -1px;
    }

    .filters-section {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        align-items: center;
    }

    .filter-button {
        padding: 0.5rem 1.2rem;
        border-radius: 40px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        border: var(--glass-border);
        background: rgba(20, 20, 30, 0.2);
        backdrop-filter: var(--glass-blur);
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .filter-button:hover {
        background: rgba(16, 185, 129, 0.25);
        border-color: var(--accent-green);
        color: white;
        transform: translateY(-2px);
    }

    .filter-button.active {
        background: var(--gradient-green);
        color: white;
        border-color: transparent;
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.4);
    }

    .filter-button .count {
        background: rgba(255, 255, 255, 0.1);
        padding: 0.15rem 0.5rem;
        border-radius: 30px;
        font-size: 0.7rem;
        margin-left: 0.2rem;
    }

    .search-box {
        flex: 1;
        min-width: 250px;
        position: relative;
        margin-left: auto;
    }

    .search-box i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 0.9rem;
        z-index: 2;
    }

    .search-input {
        width: 100%;
        padding: 0.6rem 1rem 0.6rem 2.8rem;
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 40px;
        color: var(--text-primary);
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--accent-purple);
        box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.15);
        background: rgba(20, 20, 30, 0.6);
    }

    .clear-search {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        cursor: pointer;
        font-size: 0.9rem;
        z-index: 2;
        transition: color 0.2s ease;
    }

    .clear-search:hover {
        color: var(--accent-red);
    }

    .members-table-container {
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: var(--shadow);
        margin-bottom: 2rem;
    }

    .members-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
    }

    .members-table th {
        text-align: left;
        padding: 0.8rem 1rem;
        background: rgba(0, 0, 0, 0.3);
        color: var(--text-secondary);
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .members-table td {
        padding: 0.8rem 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        color: var(--text-primary);
        vertical-align: middle;
    }

    .members-table tbody tr:hover {
        background: rgba(255, 255, 255, 0.02);
    }

    .table-user {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .table-avatar {
        width: 32px;
        height: 32px;
        border-radius: 10px;
        border: 2px solid var(--accent-green);
        object-fit: cover;
    }

    .table-user-info {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
    }

    .table-realname {
        font-weight: 600;
        color: var(--text-primary);
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .table-realname i {
        color: var(--accent-green);
        font-size: 0.7rem;
    }

    .table-discord {
        font-size: 0.7rem;
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .table-discord i {
        color: var(--accent-blue);
        font-size: 0.6rem;
    }

    .table-user-id {
        font-size: 0.6rem;
        color: var(--text-muted);
        font-family: monospace;
    }

    .table-tier {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        font-weight: 700;
        font-size: 0.9rem;
        margin-right: 0.3rem;
    }

    .table-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.25rem 0.8rem;
        border-radius: 40px;
        font-size: 0.75rem;
        font-weight: 600;
        backdrop-filter: var(--glass-blur);
        white-space: nowrap;
    }

    .table-badge.new {
        background: rgba(16, 185, 129, 0.15);
        color: var(--accent-green);
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .table-details {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .table-detail-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--text-secondary);
        font-size: 0.75rem;
    }

    .table-detail-item i {
        color: var(--accent-green);
        font-size: 0.7rem;
        width: 14px;
    }

    .table-detail-item span {
        color: var(--text-primary);
        font-weight: 500;
        font-size: 0.75rem;
    }

    .table-date {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--text-secondary);
        font-size: 0.7rem;
    }

    .table-date i {
        color: var(--accent-green);
        font-size: 0.7rem;
    }

    .table-actions {
        display: flex;
        gap: 0.2rem;
        flex-wrap: wrap;
        align-items: center;
    }

    .table-action-btn {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        border: none;
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-secondary);
        font-size: 0.8rem;
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
    }

    .table-action-btn:hover {
        transform: translateY(-2px);
    }

    .table-action-btn.view {
        color: var(--accent-blue);
    }

    .table-action-btn.view:hover {
        background: rgba(59, 130, 246, 0.2);
        color: white;
        border-color: var(--accent-blue);
    }

    .table-action-btn.exclude {
        color: var(--accent-red);
    }

    .table-action-btn.exclude:hover {
        background: rgba(239, 68, 68, 0.2);
        color: white;
        border-color: var(--accent-red);
    }

    /* Индикатор заметки */
    .note-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: var(--accent-red);
        box-shadow: 0 0 10px var(--accent-red);
        animation: pulse-red 2s infinite;
        margin-left: 0.3rem;
        display: inline-block;
    }

    @keyframes pulse-red {
        0% {
            box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
        }
        70% {
            box-shadow: 0 0 0 6px rgba(239, 68, 68, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(239, 68, 68, 0);
        }
    }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border-radius: 24px;
        border: 1px dashed rgba(255, 255, 255, 0.1);
    }

    .empty-icon {
        font-size: 4rem;
        color: var(--text-muted);
        margin-bottom: 1rem;
        animation: floatIcon 4s ease-in-out infinite;
    }

    .empty-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .empty-text {
        color: var(--text-secondary);
        font-size: 1rem;
        margin-bottom: 1.5rem;
    }

    .loading-skeleton {
        animation: pulse 1.5s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    /* ===== МОДАЛЬНЫЕ ОКНА ===== */
    .modal {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: var(--glass-blur);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        visibility: hidden;
        transition: all 0.4s ease;
    }

    .modal.show {
        opacity: 1;
        visibility: visible;
    }

    .modal-content {
        background: rgba(20, 20, 30, 0.4);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 30px;
        padding: 2rem;
        max-width: 550px;
        width: 90%;
        max-height: 85vh;
        overflow-y: auto;
        position: relative;
        transform: translateY(-30px) scale(0.95);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: var(--shadow-lg);
    }

    .modal.show .modal-content {
        transform: translateY(0) scale(1);
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: var(--glass-border);
    }

    .modal-header h3 {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
    }

    .modal-close {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: var(--glass-border);
        background: rgba(255, 255, 255, 0.02);
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-close:hover {
        background: rgba(239, 68, 68, 0.15);
        color: #EF4444;
        transform: rotate(90deg);
    }

    .modal-input, .modal-select {
        width: 100%;
        padding: 0.8rem 1.2rem;
        background: rgba(0, 0, 0, 0.3);
        backdrop-filter: var(--glass-blur);
        border: var(--glass-border);
        border-radius: 40px;
        color: var(--text-primary);
        font-size: 0.9rem;
        transition: all 0.3s ease;
        margin-bottom: 1rem;
        appearance: none;
        cursor: pointer;
    }

    .modal-select {
