    </div>
</div>

<!-- Модальное окно редактирования заметок -->
<div class="modal" id="editNotesModal">
    <div class="modal-content" style="max-width: 500px;">
        <div class="modal-header">
            <h3>
                <i class="fas fa-sticky-note" style="color: #F59E0B;"></i>
                Заметки
            </h3>
            <button class="modal-close" onclick="hideEditNotesModal()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="modal-body">
            <p>Заметки для <strong id="editNotesUserName"></strong></p>
            
            <div class="form-group" style="margin-bottom: 1rem;">
                <div class="form-label" style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; color: var(--text-secondary);">
                    <i class="fas fa-pen" style="color: var(--accent-yellow);"></i>
                    <span>Текст заметки</span>
                </div>
                <textarea class="modal-textarea" id="editNotesText" placeholder="Введите заметку..." rows="6"></textarea>
            </div>
            
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                <button class="clear-notes-btn" onclick="clearNotes()">
                    <i class="fas fa-trash"></i> Очистить заметку
                </button>
                
                <div style="background: rgba(245, 158, 11, 0.1); border-radius: 12px; padding: 0.5rem 1rem; border-left: 3px solid var(--accent-yellow);">
                    <p style="color: var(--text-secondary); margin: 0; font-size: 0.8rem;">
                        <i class="fas fa-info-circle" style="color: var(--accent-yellow); margin-right: 0.5rem;"></i>
                        Заметки видны только администраторам
                    </p>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="modal-button cancel" onclick="hideEditNotesModal()">Отмена</button>
            <button class="modal-button save" onclick="confirmEditNotes()">Сохранить</button>
        </div>
    </div>
</div>

<!-- Модальное окно профиля -->
<div class="modal" id="profileModal">
    <div class="modal-content" style="max-width: 600px;">
        <div class="modal-header">
            <h3>
                <i class="fas fa-user" style="color: var(--accent-green);"></i>
                Профиль участника
            </h3>
            <button class="modal-close" onclick="hideProfileModal()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="modal-body" id="profileModalBody">
            <!-- Данные профиля будут загружаться динамически -->
        </div>
        <div class="modal-footer" id="profileModalFooter">
            <button class="modal-button cancel" onclick="hideProfileModal()">Закрыть</button>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    let members = [];
    let currentFilter = 'all';
    let currentSearch = '';
    let currentExcludeId = null;
    let currentExcludeName = '';
    let currentExcludeUserId = null;
    let currentTierId = null;
    let currentTierName = '';
    let currentTierUserId = null;
    let currentTierValue = 3;
    let selectedTier = 3;
    let currentEditNickStaticId = null;
    let currentEditNickStaticUserId = null;
    let currentEditNickStaticUserName = '';
    let currentEditRealNameId = null;
    let currentEditRealNameUserId = null;
    let currentEditRealNameUserName = '';
    let currentEditNotesId = null;
    let currentEditNotesUserId = null;
    let currentEditNotesUserName = '';
    let currentMemberForNotes = null;
    let isLoading = false;

    // ===== WEBSOCKET =====
    const socket = io();
    
    socket.on('connect', () => {
        console.log('🔌 WebSocket подключен');
        socket.emit('subscribe_members');
    });
    
    socket.on('member_added', (data) => {
        console.log('👥 Новый член семьи:', data);
        loadMembers();
        showNotification(`👥 Новый член семьи: ${data.username || 'Пользователь'}`);
    });
    
    socket.on('member_removed', (data) => {
        console.log('👋 Участник исключен:', data);
        loadMembers();
        showNotification(`👋 Участник исключен из семьи`);
    });
    
    socket.on('member_updated', () => {
        loadMembers();
    });

    // ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====
    function formatDate(dateString) {
        if (!dateString) return 'Неизвестно';
        const date = new Date(dateString);
        return date.toLocaleString('ru-RU', {
            day: '2-digit',
            month: '2-digit',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function formatDateShort(dateString) {
        if (!dateString) return 'Неизвестно';
        const date = new Date(dateString);
        return date.toLocaleDateString('ru-RU', {
            day: '2-digit',
            month: '2-digit',
            year: 'numeric'
        });
    }

    function showNotification(message, type = 'success') {
        const notification = document.createElement('div');
        notification.className = `notification ${type === 'error' ? 'error' : ''}`;
        notification.innerHTML = `
            <i class="fas fa-${type === 'error' ? 'exclamation-circle' : 'check-circle'}"></i>
            <span>${message}</span>
        `;
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.style.animation = 'slideDown 0.3s ease-in forwards';
            setTimeout(() => notification.remove(), 300);
        }, 3000);
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    // Функция для безопасного экранирования строк в onclick атрибутах
    function escapeForOnclick(str) {
        if (!str) return '';
        return str.replace(/'/g, "\\'").replace(/"/g, '&quot;');
    }

    function truncateText(text, maxLength) {
        if (!text) return '';
        if (text.length <= maxLength) return escapeHtml(text);
        return escapeHtml(text.substring(0, maxLength)) + '...';
    }

    function getTierClass(tier) {
        if (tier === 1) return 'tier-1';
        if (tier === 2) return 'tier-2';
        return 'tier-3';
    }

    function getTierIcon(tier) {
        if (tier === 1) return 'crown';
        if (tier === 2) return 'star';
        return 'user';
    }

    function showLoading() {
        const container = document.getElementById('membersTableContainer');
        container.innerHTML = `
            <div class="members-table-container">
                <table class="members-table">
                    <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Tier</th>
                            <th>Ник / Static</th>
                            <th>В семье с</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${Array(5).fill(0).map(() => `
                            <tr class="loading-skeleton">
                                <td><div style="height: 18px; width: 120px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                <td><div style="height: 18px; width: 40px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                <td><div style="height: 18px; width: 80px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                <td><div style="height: 18px; width: 70px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                                <td><div style="height: 18px; width: 60px; background: rgba(255,255,255,0.05); border-radius: 4px;"></div></td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            </div>
        `;
    }

    function updateClearSearchButton() {
        const clearBtn = document.getElementById('clearSearchBtn');
        if (clearBtn) {
            clearBtn.style.display = currentSearch ? 'block' : 'none';
        }
    }

    // ===== МОДАЛЬНЫЕ ОКНА =====
    window.showProfileModal = function(member) {
        const modalBody = document.getElementById('profileModalBody');
        const modalFooter = document.getElementById('profileModalFooter');
        
        const joinDate = member.joined_at || member.created_at;
        const tier = member.tier || 3;
        const tierClass = getTierClass(tier);
        const tierIcon = getTierIcon(tier);
        
        // Получаем реальное имя и возраст
        let realName = member.real_name || '';
        let birthDate = member.birth_date || '';
        
        // Если нет real_name, пытаемся получить из full_name
        if (!realName && member.full_name) {
            const parts = member.full_name.split(',');
            realName = parts[0] || '';
            if (!birthDate && parts.length > 1) {
                birthDate = parts[1].trim();
            }
        }
        
        // Информация о принявшем администраторе
        let reviewerInfo = '';
        if (member.reviewed_by) {
            reviewerInfo = `
                <div class="modal-review-info">
                    <i class="fas fa-user-shield"></i>
                    <div>
                        <span class="reviewer-name">${escapeHtml(member.reviewer_name || 'Администратор')}</span>
                        <span class="review-date">принял(а) ${formatDate(member.reviewed_at || joinDate)}</span>
                    </div>
                </div>
            `;
        }
        
        // Форматируем заметки для отображения
        const notes = member.profile_notes || member.notes || '';
        const notesDisplay = notes ? 
            `<div class="notes-content">${escapeHtml(notes).replace(/\n/g, '<br>')}</div>` : 
            '<span class="modal-field-value">—</span>';
        
        // Экранируем значения для onclick атрибутов
        const safeUsername = escapeForOnclick(member.username);
        const safeRealName = escapeForOnclick(realName);
        const safeBirthDate = escapeForOnclick(birthDate);
        const safeNick = escapeForOnclick(member.nick || '');
        const safeStatic = escapeForOnclick(member.static || '');
        const safeNotes = escapeForOnclick(notes);
        
        modalBody.innerHTML = `
            <div class="modal-profile">
                <img src="${member.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png'}" 
                     alt="" class="modal-avatar"
                     onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                <div class="modal-user-info">
                    <div class="modal-username">
                        ${escapeHtml(member.username)}
                        <span class="modal-tier-badge ${tierClass}" onclick="hideProfileModal(); setTimeout(() => showTierModalFromProfile(${member.id}, '${member.user_id}', '${safeUsername}', ${tier}), 300)" title="Изменить Tier">
                            <i class="fas fa-${tierIcon}"></i>
                        </span>
                    </div>
                    <div class="modal-discord">
                        <i class="fab fa-discord"></i>
                        ${escapeHtml(member.discord_name)}
                    </div>
                    <div class="modal-user-id">ID: ${member.user_id}</div>
                </div>
            </div>
            
            ${reviewerInfo}
            
            <div style="margin-bottom: 1rem; padding: 0.5rem 0.8rem; background: rgba(16, 185, 129, 0.1); border-radius: 12px; border-left: 3px solid var(--accent-green);">
                <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-muted); font-size: 0.75rem;">
                    <i class="fas fa-calendar-alt" style="color: var(--accent-green);"></i>
                    <span>В семье с <strong>${formatDate(joinDate)}</strong></span>
                </div>
            </div>
            
            <div class="modal-grid">
                <div class="modal-field">
                    <div class="modal-field-label">
                        <i class="fas fa-user-tag"></i>
                        Отображаемое имя
                    </div>
                    <div class="modal-field-value editable" onclick="hideProfileModal(); setTimeout(() => showEditRealNameModal(${member.id}, '${member.user_id}', '${safeUsername}', '${safeRealName}', '${safeBirthDate}'), 300)">
                        ${escapeHtml(realName) || '—'}
                        <i class="fas fa-pen" title="Редактировать"></i>
                    </div>
                </div>
                <div class="modal-field">
                    <div class="modal-field-label">
                        <i class="fas fa-birthday-cake"></i>
                        Возраст / ДР
                    </div>
                    <div class="modal-field-value editable" onclick="hideProfileModal(); setTimeout(() => showEditRealNameModal(${member.id}, '${member.user_id}', '${safeUsername}', '${safeRealName}', '${safeBirthDate}'), 300)">
                        ${escapeHtml(birthDate) || '—'}
                        <i class="fas fa-pen" title="Редактировать"></i>
                    </div>
                </div>
            </div>
            
            <div class="modal-grid">
                <div class="modal-field">
                    <div class="modal-field-label">
                        <i class="fas fa-tag"></i>
                        Nick
                    </div>
                    <div class="modal-field-value editable" onclick="hideProfileModal(); setTimeout(() => showEditNickStaticModal(${member.id}, '${member.user_id}', '${safeUsername}', '${safeNick}', '${safeStatic}'), 300)">
                        ${escapeHtml(member.nick) || '—'}
                        <i class="fas fa-pen" title="Редактировать"></i>
                    </div>
                </div>
                <div class="modal-field">
                    <div class="modal-field-label">
                        <i class="fas fa-hashtag"></i>
                        Static
                    </div>
                    <div class="modal-field-value editable" onclick="hideProfileModal(); setTimeout(() => showEditNickStaticModal(${member.id}, '${member.user_id}', '${safeUsername}', '${safeNick}', '${safeStatic}'), 300)">
                        ${escapeHtml(member.static) || '—'}
                        <i class="fas fa-pen" title="Редактировать"></i>
                    </div>
                </div>
            </div>
            
            <div class="modal-field full-width">
                <div class="modal-field-label">
                    <i class="fas fa-layer-group"></i>
                    Tier
                </div>
                <div class="modal-field-value editable" onclick="hideProfileModal(); setTimeout(() => showTierModalFromProfile(${member.id}, '${member.user_id}', '${safeUsername}', ${tier}), 300)">
                    <span class="table-tier ${tierClass}">
                        <i class="fas fa-${tierIcon}"></i>
                    </span>
                    Tier ${tier}
                    <i class="fas fa-pen" style="margin-left: 0.5rem;" title="Изменить"></i>
                </div>
            </div>
            
            <div class="modal-field full-width">
                <div class="modal-field-label">
                    <div class="notes-header">
                        <i class="fas fa-sticky-note" style="color: var(--accent-yellow);"></i>
                        Заметки администратора
                        ${notes ? '<span class="note-indicator" style="margin-left: 0.5rem;" title="Есть заметки"></span>' : ''}
                        ${notes ? `
                            <button class="clear-notes-btn" onclick="event.stopPropagation(); deleteNotes(${member.id}, '${member.user_id}', '${safeUsername}')" title="Удалить заметку">
                                <i class="fas fa-trash"></i>
                            </button>
                        ` : ''}
                    </div>
                </div>
                <div class="modal-field-value editable" onclick="hideProfileModal(); setTimeout(() => showEditNotesModal(${member.id}, '${member.user_id}', '${safeUsername}', '${safeNotes}'), 300)">
                    ${notes ? 'Редактировать заметки' : 'Добавить заметки'}
                    <i class="fas fa-pen" title="${notes ? 'Редактировать' : 'Добавить'}"></i>
                </div>
                ${notes ? notesDisplay : ''}
            </div>
        `;
        
        modalFooter.innerHTML = `
            <button class="modal-button cancel" onclick="hideProfileModal()">Закрыть</button>
        `;
        
        document.getElementById('profileModal').classList.add('show');
    };

    window.hideProfileModal = function() {
        const modal = document.getElementById('profileModal');
        modal.classList.remove('show');
    };

    window.showExcludeModal = function(applicationId, username, userId) {
        currentExcludeId = applicationId;
        currentExcludeName = username;
        currentExcludeUserId = userId;
        document.getElementById('excludeMemberName').textContent = username;
        document.getElementById('excludeReason').value = '';
        document.getElementById('excludeBlacklist').checked = false;
        document.getElementById('excludeModal').classList.add('show');
    };

    window.hideExcludeModal = function() {
        document.getElementById('excludeModal').classList.remove('show');
        currentExcludeId = null;
        currentExcludeName = '';
        currentExcludeUserId = null;
    };

    window.confirmExclude = async function() {
        if (!currentExcludeId || !currentExcludeUserId) return;
        
        const reason = document.getElementById('excludeReason').value.trim();
        const blacklist = document.getElementById('excludeBlacklist').checked;
        
        if (!reason) {
            showNotification('Укажите причину исключения', 'error');
            return;
        }
        
        const confirmBtn = document.querySelector('#excludeModal .modal-button.exclude');
        const originalText = confirmBtn.innerHTML;
        confirmBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Исключение...';
        confirmBtn.disabled = true;
        
        try {
            const response = await fetch(`/api/admin/family-members/${currentExcludeUserId}/exclude`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ 
                    reason: reason,
                    blacklist: blacklist
                })
            });

            const data = await response.json();

            if (data.success) {
                showNotification(`Участник ${currentExcludeName} исключен${blacklist ? ' и добавлен в черный список' : ''}`);
                hideExcludeModal();
                await loadMembers();
            } else {
                showNotification(data.error || 'Ошибка при исключении участника', 'error');
            }
        } catch (error) {
            console.error('Ошибка при исключении участника:', error);
            showNotification('Ошибка при исключении участника', 'error');
        } finally {
            confirmBtn.innerHTML = originalText;
            confirmBtn.disabled = false;
        }
    };

    // ===== ФУНКЦИИ ДЛЯ TIER =====
    window.showTierModalFromProfile = function(id, userId, username, currentTier) {
        currentTierId = id;
        currentTierUserId = userId;
        currentTierName = username;
        currentTierValue = currentTier || 3;
        selectedTier = currentTier || 3;
        
        document.getElementById('tierMemberName').textContent = username;
        document.getElementById('selectedTierDisplay').textContent = `Tier ${selectedTier}`;
        
        // Подсветка выбранного Tier
        document.querySelectorAll('.tier-option').forEach(opt => opt.classList.remove('selected'));
        document.getElementById(`tierOption${selectedTier}`).classList.add('selected');
        
        document.getElementById('tierModal').classList.add('show');
    };

    window.hideTierModal = function() {
        document.getElementById('tierModal').classList.remove('show');
        currentTierId = null;
        currentTierUserId = null;
        currentTierName = '';
    };

    window.selectTier = function(tier) {
        selectedTier = tier;
        document.querySelectorAll('.tier-option').forEach(opt => opt.classList.remove('selected'));
        document.getElementById(`tierOption${tier}`).classList.add('selected');
        document.getElementById('selectedTierDisplay').textContent = `Tier ${tier}`;
    };

    window.confirmTierChange = async function() {
        if (!currentTierId || !currentTierUserId) return;
        
        const confirmBtn = document.querySelector('#tierModal .modal-button.tier');
        const originalText = confirmBtn.innerHTML;
        confirmBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Сохранение...';
        confirmBtn.disabled = true;
        
        try {
            const response = await fetch(`/api/admin/family-members/${currentTierUserId}/tier`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ 
                    tier: selectedTier
                })
            });

            const data = await response.json();

            if (data.success) {
                showNotification(`Tier изменен на ${selectedTier} для ${currentTierName}`);
                hideTierModal();
                await loadMembers();
            } else {
                showNotification(data.error || 'Ошибка при изменении Tier', 'error');
            }
        } catch (error) {
            console.error('Ошибка при изменении Tier:', error);
            showNotification('Ошибка при изменении Tier', 'error');
        } finally {
            confirmBtn.innerHTML = originalText;
            confirmBtn.disabled = false;
        }
    };

    // ===== ФУНКЦИИ ДЛЯ РЕДАКТИРОВАНИЯ НИКА И СТАТИКА =====
    window.showEditNickStaticModal = function(id, userId, username, currentNick, currentStatic) {
        currentEditNickStaticId = id;
        currentEditNickStaticUserId = userId;
        currentEditNickStaticUserName = username;
        
        document.getElementById('editNickStaticUserName').textContent = username;
        document.getElementById('editNickInput').value = currentNick || '';
        document.getElementById('editStaticInput').value = currentStatic || '';
        
        document.getElementById('editNickStaticModal').classList.add('show');
    };

    window.hideEditNickStaticModal = function() {
        document.getElementById('editNickStaticModal').classList.remove('show');
        currentEditNickStaticId = null;
        currentEditNickStaticUserId = null;
        currentEditNickStaticUserName = '';
    };

    window.confirmEditNickStatic = async function() {
        if (!currentEditNickStaticId || !currentEditNickStaticUserId) return;
        
        const nick = document.getElementById('editNickInput').value.trim();
        const staticVal = document.getElementById('editStaticInput').value.trim();
        
        const confirmBtn = document.querySelector('#editNickStaticModal .modal-button.save');
        const originalText = confirmBtn.innerHTML;
        confirmBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Сохранение...';
        confirmBtn.disabled = true;
        
        try {
            const response = await fetch(`/api/admin/family-members/${currentEditNickStaticUserId}/nick-static`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ 
                    nick: nick,
                    static: staticVal
                })
            });

            const data = await response.json();

            if (data.success) {
                showNotification(`Nick/Static обновлены`);
                hideEditNickStaticModal();
                await loadMembers();
            } else {
                showNotification(data.error || 'Ошибка при обновлении', 'error');
            }
        } catch (error) {
            console.error('Ошибка при обновлении:', error);
            showNotification('Ошибка при обновлении', 'error');
        } finally {
            confirmBtn.innerHTML = originalText;
            confirmBtn.disabled = false;
        }
    };

    // ===== ФУНКЦИИ ДЛЯ РЕДАКТИРОВАНИЯ РЕАЛЬНОГО ИМЕНИ И ВОЗРАСТА =====
    window.showEditRealNameModal = function(id, userId, username, currentRealName, currentBirthDate) {
        currentEditRealNameId = id;
        currentEditRealNameUserId = userId;
        currentEditRealNameUserName = username;
        
        document.getElementById('editRealNameUserName').textContent = username;
        document.getElementById('editRealNameInput').value = currentRealName || '';
        document.getElementById('editBirthdayInput').value = currentBirthDate || '';
        
        document.getElementById('editRealNameModal').classList.add('show');
    };

    window.hideEditRealNameModal = function() {
        document.getElementById('editRealNameModal').classList.remove('show');
        currentEditRealNameId = null;
        currentEditRealNameUserId = null;
        currentEditRealNameUserName = '';
    };

    window.confirmEditRealName = async function() {
        if (!currentEditRealNameId || !currentEditRealNameUserId) return;
        
        const realName = document.getElementById('editRealNameInput').value.trim();
        const birthDate = document.getElementById('editBirthdayInput').value.trim();
        
        const confirmBtn = document.querySelector('#editRealNameModal .modal-button.save');
        const originalText = confirmBtn.innerHTML;
        confirmBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Сохранение...';
        confirmBtn.disabled = true;
        
        try {
            const response = await fetch(`/api/admin/family-members/${currentEditRealNameUserId}/profile`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ 
                    real_name: realName,
                    birth_date: birthDate
                })
            });

            const data = await response.json();

            if (data.success) {
                showNotification(`Профиль обновлен`);
                hideEditRealNameModal();
                await loadMembers();
            } else {
                showNotification(data.error || 'Ошибка при обновлении профиля', 'error');
            }
        } catch (error) {
            console.error('Ошибка при обновлении профиля:', error);
            showNotification('Ошибка при обновлении профиля', 'error');
        } finally {
            confirmBtn.innerHTML = originalText;
            confirmBtn.disabled = false;
        }
    };

    // ===== ФУНКЦИИ ДЛЯ ЗАМЕТОК =====
    window.clearNotes = function() {
        if (confirm('Очистить всю заметку?')) {
            document.getElementById('editNotesText').value = '';
        }
    };

    window.deleteNotes = async function(id, userId, username) {
        if (!confirm('Удалить все заметки?')) return;
        
        try {
            const response = await fetch(`/api/admin/family-members/${userId}/notes`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ 
                    notes: ''
                })
            });

            const data = await response.json();

            if (data.success) {
                showNotification('Заметки удалены');
                hideProfileModal();
                await loadMembers();
            } else {
                showNotification(data.error || 'Ошибка при удалении заметок', 'error');
            }
        } catch (error) {
            console.error('Ошибка при удалении заметок:', error);
            showNotification('Ошибка при удалении заметок', 'error');
        }
    };

    window.showEditNotesModal = function(id, userId, username, currentNotes) {
        currentEditNotesId = id;
        currentEditNotesUserId = userId;
        currentEditNotesUserName = username;
        currentMemberForNotes = { id, userId, username, notes: currentNotes };
        
        document.getElementById('editNotesUserName').textContent = username;
        document.getElementById('editNotesText').value = currentNotes || '';
        
        document.getElementById('editNotesModal').classList.add('show');
    };

    window.hideEditNotesModal = function() {
        document.getElementById('editNotesModal').classList.remove('show');
        currentEditNotesId = null;
        currentEditNotesUserId = null;
        currentEditNotesUserName = null;
        currentMemberForNotes = null;
    };

    window.confirmEditNotes = async function() {
        if (!currentEditNotesId || !currentEditNotesUserId) return;
        
        const notes = document.getElementById('editNotesText').value.trim();
        
        const confirmBtn = document.querySelector('#editNotesModal .modal-button.save');
        const originalText = confirmBtn.innerHTML;
        confirmBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Сохранение...';
        confirmBtn.disabled = true;
        
        try {
            const response = await fetch(`/api/admin/family-members/${currentEditNotesUserId}/notes`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ 
                    notes: notes
                })
            });

            const data = await response.json();

            if (data.success) {
                showNotification(`Заметки обновлены`);
                hideEditNotesModal();
                await loadMembers();
            } else {
                showNotification(data.error || 'Ошибка при обновлении заметок', 'error');
            }
        } catch (error) {
            console.error('Ошибка при обновлении заметок:', error);
            showNotification('Ошибка при обновлении заметок', 'error');
        } finally {
            confirmBtn.innerHTML = originalText;
            confirmBtn.disabled = false;
        }
    };

    // ===== ПОИСК И ФИЛЬТРАЦИЯ =====
    window.searchMembers = function() {
        currentSearch = document.getElementById('searchInput').value.toLowerCase();
        updateClearSearchButton();
        renderMembers();
    };

    window.clearSearch = function() {
        document.getElementById('searchInput').value = '';
        currentSearch = '';
        updateClearSearchButton();
        renderMembers();
    };

    window.filterMembers = function(filter) {
        currentFilter = filter;
        
        document.querySelectorAll('.filter-button').forEach(btn => btn.classList.remove('active'));
        document.getElementById(`filter${filter.charAt(0).toUpperCase() + filter.slice(1)}`).classList.add('active');
        
        renderMembers();
    };

    // ===== ЗАГРУЗКА УЧАСТНИКОВ =====
    window.loadMembers = async function(force = false) {
        if (isLoading && !force) return;
        
        isLoading = true;
        const refreshBtn = document.getElementById('refreshBtn');
        if (refreshBtn) {
            refreshBtn.classList.add('loading');
            const icon = refreshBtn.querySelector('i');
            if (icon) icon.classList.add('fa-spin');
        }
        
        showLoading();
        
        try {
            const response = await fetch('/api/admin/family-members');
            const data = await response.json();
            
            if (data.success) {
                members = data.data;
                // Добавляем tier по умолчанию, если его нет
                members = members.map(m => ({
                    ...m,
                    tier: m.tier || 3,
                    real_name: m.real_name || '',
                    birth_date: m.birth_date || ''
                }));
                updateStats();
                renderMembers();
            } else {
                throw new Error(data.error || 'Не удалось загрузить данные');
            }
        } catch (error) {
            console.error('Ошибка загрузки участников:', error);
            showNotification('Ошибка загрузки участников', 'error');
            
            const container = document.getElementById('membersTableContainer');
            container.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-exclamation-triangle" style="color: #EF4444;"></i>
                    </div>
                    <h3 class="empty-title">Ошибка загрузки</h3>
                    <p class="empty-text">Не удалось загрузить участников</p>
                    <button onclick="loadMembers(true)" class="filter-button" style="margin-top: 1rem;">
                        <i class="fas fa-sync-alt"></i> Повторить
                    </button>
                </div>
            `;
        } finally {
            isLoading = false;
            if (refreshBtn) {
                refreshBtn.classList.remove('loading');
                const icon = refreshBtn.querySelector('i');
                if (icon) icon.classList.remove('fa-spin');
            }
        }
    };

    // ===== ОБНОВЛЕНИЕ СТАТИСТИКИ =====
    function updateStats() {
        const total = members.length;
        const now = new Date();
        const oneMonthAgo = new Date(now.setMonth(now.getMonth() - 1));
        
        const newMembers = members.filter(member => {
            const joinDate = new Date(member.joined_at || member.created_at);
            return joinDate > oneMonthAgo;
        }).length;
        
        document.getElementById('totalMembers').textContent = total;
        document.getElementById('allCount').textContent = total;
        document.getElementById('newCount').textContent = newMembers;
        document.getElementById('newMembers').textContent = newMembers;
    }

    // ===== ОТОБРАЖЕНИЕ УЧАСТНИКОВ =====
    function renderMembers() {
        const container = document.getElementById('membersTableContainer');
        
        let filteredMembers = members;
        
        // Применяем фильтр
        if (currentFilter === 'new') {
            const now = new Date();
            const oneMonthAgo = new Date(now.setMonth(now.getMonth() - 1));
            filteredMembers = filteredMembers.filter(member => {
                const joinDate = new Date(member.joined_at || member.created_at);
                return joinDate > oneMonthAgo;
            });
        }
        
        // Применяем поиск
        if (currentSearch) {
            filteredMembers = filteredMembers.filter(member => 
                (member.username && member.username.toLowerCase().includes(currentSearch)) ||
                (member.real_name && member.real_name.toLowerCase().includes(currentSearch)) ||
                (member.nick && member.nick.toLowerCase().includes(currentSearch)) ||
                (member.static && member.static.toLowerCase().includes(currentSearch)) ||
                (member.discord_name && member.discord_name.toLowerCase().includes(currentSearch)) ||
                (member.user_id && member.user_id.includes(currentSearch))
            );
        }
        
        // Сортируем по дате вступления (новые сверху)
        filteredMembers.sort((a, b) => {
            const dateA = new Date(a.joined_at || a.created_at);
            const dateB = new Date(b.joined_at || b.created_at);
            return dateB - dateA;
        });
        
        if (filteredMembers.length === 0) {
            container.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3 class="empty-title">Нет участников</h3>
                    <p class="empty-text">${currentSearch ? 'По вашему запросу ничего не найдено' : 'Пока нет принятых участников'}</p>
                    ${currentSearch ? '<button onclick="clearSearch()" class="filter-button" style="margin-top: 1rem;">Очистить поиск</button>' : ''}
                </div>
            `;
            return;
        }
        
        let tableHtml = `
            <div class="members-table-container">
                <table class="members-table">
                    <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Tier</th>
                            <th>Ник / Static</th>
                            <th>В семье с</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
        `;
        
        filteredMembers.forEach(member => {
            const avatarUrl = member.avatar_url || 'https://cdn.discordapp.com/embed/avatars/0.png';
            const joinDate = member.joined_at || member.created_at;
            const memberId = member.id;
            const userId = member.user_id;
            const username = member.username || 'Неизвестно';
            const discordName = member.discord_name || username;
            const tier = member.tier || 3;
            const tierClass = getTierClass(tier);
            const tierIcon = getTierIcon(tier);
            
            // Получаем реальное имя
            let realName = member.real_name || '';
            
            // Если нет real_name, пытаемся получить из full_name
            if (!realName && member.full_name) {
                const parts = member.full_name.split(',');
                realName = parts[0] || '';
            }
            
            const isNew = (() => {
                const now = new Date();
                const oneMonthAgo = new Date(now.setMonth(now.getMonth() - 1));
                return new Date(joinDate) > oneMonthAgo;
            })();
            
            // Проверяем наличие непрочитанных заметок
            const hasNotes = member.profile_notes || member.notes;
            
            const memberJson = JSON.stringify(member).replace(/'/g, "\\'").replace(/"/g, '&quot;');
            
            tableHtml += `
                <tr>
                    <td>
                        <div class="table-user">
                            <img src="${avatarUrl}" 
                                 alt="" class="table-avatar"
                                 onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            <div class="table-user-info">
                                <span class="table-realname">
                                    <i class="fas fa-user"></i>
                                    ${escapeHtml(realName) || escapeHtml(username)}
                                </span>
                                <span class="table-discord">
                                    <i class="fab fa-discord"></i>
                                    ${escapeHtml(discordName)}
                                </span>
                                <span class="table-user-id">${userId}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="table-tier ${tierClass}" title="Tier ${tier}">
                            <i class="fas fa-${tierIcon}"></i>
                        </span>
                    </td>
                    <td>
                        <div class="table-details">
                            <div class="table-detail-item">
                                <i class="fas fa-tag" style="color: var(--accent-purple);"></i>
                                <span style="color: var(--accent-purple);">${escapeHtml(member.nick) || '—'}</span>
                            </div>
                            <div class="table-detail-item">
                                <i class="fas fa-hashtag" style="color: var(--accent-yellow);"></i>
                                <span style="color: var(--accent-yellow);">${escapeHtml(member.static) || '—'}</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="table-date">
                            <i class="fas fa-calendar-alt"></i>
                            ${formatDateShort(joinDate)}
                        </div>
                        ${isNew ? '<span class="table-badge new"><i class="fas fa-star"></i> Новый</span>' : ''}
                    </td>
                    <td>
                        <div class="table-actions">
                            <button class="table-action-btn view" onclick='showProfileModal(${memberJson})' title="Просмотр">
                                <i class="fas fa-eye"></i>
                            </button>
                            <button class="table-action-btn exclude" onclick="showExcludeModal(${memberId}, '${escapeHtml(username)}', '${userId}')" title="Исключить">
                                <i class="fas fa-user-minus"></i>
                            </button>
                            ${hasNotes ? '<span class="note-indicator" title="Есть заметки"></span>' : ''}
                        </div>
                    </td>
                </tr>
            `;
        });
        
        tableHtml += `
                    </tbody>
                </table>
            </div>
        `;
        
        container.innerHTML = tableHtml;
    }

    // ===== ИНИЦИАЛИЗАЦИЯ =====
    document.addEventListener('DOMContentLoaded', () => {
        loadMembers();
        updateClearSearchButton();
        document.getElementById('filterAll').classList.add('active');
    });

    // Закрытие модальных окон
    document.addEventListener('click', (event) => {
        const excludeModal = document.getElementById('excludeModal');
        const profileModal = document.getElementById('profileModal');
        const tierModal = document.getElementById('tierModal');
        const editNickStaticModal = document.getElementById('editNickStaticModal');
        const editRealNameModal = document.getElementById('editRealNameModal');
        const editNotesModal = document.getElementById('editNotesModal');
        
        if (event.target === excludeModal) {
            hideExcludeModal();
        }
        if (event.target === profileModal) {
            hideProfileModal();
        }
        if (event.target === tierModal) {
            hideTierModal();
        }
        if (event.target === editNickStaticModal) {
            hideEditNickStaticModal();
        }
        if (event.target === editRealNameModal) {
            hideEditRealNameModal();
        }
        if (event.target === editNotesModal) {
            hideEditNotesModal();
        }
    });

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            hideExcludeModal();
            hideProfileModal();
            hideTierModal();
            hideEditNickStaticModal();
            hideEditRealNameModal();
            hideEditNotesModal();
        }
    });

})();
</script>